{
  "name": "@mixturemarketing/mm-control-plane",
  "version": "0.0.1",
  "private": true,
  "description": "MixtureMarketing hub — admin dashboard + Hub API + D1 + KV + R2 + Cron",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrations:apply:local": "wrangler d1 migrations apply mm-control-plane --local",
    "migrations:apply:production": "wrangler d1 migrations apply mm-control-plane --env production",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mixturemarketing/logger": "workspace:*",
    "@mixturemarketing/web-core": "workspace:*",
    "hono": "^4.6.12",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9",
    "wrangler": "^3.91.0"
  }
}
