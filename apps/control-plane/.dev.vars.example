# Local dev secrets for mm-control-plane. Copy to `.dev.vars` (gitignored).
# Used by `wrangler dev` AND by Node scripts via `node --env-file=.dev.vars`.

# --- Provisioning (Track 4) ---
PROVISIONING_DRY_RUN="true"

# OVH API — domain registration + DNS. Set up: docs/OVH-SETUP.md
OVH_APP_KEY=""
OVH_APP_SECRET=""
OVH_CONSUMER_KEY=""
OVH_ENDPOINT="ovh-eu"

# GitHub — repo create + commit + workflow_dispatch for klient deploy
GITHUB_PAT=""
GITHUB_ORG="MixtureMarketing"
GITHUB_SOURCE_REPO="MixtureMarketing/binary-planet"

# Cloudflare — Worker custom domain (after wrangler deploy via GH Actions)
CF_API_TOKEN=""
CF_ACCOUNT_ID=""
CF_ZONE_ID=""

# --- Lead pipeline ---
RESEND_API_KEY=""
RESEND_FROM="leads@mixturemarketing.pl"

SMSAPI_TOKEN=""
SMSAPI_FROM="INFO"

# --- AI ---
ANTHROPIC_API_KEY=""

# --- SEO / data ---
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# --- Payments ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Per-tier price IDs from Stripe dashboard → Products → New product (Recurring monthly).
STRIPE_PRICE_STARTER=""    # price_xxx for 149 zł/mc
STRIPE_PRICE_STANDARD=""   # price_xxx for 199 zł/mc
STRIPE_PRICE_PREMIUM=""    # price_xxx for 299 zł/mc
STRIPE_CHECKOUT_RETURN_URL="http://localhost:4322"  # admin base URL for success/cancel redirects
P24_MERCHANT_ID=""
P24_CRC_KEY=""
P24_API_KEY=""
FAKTUROWNIA_API_TOKEN=""
FAKTUROWNIA_LOGIN=""               # subdomain z URL: https://{login}.fakturownia.pl
FAKTUROWNIA_DRY_RUN="true"         # set "false" for real invoice generation

# --- Polish business data ---
REGON_USER_KEY=""

# --- Internal crypto ---
JWT_SIGNING_KEY=""
D1_ENCRYPTION_KEY=""
BACKUP_ENCRYPTION_KEY=""
TURNSTILE_SECRET_KEY=""
