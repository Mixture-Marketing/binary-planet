---
import { env } from "cloudflare:workers";
import AdminLayout from "../../layouts/AdminLayout.astro";

import { listClients } from "../../lib/db.ts";

if (!env?.DB) return new Response("Runtime not available", { status: 500 });

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get("status") ?? undefined;
const searchQuery = (url.searchParams.get("q") ?? "").trim().toLowerCase();

const allClients = await listClients(env.DB, {
  ...(statusFilter && { status: statusFilter }),
});

// Client-side filter — for now just substring on business_name/industry/city
const clients = searchQuery
  ? allClients.filter((c) =>
      [c.business_name, c.industry, c.city, c.primary_domain ?? ""]
        .some((f) => f.toLowerCase().includes(searchQuery))
    )
  : allClients;

const statusOptions = ["all", "active", "pending", "provisioning", "paused", "suspended", "churned"];

const formatDate = (iso: string | null): string => {
  if (!iso) return "—";
  return new Date(iso).toLocaleDateString("pl-PL");
};

const tierLabel: Record<string, string> = {
  starter: "Starter",
  standard: "Standard",
  premium: "Premium",
  professional: "Professional",
};
---

<AdminLayout title="Klienci">
  <header style="display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem;">
    <div>
      <h1 style="font-size: 2rem; font-weight: 800; margin: 0 0 0.5rem 0;">Klienci</h1>
      <p style="color: var(--c-text-muted); margin: 0;">
        {clients.length}{searchQuery && ` z ${allClients.length}`} {statusFilter ? `(filtr: ${statusFilter})` : "łącznie"}{searchQuery && ` · "${searchQuery}"`}
      </p>
    </div>
    <a href="/onboarding/new" class="btn btn-primary" style="display: inline-flex; align-items: center; gap: 0.4rem;">
      <span aria-hidden="true">+</span> Nowy klient
    </a>
  </header>

  <!-- Search + status filter chips row -->
  <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem; align-items: center;">
    <form role="search" method="get" action="/clients" style="display: flex; gap: 0.4rem; align-items: center; flex: 1; min-width: 240px;">
      {statusFilter && <input type="hidden" name="status" value={statusFilter} />}
      <label for="clients-search" class="visually-hidden">Szukaj klienta</label>
      <input
        id="clients-search"
        type="search"
        name="q"
        value={searchQuery}
        placeholder="Szukaj po nazwie, branży, mieście, domenie…"
        autocomplete="off"
        style="flex: 1; padding: 0.55rem 0.85rem; border: 1px solid var(--c-border); border-radius: 6px; font: inherit; min-height: 38px;"
      />
      <button type="submit" class="btn" style="font-size: 0.85rem; padding: 0.4rem 0.9rem;">Szukaj</button>
      {searchQuery && <a href={statusFilter ? `/clients?status=${statusFilter}` : "/clients"} class="btn" style="font-size: 0.85rem; padding: 0.4rem 0.9rem;">Wyczyść</a>}
    </form>
    <div style="display: flex; gap: 0.4rem; flex-wrap: wrap;">
      {statusOptions.map((s) => (
        <a
          href={s === "all" ? (searchQuery ? `/clients?q=${encodeURIComponent(searchQuery)}` : "/clients") : `/clients?status=${s}${searchQuery ? `&q=${encodeURIComponent(searchQuery)}` : ""}`}
          class={`btn ${(s === "all" && !statusFilter) || s === statusFilter ? "btn-primary" : ""}`}
          style="font-size: 0.8rem; padding: 0.35rem 0.75rem; min-height: 30px;"
        >
          {s}
        </a>
      ))}
    </div>
  </div>

  <div class="card" style="padding: 0;">
    {clients.length === 0 ? (
      <p style="padding: 2rem; text-align: center; color: var(--c-text-muted); margin: 0;">
        Brak klientów {statusFilter ? `o statusie "${statusFilter}"` : "w bazie"}.
      </p>
    ) : (
      <table class="table">
        <thead>
          <tr>
            <th>Firma</th>
            <th>Domena</th>
            <th>Branża</th>
            <th>Miasto</th>
            <th>Tier</th>
            <th>Status</th>
            <th>Aktywacja</th>
          </tr>
        </thead>
        <tbody>
          {clients.map((c) => (
            <tr>
              <td>
                <a href={`/clients/${c.id}`} style="color: var(--c-brand); text-decoration: none; font-weight: 600;">
                  {c.business_name}
                </a>
                <p style="margin: 0.15rem 0 0 0; font-size: 0.75rem; color: var(--c-text-muted); font-family: ui-monospace, monospace;">{c.id}</p>
              </td>
              <td>
                {c.primary_domain ? (
                  <a href={`https://${c.primary_domain}`} target="_blank" rel="noopener" style="color: var(--c-text); text-decoration: underline;">
                    {c.primary_domain}
                  </a>
                ) : "—"}
              </td>
              <td>{c.industry}</td>
              <td>{c.city}</td>
              <td><span class="badge">{tierLabel[c.tier] ?? c.tier}</span></td>
              <td>
                <span class={`badge ${c.status === "active" ? "badge-success" : c.status === "churned" || c.status === "suspended" ? "badge-danger" : "badge-warning"}`}>
                  {c.status}
                </span>
              </td>
              <td style="color: var(--c-text-muted); font-size: 0.85rem;">{formatDate(c.activated_at)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
