---
import LoginLayout from "../layouts/LoginLayout.astro";
import Icon from "../components/Icon.astro";

const url = new URL(Astro.request.url);
const next = url.searchParams.get("next") ?? "/";
const sent = url.searchParams.get("sent") === "1";
const error = url.searchParams.get("error");
---

<LoginLayout title="Logowanie — MM Admin">
  {sent ? (
    <>
      <h2 style="font-size: 1.25rem; font-weight: 700; margin: 0 0 0.5rem 0; color: var(--c-success); display: flex; align-items: center; gap: 0.5rem;">
        <Icon name="check-circle-2" size={22} /> Wysłano link logowania
      </h2>
      <p style="color: var(--c-text-muted); margin: 0 0 1rem 0;">
        Sprawdź skrzynkę e-mail. Link wygaśnie za 15 minut.
      </p>
      <p style="font-size: 0.85rem; color: var(--c-text-muted); margin: 0;">
        Nie widzisz emaila? Sprawdź spam lub <a href="/login" style="color: var(--c-brand); text-decoration: underline;">spróbuj ponownie</a>.
      </p>
    </>
  ) : (
    <>
      <h2 style="font-size: 1.25rem; font-weight: 700; margin: 0 0 0.5rem 0;">Zaloguj się</h2>
      <p style="color: var(--c-text-muted); margin: 0 0 1.5rem 0;">
        Wpisz e-mail. Wyślemy link logowania (ważny 15 minut).
      </p>

      {error && (
        <div role="alert" style="padding: 0.75rem 1rem; background: #fef2f2; color: var(--c-danger); border-radius: 0.5rem; margin-bottom: 1rem; font-size: 0.9rem;">
          {error === "invalid_email" && "Nieprawidłowy adres e-mail."}
          {error === "not_found" && "Konto z tym adresem nie istnieje."}
          {error === "send_failed" && "Nie udało się wysłać emaila. Spróbuj ponownie."}
          {error === "invalid_token" && "Link wygasł lub jest nieprawidłowy. Wygeneruj nowy."}
        </div>
      )}

      <form method="POST" action="/api/auth/send-link" style="display: flex; flex-direction: column; gap: 1rem;">
        <input type="hidden" name="next" value={next} />
        <label>
          <span style="display: block; font-weight: 600; margin-bottom: 0.3rem; font-size: 0.9rem;">E-mail</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            placeholder="jakub@mixturemarketing.pl"
            style="width: 100%; padding: 0.6rem 0.875rem; border: 1px solid var(--c-border); border-radius: 0.5rem; font: inherit;"
          />
        </label>
        <button type="submit" class="btn btn-primary" style="width: 100%;">
          Wyślij link logowania
        </button>
      </form>
    </>
  )}
</LoginLayout>
