---
import { env } from "cloudflare:workers";
import AdminLayout from "../layouts/AdminLayout.astro";
import Icon from "../components/Icon.astro";
import { CRON_JOBS } from "../lib/cron-jobs.ts";

if (!env?.DB) return new Response("Runtime not available", { status: 500 });

// Recent cron runs (status visibility for Faza 5 scheduled tasks)
const cronRuns = await env.DB
  .prepare(
    `SELECT job_name, started_at, finished_at, status, items_processed, items_failed, error
       FROM cron_runs
      ORDER BY started_at DESC LIMIT 30`,
  )
  .all<{
    job_name: string;
    started_at: string;
    finished_at: string | null;
    status: string;
    items_processed: number;
    items_failed: number;
    error: string | null;
  }>();

const aiCallsToday = await env.DB
  .prepare(
    `SELECT COUNT(*) AS calls, SUM(cost_grosze) AS cost
       FROM ai_calls WHERE occurred_at >= datetime('now', '-1 day')`,
  )
  .first<{ calls: number; cost: number }>();

const healthLast = await env.DB
  .prepare(
    `SELECT
       COUNT(*) AS checked,
       SUM(CASE WHEN uptime = 1 THEN 1 ELSE 0 END) AS up
     FROM health_checks WHERE checked_at >= datetime('now', '-1 hour')`,
  )
  .first<{ checked: number; up: number }>();

// Track 23 — last probe per infra service (api/app/panel/marketing)
const infraServices = ["system_api", "system_app", "system_panel", "system_marketing"];
const infraRows = await Promise.all(
  infraServices.map(async (id) => {
    const r = await env.DB
      .prepare(
        `SELECT action, occurred_at, metadata_json FROM audit_log
          WHERE resource_type = 'service' AND resource_id = ?
            AND action IN ('infra.probe.ok','infra.probe.failed')
          ORDER BY id DESC LIMIT 1`,
      )
      .bind(id)
      .first<{ action: string; occurred_at: string; metadata_json: string }>();
    let meta: { url?: string; status?: number; duration_ms?: number; error?: string } = {};
    try { meta = r?.metadata_json ? JSON.parse(r.metadata_json) : {}; } catch {}
    return {
      id,
      url: meta.url ?? "—",
      ok: r?.action === "infra.probe.ok",
      status: meta.status,
      duration_ms: meta.duration_ms,
      error: meta.error,
      checked_at: r?.occurred_at ?? null,
    };
  }),
);

const formatDuration = (started: string, finished: string | null): string => {
  if (!finished) return "—";
  const ms = new Date(finished).getTime() - new Date(started).getTime();
  return ms < 1000 ? `${ms}ms` : `${(ms / 1000).toFixed(1)}s`;
};
---

<AdminLayout title="Operations">
  <header style="margin-bottom: 2rem;">
    <h1 style="font-size: 2rem; font-weight: 800; margin: 0 0 0.5rem 0; display: flex; align-items: center; gap: 0.6rem;"><Icon name="settings" size={28} /> Operations</h1>
    <p style="color: var(--c-text-muted); margin: 0;">
      Status zaplecza: crony, AI quota, health checks.
    </p>
  </header>

  <details class="card" style="margin-bottom: 1.5rem;">
    <summary style="cursor: pointer; font-weight: 600; display: flex; align-items: center; gap: 0.4rem;">
      <Icon name="play" size={16} /> Manualne uruchomienie cron jobs (dla free Workers plan)
    </summary>
    <p style="margin: 1rem 0 0.75rem 0; font-size: 0.9rem; color: var(--c-text-muted);">
      Na free plan CF Workers cron triggers nie działają. Tu możesz odpalić każdy job ręcznie.
      W produkcji ustawiony przez wrangler.toml automatycznie.
    </p>
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
      {CRON_JOBS.map((j) => (
        <button
          type="button"
          class="btn cron-run-btn"
          data-job={j.slug}
          title={`${j.description} (${j.schedule})`}
          style="font-size: 0.85rem; padding: 0.4rem 0.85rem; min-height: 32px; gap: 0.4rem;"
        >
          <Icon name="play" size={12} /> {j.label}
          <small style="color: var(--c-text-muted); font-weight: 400;">· {j.schedule}</small>
        </button>
      ))}
    </div>
    <p id="cron-status" style="margin: 0.75rem 0 0 0; font-size: 0.85rem; color: var(--c-text-muted); font-family: ui-monospace, monospace;"></p>
    <p style="margin-top: 1rem; font-size: 0.8rem; color: var(--c-text-muted);">
      Klucz server-side w wrangler secrets — działa bez ręcznej konfiguracji.
    </p>
  </details>

  <script is:inline>
    document.querySelectorAll(".cron-run-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const job = btn.dataset.job;
        const statusEl = document.getElementById("cron-status");
        btn.disabled = true;
        statusEl.textContent = `Odpalam ${job}…`;
        try {
          const res = await fetch(`/api/cron/run`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ job }),
          });
          const json = await res.json();
          if (json.ok) {
            statusEl.textContent = `${job}: processed=${json.data.processed} failed=${json.data.failed} duration=${json.data.duration_ms}ms`;
            setTimeout(() => window.location.reload(), 1500);
          } else {
            statusEl.textContent = `BŁĄD: ${json.error?.message || json.error || JSON.stringify(json)}`;
          }
        } catch (e) {
          statusEl.textContent = `Network error: ${e.message}`;
        } finally {
          btn.disabled = false;
        }
      });
    });
  </script>

  <section style="display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); margin-bottom: 2.5rem;">
    <div class="card">
      <p style="margin: 0; font-size: 0.85rem; color: var(--c-text-muted); font-weight: 600; text-transform: uppercase;">AI calls / 24h</p>
      <p style="margin: 0.5rem 0 0 0; font-size: 1.75rem; font-weight: 800;">{aiCallsToday?.calls ?? 0}</p>
      <p style="margin: 0; font-size: 0.85rem; color: var(--c-text-muted);">
        Koszt: ${((aiCallsToday?.cost ?? 0) / 10000).toFixed(2)}
      </p>
    </div>
    <div class="card">
      <p style="margin: 0; font-size: 0.85rem; color: var(--c-text-muted); font-weight: 600; text-transform: uppercase;">Health checks / 1h</p>
      <p style="margin: 0.5rem 0 0 0; font-size: 1.75rem; font-weight: 800;">{healthLast?.checked ?? 0}</p>
      <p style="margin: 0; font-size: 0.85rem;" class={(healthLast?.up ?? 0) === (healthLast?.checked ?? 0) ? "" : ""}>
        Up: <strong>{healthLast?.up ?? 0}</strong> / {healthLast?.checked ?? 0}
      </p>
    </div>
    <div class="card">
      <p style="margin: 0; font-size: 0.85rem; color: var(--c-text-muted); font-weight: 600; text-transform: uppercase;">Ostatnie cron runs</p>
      <p style="margin: 0.5rem 0 0 0; font-size: 1.75rem; font-weight: 800;">{cronRuns.results?.length ?? 0}</p>
      <p style="margin: 0; font-size: 0.85rem; color: var(--c-text-muted);">w bazie</p>
    </div>
  </section>

  <h2 style="font-size: 1.25rem; font-weight: 700; margin: 0 0 1rem 0; display: flex; align-items: center; gap: 0.4rem;">
    <Icon name="bell" size={20} /> Infra health (own services)
  </h2>
  <div class="card" style="padding: 0; margin-bottom: 2rem;">
    <table class="table">
      <thead>
        <tr>
          <th>Service</th>
          <th>Status</th>
          <th>HTTP</th>
          <th>Latency</th>
          <th>URL</th>
          <th>Last probe</th>
        </tr>
      </thead>
      <tbody>
        {infraRows.map((s) => (
          <tr>
            <td style="font-family: ui-monospace, monospace; font-size: 0.85rem;">{s.id}</td>
            <td>
              {s.checked_at == null ? <span class="badge">no data</span> :
                s.ok ? <span class="badge badge-success">UP</span> : <span class="badge badge-danger">DOWN</span>}
            </td>
            <td style="font-size: 0.85rem;">{s.status ?? "—"}</td>
            <td style="font-size: 0.85rem; color: var(--c-text-muted);">{s.duration_ms != null ? `${s.duration_ms} ms` : "—"}</td>
            <td style="font-size: 0.78rem; color: var(--c-text-muted); word-break: break-all;">{s.url}</td>
            <td style="font-size: 0.78rem; color: var(--c-text-muted);">{s.checked_at ?? "—"}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <h2 style="font-size: 1.25rem; font-weight: 700; margin: 0 0 1rem 0;">Scheduled jobs (ostatnie 30)</h2>
  <div class="card" style="padding: 0;">
    {(cronRuns.results?.length ?? 0) === 0 ? (
      <p style="padding: 2rem; text-align: center; color: var(--c-text-muted); margin: 0;">
        Brak uruchomień cron w bazie. Po deploy mm-control-plane z aktywnym CF Workers Paid pojawią się tu.
      </p>
    ) : (
      <table class="table">
        <thead>
          <tr>
            <th>Job</th>
            <th>Status</th>
            <th>Czas trwania</th>
            <th>Items</th>
            <th>Kiedy</th>
          </tr>
        </thead>
        <tbody>
          {cronRuns.results?.map((run) => (
            <tr>
              <td style="font-family: ui-monospace, monospace; font-size: 0.85rem;">{run.job_name}</td>
              <td>
                <span class={`badge ${run.status === "success" ? "badge-success" : run.status === "failed" ? "badge-danger" : run.status === "partial_success" ? "badge-warning" : ""}`}>
                  {run.status}
                </span>
              </td>
              <td style="font-size: 0.85rem; color: var(--c-text-muted);">{formatDuration(run.started_at, run.finished_at)}</td>
              <td style="font-size: 0.85rem;">
                {run.items_processed} processed{run.items_failed > 0 ? `, ${run.items_failed} failed` : ""}
              </td>
              <td style="font-size: 0.85rem; color: var(--c-text-muted);">{new Date(run.started_at).toLocaleString("pl-PL")}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
