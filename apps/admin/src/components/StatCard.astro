---
interface Props {
  label: string;
  value: string | number;
  /** Optional delta (e.g. "+12% vs last week"). */
  delta?: string;
  deltaTone?: "positive" | "negative" | "neutral";
  icon?: string;
}

const { label, value, delta, deltaTone = "neutral", icon } = Astro.props;

const deltaColor = {
  positive: "var(--c-success)",
  negative: "var(--c-danger)",
  neutral: "var(--c-text-muted)",
}[deltaTone];
---

<div class="card" style="display: flex; flex-direction: column; gap: 0.5rem;">
  <div style="display: flex; align-items: center; gap: 0.5rem; color: var(--c-text-muted);">
    {icon && <span aria-hidden="true" style="font-size: 1.1rem;">{icon}</span>}
    <p style="margin: 0; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">
      {label}
    </p>
  </div>
  <p style="margin: 0; font-size: 2rem; font-weight: 800; line-height: 1.1;">{value}</p>
  {delta && (
    <p style={`margin: 0; font-size: 0.85rem; color: ${deltaColor};`}>{delta}</p>
  )}
</div>
