---
import { env } from "cloudflare:workers";
import PanelLayout from "../layouts/PanelLayout.astro";
import Icon from "../components/Icon.astro";

const client = Astro.locals.client;
if (!env?.DB || !client) return new Response("Runtime not ready", { status: 500 });

// Read real monthly reports from D1
const reportsResult = await env.DB
  .prepare(
    `SELECT month_id, summary, pdf_r2_key, generated_at
       FROM monthly_reports
      WHERE client_id = ?
      ORDER BY month_id DESC
      LIMIT 24`,
  )
  .bind(client.id)
  .all<{ month_id: string; summary: string; pdf_r2_key: string | null; generated_at: string }>();

const reports = (reportsResult.results ?? []).map((r) => ({
  month: r.month_id,
  pdf_url: r.pdf_r2_key ? `/api/raporty/download?month=${r.month_id}` : "",
  summary: r.summary,
}));
---

<PanelLayout title="Raporty">
  <header style="margin-bottom: 2rem;">
    <h1 style="font-size: 2rem; font-weight: 800; margin: 0 0 0.5rem 0; display: flex; align-items: center; gap: 0.6rem;">
      <Icon name="clipboard-list" size={28} /> Raporty miesięczne
    </h1>
    <p style="margin: 0; color: var(--c-text-muted);">
      Co miesiąc dostajesz podsumowanie: pozycje SEO, liczby leadów, koszty kampanii, rekomendacje.
    </p>
  </header>

  <div class="card" style="padding: 0;">
    {reports.length === 0 ? (
      <div style="padding: 3rem 2rem; text-align: center;">
        <p style="margin: 0 0 0.5rem 0; color: var(--c-text-muted);">Brak raportów.</p>
        <p style="margin: 0; font-size: 0.85rem; color: var(--c-text-muted);">
          Pierwszy raport pojawi się 30 dni po aktywacji subskrypcji.
        </p>
      </div>
    ) : (
      <ul style="list-style: none; padding: 0; margin: 0;">
        {reports.map((r) => (
          <li style="padding: 1rem 1.5rem; border-bottom: 1px solid var(--c-border); display: flex; gap: 1rem; align-items: center; justify-content: space-between;">
            <div>
              <p style="margin: 0; font-weight: 600;">{r.month}</p>
              <p style="margin: 0.25rem 0 0 0; font-size: 0.85rem; color: var(--c-text-muted);">{r.summary}</p>
            </div>
            <a href={r.pdf_url} class="btn" style="font-size: 0.85rem; padding: 0.4rem 0.9rem; min-height: 32px;">
              <Icon name="file-text" size={14} /> Pobierz PDF
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>

  <details class="card" style="margin-top: 1.5rem;">
    <summary style="cursor: pointer; font-weight: 600; display: flex; align-items: center; gap: 0.4rem;">
      <Icon name="info" size={16} /> Co znajdę w raporcie miesięcznym?
    </summary>
    <ul style="margin-top: 1rem; padding-left: 1.5rem; color: var(--c-text); font-size: 0.9rem; line-height: 1.7;">
      <li><strong>Pozycje SEO</strong> dla głównych słów kluczowych w Twojej okolicy (Google Search Console + DataForSEO)</li>
      <li><strong>Liczby leadów</strong> z podziałem na źródło (formularz, telefon, GBP)</li>
      <li><strong>Opinie GBP</strong> — nowe opinie, średnia ocena</li>
      <li><strong>Trendy</strong> — porównanie miesiąc-do-miesiąca</li>
      <li><strong>Rekomendacje AI</strong> — co poprawić w najbliższych 30 dniach</li>
    </ul>
  </details>
</PanelLayout>
