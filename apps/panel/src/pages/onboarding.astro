        <!-- ============ SUBMIT ============ -->
        <div id="form-errors" style="display: none; padding: 1rem; background: #fef2f2; border: 1px solid #fecaca; color: var(--c-danger); border-radius: 8px; margin-bottom: 1rem;"></div>

        <div class="step-nav-bar">
          <button type="button" id="prev-step" class="btn" style="min-height: 44px; padding: 0.6rem 1.2rem;" hidden>← Wstecz</button>
          <div style="flex: 1; text-align: center;">
            <div style="display: flex; align-items: center; gap: 0.5rem; justify-content: center;">
              <span id="progress-label" style="font-weight: 700; font-size: 0.85rem;">Krok 1 / 9</span>
              <div
                role="progressbar"
                aria-valuemin="0"
                aria-valuemax="9"
                aria-valuenow="1"
                id="progress-track"
                style="flex: 1; max-width: 200px; height: 6px; background: var(--c-border); border-radius: 999px; overflow: hidden;"
              >
                <div id="progress-fill" style="height: 100%; width: 11%; background: var(--c-brand); transition: width 300ms ease;"></div>
              </div>
              <span id="progress-pct" style="font-size: 0.72rem; color: var(--c-text-muted); min-width: 2.2rem; text-align: right; font-variant-numeric: tabular-nums;">11%</span>
            </div>
            <p style="margin: 0.3rem 0 0 0; font-size: 0.75rem; color: var(--c-text-muted);">
              <span id="draft-status"></span>
            </p>
          </div>
          <button type="button" id="next-step" class="btn btn-primary" style="min-height: 44px; padding: 0.6rem 1.2rem;">Dalej →</button>
          <button type="submit" id="submit-btn" class="btn btn-primary" style="min-height: 44px; padding: 0.6rem 1.2rem;" hidden>
            Zatwierdź i rozpocznij budowę →
          </button>
        </div>
      </form>
    </main>

    <style is:global>
      /* Field grid — 2-col desktop, 1-col mobile, with consistent gap */
      .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem 1rem; }
      @media (max-width: 720px) { .grid-2 { grid-template-columns: 1fr; gap: 0.85rem; } }

      /* Label structure — text above, input below, hint below input */
      label {
        display: flex; flex-direction: column; gap: 0.3rem;
        font-size: 0.92rem; line-height: 1.4;
        color: var(--c-text);
      }
      label > .field-label-text { font-weight: 600; }
      label .req { color: var(--c-danger); font-weight: 700; margin-left: 0.15rem; }
      .field-hint {
        font-size: 0.78rem; color: var(--c-text-muted); margin-top: 0.1rem;
        line-height: 1.4;
      }
      .field-counter {
        font-size: 0.72rem; color: var(--c-text-muted);
        text-align: right; font-variant-numeric: tabular-nums;
        margin-top: -0.15rem;
      }
      .field-counter.is-warn { color: #b45309; }
      .field-counter.is-over { color: var(--c-danger); font-weight: 600; }

      /* Inputs — bigger touch targets (44px min), consistent padding */
      input[type="text"], input[type="email"], input[type="number"], input[type="tel"], select, textarea {
        padding: 0.65rem 0.75rem;
        border: 1px solid var(--c-border); border-radius: 8px;
        font-family: inherit; font-size: 0.95rem; background: white;
        min-height: 42px; box-sizing: border-box;
        transition: border-color 150ms, box-shadow 150ms;
      }
      textarea { min-height: 80px; resize: vertical; }
      input:focus, select:focus, textarea:focus {
        outline: none; border-color: var(--c-brand);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--c-brand) 20%, transparent);
      }
      input:invalid:not(:placeholder-shown) { border-color: var(--c-danger); }
      input:invalid:not(:placeholder-shown):focus {
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--c-danger) 20%, transparent);
      }

      /* Sub-sections inside details */
      details > *:not(summary) { margin-top: 0.85rem; }
      details > summary { padding: 0.15rem 0; }

      .service-row, .review-row {
        background: var(--c-surface-muted); padding: 1rem;
        border-radius: 8px; border: 1px solid var(--c-border);
      }

      /* Radio cards */
      .radio-card {
        display: flex; gap: 0.6rem; align-items: start;
        padding: 0.85rem 1rem; border: 1px solid var(--c-border);
        border-radius: 8px; cursor: pointer;
        transition: border-color 150ms, background 150ms;
      }
      .radio-card:has(input:checked) {
        border-color: var(--c-brand); background: color-mix(in srgb, var(--c-brand) 6%, transparent);
      }

      /* Submit button area */
      .submit-bar {
        position: sticky; bottom: 1rem; z-index: 5;
        background: var(--c-surface); border: 1px solid var(--c-border);
        border-radius: 12px; padding: 1rem;
        box-shadow: 0 -4px 12px -8px rgba(0,0,0,0.15);
        display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;
      }

      /* Multi-step wizard — show only current step's <details>, hide rest.
       * Note: do NOT force display:block on children — would unhide <script> and
       * <style> elements (normally display:none), rendering them as visible text. */
      #onboarding-form > details { display: none; }
      #onboarding-form > details.is-active-step { display: block; }
      /* Disable summary toggle in step mode — content always visible when details[open] */
      #onboarding-form > details.is-active-step > summary { pointer-events: none; cursor: default; }

      /* Stepper — pills on top */
      .wizard-stepper li.is-current {
        background: var(--c-brand) !important;
        color: white !important;
        border-color: var(--c-brand) !important;
      }
      .wizard-stepper li.is-current .step-num {
        background: rgba(255,255,255,0.25);
        color: white;
      }
      .wizard-stepper li.is-done {
        background: #ecfdf5 !important;
        color: #047857 !important;
        border-color: #a7f3d0 !important;
      }
      .wizard-stepper li.is-done .step-num {
        background: #10b981;
        color: white;
      }
      .wizard-stepper li.is-done .step-num::before {
        content: "✓";
        font-size: 0.85em;
      }
      .wizard-stepper li.is-done .step-num span { display: none; }
      .wizard-stepper li:hover:not(.is-current) {
        border-color: var(--c-brand) !important;
      }
      .wizard-stepper li:focus-visible {
        outline: 2px solid var(--c-brand);
        outline-offset: 2px;
      }
      @media (max-width: 720px) {
        .wizard-stepper .step-label { display: none; }
      }

      /* Step nav bar — replaces sticky submit-bar */
      .step-nav-bar {
        position: sticky; bottom: 1rem; z-index: 5;
        background: var(--c-surface); border: 1px solid var(--c-border);
        border-radius: 12px; padding: 0.75rem 1rem;
        box-shadow: 0 -4px 12px -8px rgba(0,0,0,0.15);
        display: flex; gap: 1rem; align-items: center;
      }

      /* Section badges — required vs optional */
      .section-badge {
        font-size: 0.7rem; padding: 0.15rem 0.45rem; border-radius: 999px;
        margin-left: 0.5rem; font-weight: 600; letter-spacing: 0.02em;
      }
      .section-badge.required { background: color-mix(in srgb, var(--c-danger) 12%, transparent); color: #991b1b; }
      .section-badge.optional { background: var(--c-surface-muted); color: var(--c-text-muted); }
    </style>

    <script is:inline>
      const servicesList = document.getElementById("services-list");
      const addServiceBtn = document.getElementById("add-service");
      let serviceIdx = 0;
      function addServiceRow(prefill) {
        prefill = prefill || {};
        const i = serviceIdx++;
        const row = document.createElement("div");
        row.className = "service-row";
        row.innerHTML = `
          <input type="hidden" name="services_${i}_slug" data-auto-slug value="${prefill.slug||''}" />
          <div class="grid-2">
            <label>Nazwa usługi *
              <input type="text" name="services_${i}_name" data-service-name required maxlength="120" value="${prefill.name||''}" placeholder="np. Awaryjne otwieranie zamków" />
            </label>
            <label>Cena od (opcjonalne)
              <input type="text" name="services_${i}_price_from" maxlength="40" value="${prefill.price_from||''}" placeholder="od 100 zł" />
            </label>
          </div>
          <label style="margin-top: 0.5rem;">Krótki opis *
            <textarea name="services_${i}_description" required maxlength="500" rows="2" placeholder="np. Otwieram każdy zamek bez uszkodzenia drzwi, dojazd 24/7 w okolice Rzeszowa.">${prefill.description||''}</textarea>
          </label>
          <input type="hidden" name="services_${i}_icon_key" value="${prefill.icon_key||''}" />
          <button type="button" class="btn" data-remove style="margin-top: 0.5rem; font-size: 0.8rem;">Usuń</button>
        `;
        // Auto-generate slug from name (slugify Polish characters → ASCII kebab-case)
        const nameInput = row.querySelector("[data-service-name]");
        const slugInput = row.querySelector("[data-auto-slug]");
        function slugify(s) {
          return s
            .toLowerCase()
            .normalize("NFD").replace(/[̀-ͯ]/g, "")
            .replace(/ł/g, "l")
            .replace(/[^a-z0-9]+/g, "-")
            .replace(/^-|-$/g, "")
            .slice(0, 60);
        }
        nameInput.addEventListener("input", () => {
          // Don't overwrite if user manually customized (prefilled non-empty + differs from current name slugify)
          if (!slugInput.dataset.locked) slugInput.value = slugify(nameInput.value);
        });
        // If prefill had explicit slug, lock auto-update
        if (prefill.slug && slugify(prefill.name || "") !== prefill.slug) {
          slugInput.dataset.locked = "true";
        }
        row.querySelector("[data-remove]").addEventListener("click", () => row.remove());
        servicesList.appendChild(row);
      }
      addServiceBtn.addEventListener("click", () => addServiceRow());

      // ============ DOMAIN AVAILABILITY CHECK (OVH) ============
      // Debounced inline check — calls /api/onboarding/check-domain when user
      // pauses typing. Shows price (first year + renew) or "taken" status.
      const domainInput = document.getElementById("primary_domain");
      const domainResult = document.getElementById("domain-check-result");
      const domainSourceRadios = document.querySelectorAll('input[name="domain_source"]');
      let domainCheckTimer = null;
      let lastCheckedDomain = "";
      function shouldCheck() {
        // Only check when user wants us to REGISTER (not "I have own")
        const sourceEl = document.querySelector('input[name="domain_source"]:checked');
        return sourceEl?.value === "register";
      }
      function renderDomainResult(html, tone) {
        const colors = {
          info: "color: #1e40af;",
          ok: "color: #047857;",
          warn: "color: #b45309;",
          err: "color: #b91c1c;",
        };
        domainResult.style.cssText = "margin-top: 0.5rem; font-size: 0.9rem; min-height: 1.3rem; " + (colors[tone] || colors.info);
        domainResult.innerHTML = html;
      }
      async function checkDomainNow() {
        const d = domainInput.value.trim().toLowerCase();
        if (!d || !/^[a-z0-9.-]+\.[a-z]{2,}$/.test(d)) {
          domainResult.innerHTML = "";
          return;
        }
        if (d === lastCheckedDomain) return;
        if (!shouldCheck()) {
          renderDomainResult("Wybrałeś \"mam własną domenę\" — sprawdzanie dostępności pominięte.", "info");
          return;
        }
        lastCheckedDomain = d;
        renderDomainResult("⏳ Sprawdzam dostępność w OVH...", "info");
        try {
          const res = await fetch("/api/onboarding/check-domain?domain=" + encodeURIComponent(d));
          const body = await res.json();
          if (!body.ok) {
            renderDomainResult("⚠ Nie udało się sprawdzić: " + (body.error || "unknown"), "warn");
            return;
          }
          const data = body.data;
          if (data.available) {
            const price = data.price_first_year ? `${data.price_first_year.value} ${data.price_first_year.currency || "PLN"}` : "(cena nieznana)";
            const renew = data.price_renew ? `, odnowienie ${data.price_renew.value} ${data.price_renew.currency || "PLN"}/rok` : "";
            renderDomainResult(`✓ <strong>${d}</strong> dostępna — pierwszy rok ${price}${renew} (wliczone w pakiet)`, "ok");
          } else {
            renderDomainResult(`✗ <strong>${d}</strong> już zajęta. Jeśli to Twoja domena — zaznacz wyżej "Mam już własną domenę".`, "err");
          }
        } catch (e) {
          renderDomainResult("⚠ Błąd sieci: " + (e?.message || e), "warn");
        }
      }
      if (domainInput) {
        domainInput.addEventListener("input", () => {
          if (domainCheckTimer) clearTimeout(domainCheckTimer);
          domainCheckTimer = setTimeout(checkDomainNow, 700);
        });
      }

      // ============ DOMAIN SOURCE TOGGLE (preview / register / owned) ============
      const domainInputWrap = document.getElementById("domain-input-wrap");
      const previewBox = document.getElementById("preview-info-box");
      function updateDomainModeUI() {
        const sourceEl = document.querySelector('input[name="domain_source"]:checked');
        const mode = sourceEl?.value || "register";
        if (mode === "preview") {
          // Hide domain input + show preview info; clear required so step validates
          if (domainInputWrap) domainInputWrap.style.display = "none";
          if (previewBox) previewBox.style.display = "block";
          if (domainInput) {
            domainInput.required = false;
            domainInput.value = "";
          }
        } else {
          if (domainInputWrap) domainInputWrap.style.display = "block";
          if (previewBox) previewBox.style.display = "none";
          if (domainInput) domainInput.required = true;
        }
        lastCheckedDomain = "";
        if (domainInput?.value) checkDomainNow();
      }
      domainSourceRadios.forEach((r) => r.addEventListener("change", updateDomainModeUI));
      updateDomainModeUI();

      // ============ POSTAL CODE AUTO-FORMAT (NN-NNN) ============
      const postalInput = document.getElementById("postal_code");
      if (postalInput) {
        postalInput.addEventListener("input", (e) => {
          const v = e.target.value.replace(/\D/g, "").slice(0, 5);
          e.target.value = v.length > 2 ? v.slice(0, 2) + "-" + v.slice(2) : v;
        });
      }

      // ============ PHONE AUTO-FORMAT (+48 XXX XXX XXX) ============
      // Format on BLUR only — formatting on every keystroke causes cursor jumps.
      // User types freely (any format), we clean + format when they leave the field.
      const phoneInput = document.getElementById("contact_phone");
      function formatPhone(raw) {
        const hasPlus = raw.trim().startsWith("+");
        let digits = raw.replace(/\D/g, "");
        // Country code 48 stripping: if hasPlus, always strip leading 48;
        // if no plus but 11+ digits starting with 48 → also country code
        if (hasPlus && digits.startsWith("48")) digits = digits.slice(2);
        else if (!hasPlus && digits.startsWith("48") && digits.length >= 11) digits = digits.slice(2);
        digits = digits.slice(0, 9);
        const grouped = digits.length > 6 ? `${digits.slice(0,3)} ${digits.slice(3,6)} ${digits.slice(6)}`
                     : digits.length > 3 ? `${digits.slice(0,3)} ${digits.slice(3)}`
                     : digits;
        if (digits.length === 0) return "";
        return "+48 " + grouped;
      }
      if (phoneInput) {
        phoneInput.addEventListener("blur", (e) => {
          const formatted = formatPhone(e.target.value);
          if (formatted !== e.target.value) e.target.value = formatted;
        });
      }

      // ============ CHARACTER COUNTERS ============
      document.querySelectorAll("[data-counter]").forEach((input) => {
        const counter = document.getElementById(input.dataset.counter);
        if (!counter) return;
        const max = parseInt(input.maxLength, 10) || parseInt(input.getAttribute("maxlength"), 10) || 0;
        const update = () => {
          const len = input.value.length;
          counter.textContent = `${len} / ${max}`;
          counter.classList.toggle("is-warn", len > max * 0.85 && len <= max);
          counter.classList.toggle("is-over", len >= max);
        };
        input.addEventListener("input", update);
        update();
      });

      // ============ LOGO UPLOAD ============
      const logoInput = document.getElementById("logo-file-input");
      const logoPreview = document.getElementById("logo-preview");
      const logoStatus = document.getElementById("logo-upload-status");
      if (logoInput) {
        logoInput.addEventListener("change", async () => {
          const file = logoInput.files && logoInput.files[0];
          if (!file) return;
          if (file.size > 500 * 1024) {
            logoStatus.style.color = "var(--c-danger)";
            logoStatus.textContent = `Plik zbyt duży: ${Math.round(file.size / 1024)} KB, max 500 KB.`;
            return;
          }
          // Local preview
          const url = URL.createObjectURL(file);
          logoPreview.innerHTML = `<img src="${url}" alt="Logo" style="width: 100%; height: 100%; object-fit: contain;" />`;
          logoStatus.style.color = "var(--c-text-muted)";
          logoStatus.textContent = "⏳ Wgrywanie...";
          try {
            const fd = new FormData();
            fd.append("logo", file);
            const res = await fetch("/api/settings/logo-upload", { method: "POST", body: fd });
            const ct = res.headers.get("content-type") || "";
            if (!ct.includes("application/json")) {
              // Server returned HTML (redirect / error page) — show HTTP status, not parse error
              logoStatus.style.color = "var(--c-danger)";
              logoStatus.textContent = `✗ Błąd serwera (${res.status}). Spróbuj ponownie lub odśwież stronę.`;
              return;
            }
            const body = await res.json();
            if (body.ok) {
              logoStatus.style.color = "#047857";
              logoStatus.textContent = "✓ Logo zapisane. Pojawi się na Twojej stronie.";
            } else {
              logoStatus.style.color = "var(--c-danger)";
              logoStatus.textContent = "✗ Błąd: " + (body.error || "unknown");
            }
          } catch (e) {
            logoStatus.style.color = "var(--c-danger)";
            logoStatus.textContent = "✗ Błąd sieci: " + (e?.message || e);
          }
        });
      }

      // ============ HOURS PRESETS ============
      const HOURS_PRESETS = {
        "standard": { monday: "08:00-18:00", tuesday: "08:00-18:00", wednesday: "08:00-18:00", thursday: "08:00-18:00", friday: "08:00-18:00", saturday: "closed", sunday: "closed" },
        "extended": { monday: "07:00-20:00", tuesday: "07:00-20:00", wednesday: "07:00-20:00", thursday: "07:00-20:00", friday: "07:00-20:00", saturday: "09:00-14:00", sunday: "closed" },
        "24-7":     { monday: "00:00-23:59", tuesday: "00:00-23:59", wednesday: "00:00-23:59", thursday: "00:00-23:59", friday: "00:00-23:59", saturday: "00:00-23:59", sunday: "00:00-23:59" },
        "weekend":  { monday: "09:00-17:00", tuesday: "09:00-17:00", wednesday: "09:00-17:00", thursday: "09:00-17:00", friday: "09:00-17:00", saturday: "09:00-17:00", sunday: "closed" },
        "clear":    { monday: "", tuesday: "", wednesday: "", thursday: "", friday: "", saturday: "", sunday: "" },
      };
      document.querySelectorAll("[data-hours-preset]").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          const preset = HOURS_PRESETS[btn.dataset.hoursPreset];
          if (!preset) return;
          Object.entries(preset).forEach(([day, val]) => {
            const input = document.querySelector(`input[name="hours_${day}"]`);
            if (input) {
              input.value = val;
              input.dispatchEvent(new Event("input", { bubbles: true }));
            }
          });
          if (btn.dataset.hoursPreset === "24-7") {
            const note = document.querySelector('input[name="hours_note"]');
            if (note && !note.value) note.value = "Awaryjne wezwania 24/7 — telefon w każdej chwili";
          }
        });
      });

      const reviewsList = document.getElementById("reviews-list");
      const addReviewBtn = document.getElementById("add-review");
      let reviewIdx = 0;
      function addReviewRow(prefill) {
        prefill = prefill || {};
        const i = reviewIdx++;
        const row = document.createElement("div");
        row.className = "review-row";
        row.innerHTML = `
          <div class="grid-2">
            <label>Autor *<input type="text" name="reviews_${i}_author" required maxlength="80" value="${prefill.author||''}" /></label>
            <label>Ocena *
              <select name="reviews_${i}_rating" required>
                ${[5,4,3,2,1].map(r => `<option value="${r}" ${prefill.rating == String(r) ? 'selected' : ''}>${"★".repeat(r)}</option>`).join('')}
              </select>
            </label>
            <label>Data * (YYYY-MM-DD)<input type="text" name="reviews_${i}_date" required pattern="\\d{4}-\\d{2}-\\d{2}" value="${prefill.date||''}" /></label>
            <label>Źródło
              <select name="reviews_${i}_source">
                <option value="gbp">GBP</option><option value="manual">Manual</option><option value="facebook">Facebook</option>
              </select>
            </label>
          </div>
          <label style="margin-top: 0.5rem;">Treść *<textarea name="reviews_${i}_text" required maxlength="800" rows="2">${prefill.text||''}</textarea></label>
          <button type="button" class="btn" data-remove style="margin-top: 0.5rem; font-size: 0.8rem;">Usuń</button>
        `;
        row.querySelector("[data-remove]").addEventListener("click", () => row.remove());
        reviewsList.appendChild(row);
      }
      addReviewBtn.addEventListener("click", () => addReviewRow());

      // Industry → schema_type
      const industrySel = document.querySelector("[data-industry]");
      const schemaInput = document.querySelector('input[name="schema_type"]');
      industrySel.addEventListener("change", () => {
        const opt = industrySel.selectedOptions[0];
        schemaInput.value = (opt && opt.dataset.schema) || "";
      });

      // localStorage draft
      const form = document.getElementById("onboarding-form");
      const DRAFT_KEY = "mm-panel-onboarding-draft-v1";
      const DRAFT_TS_KEY = "mm-panel-onboarding-draft-ts";
      const draftStatus = document.getElementById("draft-status");

      function snapshotForm() {
        const data = new FormData(form);
        const out = {};
        for (const [k, v] of data.entries()) out[k] = v;
        return out;
      }

      // Relative time formatter — "2 min temu", "1 godz temu", "wczoraj"
      function relativeTime(ts) {
        if (!ts) return "";
        const sec = Math.floor((Date.now() - ts) / 1000);
        if (sec < 5) return "przed chwilą";
        if (sec < 60) return `${sec} s temu`;
        const min = Math.floor(sec / 60);
        if (min < 60) return `${min} min temu`;
        const hr = Math.floor(min / 60);
        if (hr < 24) return `${hr} godz temu`;
        return `${Math.floor(hr / 24)} d temu`;
      }
      function updateDraftStatus() {
        const ts = parseInt(localStorage.getItem(DRAFT_TS_KEY) || "0", 10);
        if (!ts) { draftStatus.textContent = ""; return; }
        draftStatus.textContent = "Ostatni zapis: " + relativeTime(ts) + ".";
      }
      // Tick every 15s so "2 min temu" auto-refreshes to "3 min temu"
      setInterval(updateDraftStatus, 15_000);

      function saveDraft() {
        try {
          const now = Date.now();
          localStorage.setItem(DRAFT_KEY, JSON.stringify(snapshotForm()));
          localStorage.setItem(DRAFT_TS_KEY, String(now));
          updateDraftStatus();
        } catch {}
      }

      // ============ MULTI-STEP WIZARD NAVIGATION ============
      const TOTAL_STEPS = 9;
      let currentStep = 1;
      const stepperItems = Array.from(document.querySelectorAll("#stepper-list > li"));
      const prevBtn = document.getElementById("prev-step");
      const nextBtn = document.getElementById("next-step");
      const submitBtn = document.getElementById("submit-btn");

      function getStepElement(n) {
        return form.querySelectorAll(":scope > details")[n - 1] || null;
      }

      function goToStep(n, opts) {
        opts = opts || {};
        n = Math.max(1, Math.min(TOTAL_STEPS, n));
        currentStep = n;
        // Toggle visibility of all step <details>
        form.querySelectorAll(":scope > details").forEach((el, idx) => {
          const stepN = idx + 1;
          const active = stepN === n;
          el.classList.toggle("is-active-step", active);
          el.open = active;
        });
        // Update stepper UI
        stepperItems.forEach((li, idx) => {
          const stepN = idx + 1;
          li.classList.remove("is-current", "is-done");
          if (stepN < n) li.classList.add("is-done");
          if (stepN === n) {
            li.classList.add("is-current");
            li.setAttribute("aria-current", "step");
          } else {
            li.removeAttribute("aria-current");
          }
        });
        // Button visibility
        prevBtn.hidden = n === 1;
        nextBtn.hidden = n === TOTAL_STEPS;
        submitBtn.hidden = n !== TOTAL_STEPS;
        // Update progress
        updateProgress();
        // Scroll to top of step (only if not initial load)
        if (!opts.silent) {
          const stepEl = getStepElement(n);
          if (stepEl) stepEl.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      }

      function validateCurrentStep() {
        const stepEl = getStepElement(currentStep);
        if (!stepEl) return true;
        const requireds = stepEl.querySelectorAll("input[required]:not([type=hidden]), select[required], textarea[required]");
        for (const el of requireds) {
          if (!el.checkValidity()) {
            el.focus();
            el.scrollIntoView({ behavior: "smooth", block: "center" });
            stepEl.classList.add("has-errors");
            stepEl.style.borderColor = "var(--c-danger)";
            stepEl.style.boxShadow = "0 0 0 3px color-mix(in srgb, var(--c-danger) 15%, transparent)";
            return false;
          }
        }
        // Clear any prior error highlight
        stepEl.classList.remove("has-errors");
        stepEl.style.borderColor = "";
        stepEl.style.boxShadow = "";
        return true;
      }

      nextBtn.addEventListener("click", () => {
        if (!validateCurrentStep()) return;
        goToStep(currentStep + 1);
      });
      prevBtn.addEventListener("click", () => goToStep(currentStep - 1));

      // Click on stepper pill jumps (only to steps <= currentStep + 1, i.e. already-visited)
      stepperItems.forEach((li) => {
        const targetStep = parseInt(li.dataset.stepJump || "0", 10);
        const handler = () => {
          if (targetStep <= currentStep) {
            // Going back — no validation needed
            goToStep(targetStep);
          } else if (targetStep === currentStep + 1) {
            // Going forward by one — validate first
            if (validateCurrentStep()) goToStep(targetStep);
          }
          // Skipping forward (>+1) blocked silently
        };
        li.addEventListener("click", handler);
        li.addEventListener("keydown", (e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            handler();
          }
        });
      });

      // ============ PROGRESS INDICATOR ============
      const progressFill = document.getElementById("progress-fill");
      const progressLabel = document.getElementById("progress-label");
      const progressPct = document.getElementById("progress-pct");
      const progressTrack = document.getElementById("progress-track");
      function isSectionFilled(section) {
        // A section "counts as filled" when ALL required inputs (visible) have non-empty values
        const requireds = section.querySelectorAll('input[required]:not([type="hidden"]), select[required], textarea[required]');
        if (requireds.length === 0) {
          // Optional section — count as filled if ANY non-hidden input has a value (or checkbox checked)
          const any = section.querySelectorAll('input:not([type="hidden"]), select, textarea');
          return Array.from(any).some((el) => {
            if (el.type === "checkbox") return el.checked;
            return String(el.value || "").trim().length > 0;
          });
        }
        return Array.from(requireds).every((el) => {
          if (el.type === "checkbox") return el.checked;
          return String(el.value || "").trim().length > 0;
        });
      }
      function updateProgress() {
        // Progress bar reflects CURRENT STEP position (not "filled" count) —
        // simpler UX: user sees "you're at step 3 of 9" not "3 of 9 sections done".
        const pct = Math.round((currentStep / TOTAL_STEPS) * 100);
        if (progressFill) progressFill.style.width = pct + "%";
        if (progressLabel) progressLabel.textContent = `Krok ${currentStep} / ${TOTAL_STEPS}`;
        if (progressPct) progressPct.textContent = pct + "%";
        if (progressTrack) progressTrack.setAttribute("aria-valuenow", String(currentStep));
        if (progressFill) progressFill.style.background = currentStep === TOTAL_STEPS ? "#10b981" : "var(--c-brand)";
      }
      // Progress now driven by currentStep (not field-by-field) — no need to listen on form input.
      function loadDraft() {
        try {
          const raw = localStorage.getItem(DRAFT_KEY);
          if (!raw) { addServiceRow(); return; }
          const data = JSON.parse(raw);
          const sc = Object.keys(data).filter(k => /^services_\d+_slug$/.test(k)).length;
          const rc = Object.keys(data).filter(k => /^reviews_\d+_author$/.test(k)).length;
          for (let i = 0; i < Math.max(sc, 1); i++) addServiceRow();
          for (let i = 0; i < rc; i++) addReviewRow();
          for (const [k, v] of Object.entries(data)) {
            const el = form.elements.namedItem(k);
            if (!el) continue;
            if (el instanceof HTMLInputElement && el.type === "checkbox") el.checked = v === "on" || v === "true";
            else if ("value" in el) el.value = v;
          }
          industrySel.dispatchEvent(new Event("change"));
          draftStatus.textContent = "Szkic przywrócony";
        } catch { addServiceRow(); }
      }
      loadDraft();
      // After draft restore, jump to first incomplete step (or step 1 fresh)
      function findFirstIncompleteStep() {
        for (let i = 1; i <= TOTAL_STEPS; i++) {
          const el = getStepElement(i);
          if (!el) continue;
          if (!isSectionFilled(el)) return i;
        }
        return 1; // all filled — show step 1 for review
      }
      goToStep(findFirstIncompleteStep(), { silent: true });
      updateDraftStatus();
      form.addEventListener("input", () => {
        clearTimeout(window.__draftTimer);
        window.__draftTimer = setTimeout(saveDraft, 400);
      });

      const SUBMIT_LABEL = "Zatwierdź i rozpocznij budowę strony →";

      // Clear previous error highlights from sections
      function clearSectionErrors() {
        form.querySelectorAll(":scope > details").forEach((s) => {
          s.classList.remove("has-errors");
          s.style.borderColor = "";
        });
      }
      // Find first invalid required input, open its section, scroll + focus
      function highlightFirstInvalid() {
        clearSectionErrors();
        const invalid = form.querySelectorAll("input:invalid:not([type=hidden]), select:invalid, textarea:invalid");
        if (invalid.length === 0) return null;
        const first = invalid[0];
        const section = first.closest("details");
        if (section) {
          section.open = true;
          section.classList.add("has-errors");
          section.style.borderColor = "var(--c-danger)";
          section.style.boxShadow = "0 0 0 3px color-mix(in srgb, var(--c-danger) 15%, transparent)";
          section.scrollIntoView({ behavior: "smooth", block: "center" });
          setTimeout(() => first.focus(), 600);
        }
        return { input: first, section };
      }

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const submitBtn = document.getElementById("submit-btn");
        const errBox = document.getElementById("form-errors");
        errBox.style.display = "none";

        // Native validity check first — highlight section before sending
        if (!form.checkValidity()) {
          const result = highlightFirstInvalid();
          if (result) {
            errBox.innerHTML = `<strong>Brakuje danych w sekcji:</strong> sprawdź podświetlone pole "${result.input.name || result.input.id || "—"}".`;
            errBox.style.display = "block";
            return;
          }
        }
        clearSectionErrors();
        submitBtn.disabled = true;
        submitBtn.textContent = "Wysyłam…";

        const data = snapshotForm();
        const get = (k) => String(data[k] || "").trim();
        const num = (k) => { const v = get(k); return v ? Number(v) : undefined; };

        const services = [];
        for (let i = 0; i < serviceIdx; i++) {
          if (!get(`services_${i}_slug`)) continue;
          const s = {
            slug: get(`services_${i}_slug`),
            name: get(`services_${i}_name`),
            description: get(`services_${i}_description`),
          };
          const price = get(`services_${i}_price_from`);
          const icon = get(`services_${i}_icon_key`);
          if (price) s.price_from = price;
          if (icon) s.icon_key = icon;
          services.push(s);
        }

        const reviews = [];
        for (let i = 0; i < reviewIdx; i++) {
          if (!get(`reviews_${i}_author`)) continue;
          reviews.push({
            author: get(`reviews_${i}_author`),
            rating: Number(get(`reviews_${i}_rating`)) || 5,
            date: get(`reviews_${i}_date`),
            text: get(`reviews_${i}_text`),
            source: get(`reviews_${i}_source`) || "gbp",
          });
        }

        const payload = {
          legal_name: get("legal_name") || undefined,
          regon: get("regon") || undefined,
          industry: get("industry"),
          schema_type: get("schema_type"),
          founded_year: num("founded_year"),
          employee_count: num("employee_count"),
          description: get("description"),
          tagline: get("tagline"),
          long_description: get("long_description"),
          // Preview mode: no domain — provisioning will deploy to workers.dev subdomain.
          // Hub generates a deterministic preview slug from client_id when primary_domain is empty.
          primary_domain: get("primary_domain") || undefined,
          domain_source: get("domain_source"),
          street_address: get("street_address"),
          city: get("city"),
          voivodeship: get("voivodeship"),
          postal_code: get("postal_code"),
          latitude: num("latitude"),
          longitude: num("longitude"),
          service_area: get("service_area").split(",").map(s => s.trim()).filter(Boolean),
          contact_person_name: get("contact_person_name") || undefined,
          contact_phone: get("contact_phone") || undefined,
          services,
          hours: {
            monday: get("hours_monday") || undefined,
            tuesday: get("hours_tuesday") || undefined,
            wednesday: get("hours_wednesday") || undefined,
            thursday: get("hours_thursday") || undefined,
            friday: get("hours_friday") || undefined,
            saturday: get("hours_saturday") || undefined,
            sunday: get("hours_sunday") || undefined,
            note: get("hours_note") || undefined,
          },
          theme_preset: get("theme_preset"),
          theme_variant: get("theme_variant") || undefined,
          theme_hero: get("theme_hero") || undefined,
          theme_accent: get("theme_accent") || undefined,
          theme_sections: (() => {
            const raw = get("theme_sections");
            if (!raw) return undefined;
            try {
              const arr = JSON.parse(raw);
              if (Array.isArray(arr)) return arr.map((kind) => ({ kind, enabled: true }));
            } catch { /* empty */ }
            return undefined;
          })(),
          plausible: form.elements.namedItem("plausible").checked,
          zaraz: form.elements.namedItem("zaraz").checked,
          ga4_id: get("ga4_id") || undefined,
          meta_pixel: get("meta_pixel") || undefined,
          reviews,
          consent_version: get("consent_version") || "v1.0",
          privacy_policy_url: get("privacy_policy_url") || undefined,
          terms_url: get("terms_url") || undefined,
          dpa_signed: form.elements.namedItem("dpa_signed").checked,
        };

        try {
          const res = await fetch("/api/onboarding/submit", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });
          const json = await res.json();
          if (json.ok) {
            localStorage.removeItem(DRAFT_KEY);
            window.location.href = json.data.next || "/onboarding/complete";
          } else {
            const errs = json.errors || [];
            errBox.innerHTML = errs.length
              ? "<strong>Brakuje danych:</strong><ul>" + errs.map(e => `<li><code>${e.field}</code>: ${e.message}</li>`).join("") + "</ul>"
              : "<strong>Błąd:</strong> " + (json.error || "Nieznany błąd");
            errBox.style.display = "block";
            errBox.scrollIntoView({ behavior: "smooth" });
            submitBtn.disabled = false;
            submitBtn.textContent = SUBMIT_LABEL;
          }
        } catch (err) {
          errBox.innerHTML = "<strong>Błąd sieci:</strong> " + err.message;
          errBox.style.display = "block";
          submitBtn.disabled = false;
          submitBtn.textContent = SUBMIT_LABEL;
        }
      });
    </script>
  </body>
</html>
