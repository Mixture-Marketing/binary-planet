          <div class="grid-2">
            <input type="hidden" name="consent_version" value="v1.0" required />
            <label>
              <span class="field-label-text">URL polityki prywatności</span>
              <input type="url" name="privacy_policy_url" placeholder="https://twojafirma.pl/polityka-prywatnosci" />
              <small class="field-hint">Jeśli już masz na innej stronie — link tutaj. Inaczej wygenerujemy szablon RODO-zgodny.</small>
            </label>
            <label>
              <span class="field-label-text">URL regulaminu</span>
              <input type="url" name="terms_url" placeholder="https://twojafirma.pl/regulamin" />
              <small class="field-hint">Opcjonalnie. Dla B2B i usług na zlecenie warto mieć.</small>
            </label>
          </div>
          <label class="radio-card" style="cursor: pointer; margin-top: 0.85rem;">
            <input type="checkbox" name="dpa_signed" required />
            <div>
              <strong>Akceptuję umowę powierzenia przetwarzania danych (DPA) z MixtureMarketing<span class="req">*</span></strong>
              <p style="margin: 0.25rem 0 0 0; font-size: 0.85rem; color: var(--c-text-muted);">
                Pełna treść umowy: <a href="/rodo" target="_blank" style="color: var(--c-brand);">Polityka RODO MixtureMarketing →</a>
