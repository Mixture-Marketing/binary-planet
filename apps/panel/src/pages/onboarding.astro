---
import "../styles/panel.css";
import Icon from "../components/Icon.astro";
import { INDUSTRIES, POLISH_VOIVODESHIPS } from "../lib/industries.ts";
import { previewSvg, type PreviewStyle, type ThemeTokens } from "@mixturemarketing/web-core/theme";

// Style cards with default variant per style (light tokens for preview)
const STYLE_CARDS: Array<{
  slug: PreviewStyle;
  labelPl: string;
  tagline: string;
  industries: string;
  defaultVariant: string;
  tokens: ThemeTokens;
  recommendedSections: string[];
}> = [
  {
    slug: "minimalist",
    labelPl: "Czysty",
    tagline: "Profesjonalny, spokojny, klarowny",
    industries: "Prawnik · Lekarz · Księgowy · Doradca · IT · Architekt",
    defaultVariant: "mono-blue",
    tokens: { brand: "#0a4cff", brandFg: "#ffffff", accent: "#ff5c1f", surface: "#ffffff", surfaceMuted: "#f7f8fa", text: "#0a0a0a", textMuted: "#4a4a4a", border: "#e6e8ec" },
    recommendedSections: ["pricing", "team"],
  },
  {
    slug: "elegant",
    labelPl: "Elegancki",
    tagline: "Premium, ciepły, atmosfera",
    industries: "SPA · Salon · Fryzjer · Fotograf · Butik · Hotel",
    defaultVariant: "rose-cream",
    tokens: { brand: "#c4546d", brandFg: "#ffffff", accent: "#b08d57", surface: "#fdfaf6", surfaceMuted: "#f5ebe4", text: "#2a1d1f", textMuted: "#6b525a", border: "#e8d8d4" },
    recommendedSections: ["gallery", "history", "team"],
  },
  {
    slug: "dynamic",
    labelPl: "Dynamiczny",
    tagline: "Konwersyjny, mocny, \"zadzwoń teraz\"",
    industries: "Ślusarz · Mechanik · Hydraulik · Kurier · Fast-food · Siłownia",
    defaultVariant: "red-action",
    tokens: { brand: "#dc2626", brandFg: "#ffffff", accent: "#fbbf24", surface: "#ffffff", surfaceMuted: "#fef2f2", text: "#0a0a0a", textMuted: "#525252", border: "#fecaca" },
    recommendedSections: ["pricing", "video"],
  },
  {
    slug: "editorial",
    labelPl: "Magazynowy",
    tagline: "Narracyjny, historia firmy",
    industries: "Restauracja · Hotel butikowy · Winnica · Marka osobista",
    defaultVariant: "forest-amber",
    tokens: { brand: "#2d4a36", brandFg: "#fef8f0", accent: "#c47a2e", surface: "#fef8f0", surfaceMuted: "#f0e6d4", text: "#1a1410", textMuted: "#5c4f3f", border: "#d9c8a8" },
    recommendedSections: ["history", "gallery", "video", "team"],
  },
];

const client = Astro.locals.client;
const nonce = Astro.locals.nonce ?? "";
if (!client) return Astro.redirect("/login");
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Wizard onboardingu — {client.businessName}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body style="background: var(--c-bg);">
    <header style="background: var(--c-surface); border-bottom: 1px solid var(--c-border); padding: 1.25rem 2rem;">
      <div style="max-width: 880px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center;">
        <div>
          <h1 style="margin: 0; font-size: 1.1rem; font-weight: 700;">Skonfigurujmy Twoją stronę</h1>
          <p style="margin: 0.25rem 0 0 0; font-size: 0.85rem; color: var(--c-text-muted);">{client.businessName} · pakiet <strong>{client.tier}</strong></p>
        </div>
        <form method="POST" action="/api/auth/logout">
          <button type="submit" class="btn" style="font-size: 0.85rem; padding: 0.4rem 0.85rem; min-height: 32px;">
            <Icon name="log-out" size={14} /> Wyloguj
          </button>
        </form>
      </div>
    </header>

    <main style="max-width: 880px; margin: 0 auto; padding: 2rem;" data-nonce={nonce}>
      <div class="card" style="margin-bottom: 1.5rem; background: #ecfdf5; border-color: #a7f3d0;">
        <div style="display: flex; gap: 0.75rem; align-items: start;">
          <div style="color: var(--c-brand); flex-shrink: 0;"><Icon name="info" size={20} /></div>
          <div>
            <p style="margin: 0 0 0.25rem 0; font-weight: 600;">Wypełnij formularz w 5-10 minut</p>
            <p style="margin: 0; font-size: 0.9rem; color: var(--c-text-muted);">
              Stan zapisuje się automatycznie. Możesz przerwać i wrócić w każdej chwili. Po zatwierdzeniu Twoja strona będzie gotowa w 24h.
            </p>
          </div>
        </div>
      </div>

      <form id="onboarding-form" novalidate method="POST" action="#">
        <!-- ============ 1. DANE FIRMY ============ -->
        <details open class="card" style="margin-bottom: 1rem;">
          <summary style="font-weight: 700; font-size: 1.05rem; cursor: pointer; display: flex; align-items: center; gap: 0.5rem;">
            <span style="background: var(--c-brand); color: white; width: 24px; height: 24px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.85rem;">1</span>
            Dodatkowe dane firmy
          </summary>
          <p class="field-hint" style="margin-top: 0.5rem;">NIP, nazwę firmy i email podałeś już przy zamówieniu. Tu uzupełniasz resztę.</p>
          <div class="grid-2">
            <label>
              <span class="field-label-text">Nazwa prawna</span>
              <input type="text" name="legal_name" placeholder="np. Kowalski Jan — Usługi Ślusarskie" />
              <small class="field-hint">Tylko jeśli inna niż handlowa (DG czasem ma długą oficjalną nazwę).</small>
            </label>
            <label>
              <span class="field-label-text">REGON</span>
              <input type="text" name="regon" pattern="\d{9}(\d{5})?" inputmode="numeric" maxlength="14" placeholder="123456789" />
              <small class="field-hint">9 cyfr (DG) lub 14 cyfr (spółka). Pomijasz jeśli nie masz.</small>
            </label>
            <label>
              <span class="field-label-text">Branża<span class="req">*</span></span>
              <select name="industry" required data-industry>
                <option value="">— wybierz —</option>
                {INDUSTRIES.map((i) => (
                  <option value={i.slug} data-schema={i.schemaType}>{i.label}</option>
                ))}
              </select>
              <small class="field-hint">Wpływa na schema.org (lepsza pozycja w Google) + sugerowane sekcje strony.</small>
            </label>
            <input type="hidden" name="schema_type" required />
            <label>
              <span class="field-label-text">Rok założenia</span>
              <input type="number" name="founded_year" inputmode="numeric" min="1900" max={new Date().getFullYear()} placeholder="2018" />
              <small class="field-hint">Buduje zaufanie ("od 7 lat na rynku"). Pomijasz jeśli nowa firma.</small>
            </label>
            <label>
              <span class="field-label-text">Liczba pracowników</span>
              <input type="number" name="employee_count" inputmode="numeric" min="1" max="10000" placeholder="1" />
              <small class="field-hint">Wliczając Ciebie. Wyświetlamy jako "team" tylko gdy &gt; 1.</small>
            </label>
            <label>
              <span class="field-label-text">Osoba kontaktowa</span>
              <input type="text" name="contact_person_name" maxlength="100" placeholder="Jan Kowalski" />
              <small class="field-hint">Imię i nazwisko właściciela / managera. Pokażemy w sekcji "Zespół" jeśli włączysz.</small>
            </label>
          </div>
          <label style="display: block;">
            <span class="field-label-text">Krótki opis firmy<span class="req">*</span></span>
            <textarea name="description" required maxlength="500" rows="2" data-counter="description-counter" placeholder="Profesjonalne usługi ślusarskie w Rzeszowie. Otwieranie zamków, dorabianie kluczy — 24/7."></textarea>
            <div style="display: flex; justify-content: space-between; gap: 1rem;">
              <small class="field-hint">Pokazany w Google jako opis pod tytułem. <strong>Cel: zachęta do kliknięcia.</strong></small>
              <small class="field-counter" id="description-counter">0 / 500</small>
            </div>
          </label>
          <label style="display: block;">
            <span class="field-label-text">Tagline<span class="req">*</span></span>
            <input type="text" name="tagline" required maxlength="140" data-counter="tagline-counter" placeholder="Otworzymy każdy zamek — 24/7 w Rzeszowie" />
            <div style="display: flex; justify-content: space-between; gap: 1rem;">
              <small class="field-hint">Jedna mocna linia w hero strony głównej. Konkrety + lokalizacja.</small>
              <small class="field-counter" id="tagline-counter">0 / 140</small>
            </div>
          </label>
          <label style="display: block;">
            <span class="field-label-text">Długi opis firmy<span class="req">*</span></span>
            <textarea name="long_description" required maxlength="5000" rows="6" data-counter="longdesc-counter" placeholder="Działam jako ślusarz w Rzeszowie od ponad 20 lat. Specjalizuję się w awaryjnym otwieraniu zamków bez uszkadzania drzwi — używam profesjonalnych narzędzi (wytrychy, pikówki). Pracuję 24/7, dojeżdżam do 50 km od centrum Rzeszowa..."></textarea>
            <div style="display: flex; justify-content: space-between; gap: 1rem;">
              <small class="field-hint">Pokazany na stronie "O firmie" + indeksowany przez Google. Min. 200 znaków dla dobrego SEO.</small>
              <small class="field-counter" id="longdesc-counter">0 / 5000</small>
            </div>
          </label>
        </details>

        <!-- ============ 2. DOMENA ============ -->
        <details open class="card" style="margin-bottom: 1rem;">
          <summary style="font-weight: 700; font-size: 1.05rem; cursor: pointer; display: flex; align-items: center; gap: 0.5rem;">
            <span style="background: var(--c-brand); color: white; width: 24px; height: 24px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.85rem;">2</span>
            Domena Twojej strony
          </summary>
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label class="radio-card">
              <input type="radio" name="domain_source" value="register" required checked style="margin-top: 0.25rem;" />
              <div>
                <strong>Zarejestrujcie dla mnie nową domenę</strong>
                <p style="margin: 0.25rem 0 0 0; font-size: 0.85rem; color: var(--c-text-muted);">Sprawdzimy dostępność i kupimy w OVH — koszt wliczony w pakiet (~16-60 zł/rok zależnie od końcówki).</p>
              </div>
            </label>
            <label class="radio-card">
              <input type="radio" name="domain_source" value="owned" style="margin-top: 0.25rem;" />
              <div>
                <strong>Mam już własną domenę</strong>
                <p style="margin: 0.25rem 0 0 0; font-size: 0.85rem; color: var(--c-text-muted);">Skonfigurujemy DNS — wystarczy że dasz nam dostęp do panelu rejestratora (OVH / home.pl / nazwa.pl).</p>
              </div>
            </label>
          </div>
          <label style="display: block;">
            <span class="field-label-text">Domena<span class="req">*</span></span>
            <input type="text" name="primary_domain" id="primary_domain" required placeholder="np. kowalski-slusarz.pl" pattern="[a-z0-9.-]+\.[a-z]{2,}" autocomplete="off" />
            <small class="field-hint">Tylko same litery, cyfry, myślniki + końcówka (.pl, .com, .eu).</small>
            <div
              id="domain-check-result"
              role="status"
              aria-live="polite"
              style="margin-top: 0.5rem; font-size: 0.9rem; min-height: 1.3rem;"
            ></div>
          </label>
        </details>

        <!-- ============ 3. LOKALIZACJA ============ -->
        <details open class="card" style="margin-bottom: 1rem;">
          <summary style="font-weight: 700; font-size: 1.05rem; cursor: pointer; display: flex; align-items: center; gap: 0.5rem;">
            <span style="background: var(--c-brand); color: white; width: 24px; height: 24px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.85rem;">3</span>
            Lokalizacja
          </summary>
          <div class="grid-2">
            <label>
              <span class="field-label-text">Ulica i numer<span class="req">*</span></span>
              <input type="text" name="street_address" required placeholder="ul. Słowackiego 12" />
              <small class="field-hint">Adres siedziby. Pokazany na Google Maps + na stronie kontaktowej.</small>
            </label>
            <label>
              <span class="field-label-text">Miasto<span class="req">*</span></span>
              <input type="text" name="city" required placeholder="Rzeszów" />
              <small class="field-hint">Miasto siedziby firmy.</small>
            </label>
            <label>
              <span class="field-label-text">Województwo<span class="req">*</span></span>
              <select name="voivodeship" required>
                <option value="">— wybierz —</option>
                {POLISH_VOIVODESHIPS.map((v) => <option value={v}>{v}</option>)}
              </select>
            </label>
            <label>
              <span class="field-label-text">Kod pocztowy<span class="req">*</span></span>
              <input type="text" name="postal_code" id="postal_code" required pattern="\d{2}-\d{3}" inputmode="numeric" maxlength="6" placeholder="35-060" autocomplete="postal-code" />
              <small class="field-hint">Myślnik dodawany automatycznie. Format: NN-NNN.</small>
            </label>
          </div>
          <details style="margin-top: 0.85rem;">
            <summary style="font-size: 0.88rem; color: var(--c-text-muted); cursor: pointer;">Współrzędne GPS (opcjonalne — generujemy automatycznie z adresu)</summary>
            <div class="grid-2" style="margin-top: 0.5rem;">
              <label>
                <span class="field-label-text">Latitude</span>
                <input type="number" name="latitude" step="any" placeholder="50.0413" inputmode="decimal" />
                <small class="field-hint">Tylko jeśli automatyczne mapowanie z adresu jest nieprecyzyjne.</small>
              </label>
              <label>
                <span class="field-label-text">Longitude</span>
                <input type="number" name="longitude" step="any" placeholder="21.999" inputmode="decimal" />
              </label>
            </div>
          </details>
          <label style="display: block;">
            <span class="field-label-text">Obszar obsługi<span class="req">*</span></span>
            <input type="text" name="service_area" required placeholder="Rzeszów, Boguchwała, Tyczyn, Łańcut, Krasne" />
            <small class="field-hint">Miasta gdzie dojeżdżasz — generujemy osobną stronę local SEO dla każdego ("Ślusarz Boguchwała"). Oddzielone przecinkami, min. 1.</small>
          </label>
        </details>

        <!-- ============ 4. USŁUGI ============ -->
        <details open class="card" style="margin-bottom: 1rem;">
          <summary style="font-weight: 700; font-size: 1.05rem; cursor: pointer; display: flex; align-items: center; gap: 0.5rem;">
            <span style="background: var(--c-brand); color: white; width: 24px; height: 24px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.85rem;">4</span>
            Twoje usługi (1-8)
          </summary>
          <div id="services-list" style="margin-top: 0.75rem; display: flex; flex-direction: column; gap: 0.75rem;"></div>
          <button type="button" id="add-service" class="btn" style="margin-top: 0.75rem;">+ Dodaj usługę</button>
        </details>

        <!-- ============ 5. GODZINY ============ -->
        <details class="card" style="margin-bottom: 1rem;">
          <summary style="font-weight: 700; font-size: 1.05rem; cursor: pointer; display: flex; align-items: center; gap: 0.5rem;">
            <span style="background: var(--c-brand); color: white; width: 24px; height: 24px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.85rem;">5</span>
            Godziny otwarcia
            <span class="section-badge optional">opcjonalne</span>
          </summary>
          <p class="field-hint">Wybierz szablon poniżej, albo wpisz ręcznie format <code>HH:MM-HH:MM</code> (np. <code>08:00-18:00</code>). Wpisz <code>closed</code> dla dnia wolnego. Puste pole = nie pokazujemy tego dnia.</p>

          <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.75rem;">
            <button type="button" class="btn" data-hours-preset="standard" style="font-size: 0.82rem;">📋 Standardowe (8-18 pn-pt)</button>
            <button type="button" class="btn" data-hours-preset="extended" style="font-size: 0.82rem;">⏰ Wydłużone (7-20 pn-pt + sob)</button>
            <button type="button" class="btn" data-hours-preset="24-7" style="font-size: 0.82rem;">🚨 Całodobowo (24/7)</button>
            <button type="button" class="btn" data-hours-preset="weekend" style="font-size: 0.82rem;">🛍️ Z weekendem (9-17 pn-sob)</button>
            <button type="button" class="btn" data-hours-preset="clear" style="font-size: 0.82rem;">✕ Wyczyść</button>
          </div>

          <div class="grid-2" style="margin-top: 0.85rem;">
            <label>
              <span class="field-label-text">Poniedziałek</span>
              <input type="text" name="hours_monday" placeholder="08:00-18:00" pattern="(closed|\d{2}:\d{2}-\d{2}:\d{2})?" />
            </label>
            <label>
              <span class="field-label-text">Wtorek</span>
              <input type="text" name="hours_tuesday" placeholder="08:00-18:00" pattern="(closed|\d{2}:\d{2}-\d{2}:\d{2})?" />
            </label>
            <label>
              <span class="field-label-text">Środa</span>
              <input type="text" name="hours_wednesday" placeholder="08:00-18:00" pattern="(closed|\d{2}:\d{2}-\d{2}:\d{2})?" />
            </label>
            <label>
              <span class="field-label-text">Czwartek</span>
              <input type="text" name="hours_thursday" placeholder="08:00-18:00" pattern="(closed|\d{2}:\d{2}-\d{2}:\d{2})?" />
            </label>
            <label>
              <span class="field-label-text">Piątek</span>
              <input type="text" name="hours_friday" placeholder="08:00-18:00" pattern="(closed|\d{2}:\d{2}-\d{2}:\d{2})?" />
            </label>
            <label>
              <span class="field-label-text">Sobota</span>
              <input type="text" name="hours_saturday" placeholder="09:00-14:00 lub closed" pattern="(closed|\d{2}:\d{2}-\d{2}:\d{2})?" />
            </label>
            <label>
              <span class="field-label-text">Niedziela</span>
              <input type="text" name="hours_sunday" placeholder="closed" pattern="(closed|\d{2}:\d{2}-\d{2}:\d{2})?" />
            </label>
          </div>
          <label style="display: block;">
            <span class="field-label-text">Dodatkowa informacja</span>
            <input type="text" name="hours_note" maxlength="200" placeholder="Awaryjne wezwania 24/7 — telefon w każdej chwili" />
            <small class="field-hint">Pojawi się pod tabelą godzin — np. info o przerwach, urlopach, dodatkowych usługach.</small>
          </label>
        </details>

        <!-- ============ 6. THEME ============ -->
        <details open class="card" style="margin-bottom: 1rem;">
          <summary style="font-weight: 700; font-size: 1.05rem; cursor: pointer; display: flex; align-items: center; gap: 0.5rem;">
            <span style="background: var(--c-brand); color: white; width: 24px; height: 24px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.85rem;">6</span>
            Styl strony — wybierz wizualnie
          </summary>
          <p style="margin: 0.75rem 0; color: var(--c-text-muted); font-size: 0.9rem;">
            Każdy styl ma inny charakter — kolory, fonty, układ. Kliknij ten, który najlepiej pasuje do Twojej firmy.
            Możesz to zmienić w każdej chwili po onboardingu w <code>Ustawienia → Wygląd strony</code>.
          </p>

          <input type="hidden" name="theme_preset" id="theme_preset" value="minimalist" required />
          <input type="hidden" name="theme_variant" id="theme_variant" value="mono-blue" required />
          <input type="hidden" name="theme_hero" id="theme_hero" value="" />
          <input type="hidden" name="theme_accent" id="theme_accent" value="" />
          <input type="hidden" name="theme_sections" id="theme_sections" value={JSON.stringify(STYLE_CARDS[0]!.recommendedSections)} />

          <div class="style-picker" style="display: grid; grid-template-columns: 1fr; gap: 1rem; margin-top: 1rem;">
            {STYLE_CARDS.map((card, idx) => (
              <button
                type="button"
                class={`style-card ${idx === 0 ? "is-current" : ""}`}
                data-style-pick
                data-slug={card.slug}
                data-variant={card.defaultVariant}
                data-sections={JSON.stringify(card.recommendedSections)}
                aria-pressed={idx === 0 ? "true" : "false"}
                style={`background: transparent; border: 2px solid ${idx === 0 ? "var(--c-brand)" : "var(--c-border)"}; border-radius: 12px; padding: 0; cursor: pointer; text-align: left; overflow: hidden; transition: border-color 200ms, transform 150ms; display: block;`}
              >
                <div style="position: relative;">
                  <Fragment set:html={previewSvg(card.slug, card.tokens, card.labelPl)} />
                  <span class="style-card__check" aria-hidden="true" style={`position: absolute; top: 0.75rem; right: 0.75rem; width: 28px; height: 28px; border-radius: 50%; background: var(--c-brand); color: #fff; display: ${idx === 0 ? "flex" : "none"}; align-items: center; justify-content: center; font-weight: 700; font-size: 1rem; box-shadow: 0 2px 6px rgba(0,0,0,0.15);`}>✓</span>
                </div>
                <div style="padding: 1rem 1.25rem 1.25rem 1.25rem; background: var(--c-surface);">
                  <div style="display: flex; align-items: baseline; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 0.4rem;">
                    <strong style="font-size: 1.1rem; color: var(--c-text);">{card.labelPl}</strong>
                    <span style="font-size: 0.85rem; color: var(--c-text-muted); font-style: italic;">{card.tagline}</span>
                  </div>
                  <div style="font-size: 0.78rem; color: var(--c-text-muted); margin-bottom: 0.5rem;">{card.industries}</div>
                  <div style="display: flex; gap: 0.3rem; align-items: center;">
                    <span style={`width: 14px; height: 14px; border-radius: 50%; background: ${card.tokens.brand}; border: 1px solid var(--c-border);`} aria-hidden="true"></span>
                    <span style={`width: 14px; height: 14px; border-radius: 50%; background: ${card.tokens.accent}; border: 1px solid var(--c-border);`} aria-hidden="true"></span>
                    <span style={`width: 14px; height: 14px; border-radius: 50%; background: ${card.tokens.surface}; border: 1px solid var(--c-border);`} aria-hidden="true"></span>
                    <span style="font-size: 0.78rem; color: var(--c-text-muted); margin-left: 0.4rem;">Domyślnie włączone sekcje: <strong>{card.recommendedSections.join(", ")}</strong></span>
                  </div>
                </div>
              </button>
            ))}
          </div>

          <p style="margin: 0.75rem 0 0 0; color: var(--c-text-muted); font-size: 0.78rem;">
            <strong>Po wyborze:</strong> ten styl ma domyślną paletę kolorów, parę fontów (np. Inter / Playfair Display / Barlow Condensed / Fraunces) i wybrane sekcje strony.
            Wszystko można zmienić w <code>Ustawienia → Wygląd strony</code> i <code>Sekcje strony</code>.
          </p>

          <style is:global>
            .style-picker { width: 100%; }
            @media (min-width: 768px) { .style-picker { grid-template-columns: 1fr 1fr !important; } }
            .style-card { width: 100%; }
            .style-card:hover { transform: translateY(-2px); border-color: var(--c-brand) !important; }
            .style-card svg { display: block; width: 100% !important; height: auto !important; }
          </style>

          <script is:inline>
            (function () {
              document.addEventListener("click", (e) => {
                const btn = e.target.closest("[data-style-pick]");
                if (!btn) return;
                e.preventDefault();
                const slug = btn.dataset.slug;
                const variant = btn.dataset.variant;
                const sections = btn.dataset.sections;
                document.getElementById("theme_preset").value = slug;
                document.getElementById("theme_variant").value = variant;
                document.getElementById("theme_sections").value = sections;
                // Visual update
                document.querySelectorAll("[data-style-pick]").forEach((b) => {
                  const isCurrent = b === btn;
                  b.classList.toggle("is-current", isCurrent);
                  b.setAttribute("aria-pressed", isCurrent ? "true" : "false");
                  b.style.borderColor = isCurrent ? "var(--c-brand)" : "var(--c-border)";
                  const check = b.querySelector(".style-card__check");
                  if (check) check.style.display = isCurrent ? "flex" : "none";
                });
              });
            })();
          </script>
        </details>

        <!-- ============ 7. INTEGRACJE ============ -->
        <details class="card" style="margin-bottom: 1rem;">
          <summary style="font-weight: 700; font-size: 1.05rem; cursor: pointer; display: flex; align-items: center; gap: 0.5rem;">
            <span style="background: var(--c-brand); color: white; width: 24px; height: 24px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.85rem;">7</span>
            Analityka
            <span class="section-badge optional">opcjonalne</span>
          </summary>
          <p class="field-hint">Mierzymy odwiedziny strony. Plausible jest domyślnie włączony (cookieless, bez zgody RODO).</p>
          <div style="display: flex; flex-direction: column; gap: 0.5rem;">
            <label class="radio-card" style="cursor: pointer;">
              <input type="checkbox" name="plausible" checked />
              <div>
                <strong>Plausible Analytics</strong>
                <p style="margin: 0.25rem 0 0 0; font-size: 0.85rem; color: var(--c-text-muted);">Self-hosted, cookieless, RODO-friendly. Bez banera zgód. Wystarczy 95% przypadków.</p>
              </div>
            </label>
            <label class="radio-card" style="cursor: pointer;">
              <input type="checkbox" name="zaraz" />
              <div>
                <strong>Cloudflare Zaraz</strong>
                <p style="margin: 0.25rem 0 0 0; font-size: 0.85rem; color: var(--c-text-muted);">Server-side GA4/Meta Pixel (wolny narzut + lepsze dane). Wymaga konfiguracji + zgód RODO.</p>
              </div>
            </label>
          </div>
          <div class="grid-2">
            <label>
              <span class="field-label-text">GA4 Measurement ID</span>
              <input type="text" name="ga4_id" pattern="G-[A-Z0-9]+" placeholder="G-XXXXXXXXXX" />
              <small class="field-hint">Znajdziesz w Google Analytics → Admin → Property Settings.</small>
            </label>
            <label>
              <span class="field-label-text">Meta Pixel ID</span>
              <input type="text" name="meta_pixel" pattern="\d+" inputmode="numeric" placeholder="123456789012345" />
              <small class="field-hint">Znajdziesz w Meta Business Manager → Events Manager.</small>
            </label>
          </div>
        </details>

        <!-- ============ 8. OPINIE ============ -->
        <details class="card" style="margin-bottom: 1rem;">
          <summary style="font-weight: 700; font-size: 1.05rem; cursor: pointer; display: flex; align-items: center; gap: 0.5rem;">
            <span style="background: var(--c-brand); color: white; width: 24px; height: 24px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.85rem;">8</span>
            Opinie startowe
            <span class="section-badge optional">opcjonalne (max 3)</span>
          </summary>
          <p class="field-hint">
            Skopiuj 1-3 opinie z Twojej wizytówki Google (Google Maps → "Twoja firma" → karta Opinie).
            Pokażemy je na stronie głównej żeby budować zaufanie. Później klienci końcowi sami będą dawać opinie.
          </p>
          <div id="reviews-list" style="display: flex; flex-direction: column; gap: 0.75rem;"></div>
          <button type="button" id="add-review" class="btn">+ Dodaj opinię</button>
        </details>

        <!-- ============ 9. RODO ============ -->
        <details open class="card" style="margin-bottom: 1rem;">
          <summary style="font-weight: 700; font-size: 1.05rem; cursor: pointer; display: flex; align-items: center; gap: 0.5rem;">
            <span style="background: var(--c-brand); color: white; width: 24px; height: 24px; border-radius: 12px; display: inline-flex; align-items: center; justify-content: center; font-size: 0.85rem;">9</span>
            RODO i DPA
            <span class="section-badge required">wymagane</span>
          </summary>
          <p class="field-hint">
            MixtureMarketing przetwarza dane Twoich klientów (formularze leadów) jako <strong>podmiot przetwarzający</strong> (Art. 28 RODO).
            Musisz zaakceptować umowę powierzenia (DPA) — to gwarancja że dane Twoich klientów są bezpieczne i Ty pozostajesz administratorem.
          </p>
          <div class="grid-2">
            <input type="hidden" name="consent_version" value="v1.0" required />
            <label>
              <span class="field-label-text">URL polityki prywatności</span>
              <input type="url" name="privacy_policy_url" placeholder="https://twojafirma.pl/polityka-prywatnosci" />
              <small class="field-hint">Jeśli już masz na innej stronie — link tutaj. Inaczej wygenerujemy szablon RODO-zgodny.</small>
            </label>
            <label>
              <span class="field-label-text">URL regulaminu</span>
              <input type="url" name="terms_url" placeholder="https://twojafirma.pl/regulamin" />
              <small class="field-hint">Opcjonalnie. Dla B2B i usług na zlecenie warto mieć.</small>
            </label>
          </div>
          <label class="radio-card" style="cursor: pointer; margin-top: 0.85rem;">
            <input type="checkbox" name="dpa_signed" required />
            <div>
              <strong>Akceptuję umowę powierzenia przetwarzania danych (DPA) z MixtureMarketing<span class="req">*</span></strong>
              <p style="margin: 0.25rem 0 0 0; font-size: 0.85rem; color: var(--c-text-muted);">
                Pełna treść umowy: <a href="/rodo" target="_blank" style="color: var(--c-brand);">Polityka RODO MixtureMarketing →</a>
              </p>
            </div>
          </label>
        </details>

        <!-- ============ SUBMIT ============ -->
        <div id="form-errors" style="display: none; padding: 1rem; background: #fef2f2; border: 1px solid #fecaca; color: var(--c-danger); border-radius: 8px; margin-bottom: 1rem;"></div>

        <div class="submit-bar">
          <div style="flex: 1; min-width: 200px;">
            <p style="margin: 0; font-weight: 700; font-size: 1rem;">Gotowy do startu?</p>
            <p style="margin: 0.15rem 0 0 0; font-size: 0.85rem; color: var(--c-text-muted);">
              Po zatwierdzeniu zaczynamy budowę. Strona online za ~24h. <span id="draft-status" style="color: var(--c-text-muted); font-size: 0.85rem;"></span>
            </p>
          </div>
          <button type="submit" id="submit-btn" class="btn btn-primary" style="min-height: 48px; font-size: 1rem; padding: 0.75rem 1.5rem;">
            Zatwierdź i rozpocznij budowę strony →
          </button>
        </div>
      </form>
    </main>

    <style is:global>
      /* Field grid — 2-col desktop, 1-col mobile, with consistent gap */
      .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem 1rem; }
      @media (max-width: 720px) { .grid-2 { grid-template-columns: 1fr; gap: 0.85rem; } }

      /* Label structure — text above, input below, hint below input */
      label {
        display: flex; flex-direction: column; gap: 0.3rem;
        font-size: 0.92rem; line-height: 1.4;
        color: var(--c-text);
      }
      label > .field-label-text { font-weight: 600; }
      label .req { color: var(--c-danger); font-weight: 700; margin-left: 0.15rem; }
      .field-hint {
        font-size: 0.78rem; color: var(--c-text-muted); margin-top: 0.1rem;
        line-height: 1.4;
      }
      .field-counter {
        font-size: 0.72rem; color: var(--c-text-muted);
        text-align: right; font-variant-numeric: tabular-nums;
        margin-top: -0.15rem;
      }
      .field-counter.is-warn { color: #b45309; }
      .field-counter.is-over { color: var(--c-danger); font-weight: 600; }

      /* Inputs — bigger touch targets (44px min), consistent padding */
      input[type="text"], input[type="email"], input[type="number"], input[type="tel"], select, textarea {
        padding: 0.65rem 0.75rem;
        border: 1px solid var(--c-border); border-radius: 8px;
        font-family: inherit; font-size: 0.95rem; background: white;
        min-height: 42px; box-sizing: border-box;
        transition: border-color 150ms, box-shadow 150ms;
      }
      textarea { min-height: 80px; resize: vertical; }
      input:focus, select:focus, textarea:focus {
        outline: none; border-color: var(--c-brand);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--c-brand) 20%, transparent);
      }
      input:invalid:not(:placeholder-shown) { border-color: var(--c-danger); }
      input:invalid:not(:placeholder-shown):focus {
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--c-danger) 20%, transparent);
      }

      /* Sub-sections inside details */
      details > *:not(summary) { margin-top: 0.85rem; }
      details > summary { padding: 0.15rem 0; }

      .service-row, .review-row {
        background: var(--c-surface-muted); padding: 1rem;
        border-radius: 8px; border: 1px solid var(--c-border);
      }

      /* Radio cards */
      .radio-card {
        display: flex; gap: 0.6rem; align-items: start;
        padding: 0.85rem 1rem; border: 1px solid var(--c-border);
        border-radius: 8px; cursor: pointer;
        transition: border-color 150ms, background 150ms;
      }
      .radio-card:has(input:checked) {
        border-color: var(--c-brand); background: color-mix(in srgb, var(--c-brand) 6%, transparent);
      }

      /* Submit button area */
      .submit-bar {
        position: sticky; bottom: 1rem; z-index: 5;
        background: var(--c-surface); border: 1px solid var(--c-border);
        border-radius: 12px; padding: 1rem;
        box-shadow: 0 -4px 12px -8px rgba(0,0,0,0.15);
        display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;
      }

      /* Section badges — required vs optional */
      .section-badge {
        font-size: 0.7rem; padding: 0.15rem 0.45rem; border-radius: 999px;
        margin-left: 0.5rem; font-weight: 600; letter-spacing: 0.02em;
      }
      .section-badge.required { background: color-mix(in srgb, var(--c-danger) 12%, transparent); color: #991b1b; }
      .section-badge.optional { background: var(--c-surface-muted); color: var(--c-text-muted); }
    </style>

    <script is:inline>
      const servicesList = document.getElementById("services-list");
      const addServiceBtn = document.getElementById("add-service");
      let serviceIdx = 0;
      function addServiceRow(prefill) {
        prefill = prefill || {};
        const i = serviceIdx++;
        const row = document.createElement("div");
        row.className = "service-row";
        row.innerHTML = `
          <input type="hidden" name="services_${i}_slug" data-auto-slug value="${prefill.slug||''}" />
          <div class="grid-2">
            <label>Nazwa usługi *
              <input type="text" name="services_${i}_name" data-service-name required maxlength="120" value="${prefill.name||''}" placeholder="np. Awaryjne otwieranie zamków" />
            </label>
            <label>Cena od (opcjonalne)
              <input type="text" name="services_${i}_price_from" maxlength="40" value="${prefill.price_from||''}" placeholder="od 100 zł" />
            </label>
          </div>
          <label style="margin-top: 0.5rem;">Krótki opis *
            <textarea name="services_${i}_description" required maxlength="500" rows="2" placeholder="np. Otwieram każdy zamek bez uszkodzenia drzwi, dojazd 24/7 w okolice Rzeszowa.">${prefill.description||''}</textarea>
          </label>
          <input type="hidden" name="services_${i}_icon_key" value="${prefill.icon_key||''}" />
          <button type="button" class="btn" data-remove style="margin-top: 0.5rem; font-size: 0.8rem;">Usuń</button>
        `;
        // Auto-generate slug from name (slugify Polish characters → ASCII kebab-case)
        const nameInput = row.querySelector("[data-service-name]");
        const slugInput = row.querySelector("[data-auto-slug]");
        function slugify(s) {
          return s
            .toLowerCase()
            .normalize("NFD").replace(/[̀-ͯ]/g, "")
            .replace(/ł/g, "l")
            .replace(/[^a-z0-9]+/g, "-")
            .replace(/^-|-$/g, "")
            .slice(0, 60);
        }
        nameInput.addEventListener("input", () => {
          // Don't overwrite if user manually customized (prefilled non-empty + differs from current name slugify)
          if (!slugInput.dataset.locked) slugInput.value = slugify(nameInput.value);
        });
        // If prefill had explicit slug, lock auto-update
        if (prefill.slug && slugify(prefill.name || "") !== prefill.slug) {
          slugInput.dataset.locked = "true";
        }
        row.querySelector("[data-remove]").addEventListener("click", () => row.remove());
        servicesList.appendChild(row);
      }
      addServiceBtn.addEventListener("click", () => addServiceRow());

      // ============ DOMAIN AVAILABILITY CHECK (OVH) ============
      // Debounced inline check — calls /api/onboarding/check-domain when user
      // pauses typing. Shows price (first year + renew) or "taken" status.
      const domainInput = document.getElementById("primary_domain");
      const domainResult = document.getElementById("domain-check-result");
      const domainSourceRadios = document.querySelectorAll('input[name="domain_source"]');
      let domainCheckTimer = null;
      let lastCheckedDomain = "";
      function shouldCheck() {
        // Only check when user wants us to REGISTER (not "I have own")
        const sourceEl = document.querySelector('input[name="domain_source"]:checked');
        return sourceEl?.value === "register";
      }
      function renderDomainResult(html, tone) {
        const colors = {
          info: "color: #1e40af;",
          ok: "color: #047857;",
          warn: "color: #b45309;",
          err: "color: #b91c1c;",
        };
        domainResult.style.cssText = "margin-top: 0.5rem; font-size: 0.9rem; min-height: 1.3rem; " + (colors[tone] || colors.info);
        domainResult.innerHTML = html;
      }
      async function checkDomainNow() {
        const d = domainInput.value.trim().toLowerCase();
        if (!d || !/^[a-z0-9.-]+\.[a-z]{2,}$/.test(d)) {
          domainResult.innerHTML = "";
          return;
        }
        if (d === lastCheckedDomain) return;
        if (!shouldCheck()) {
          renderDomainResult("Wybrałeś \"mam własną domenę\" — sprawdzanie dostępności pominięte.", "info");
          return;
        }
        lastCheckedDomain = d;
        renderDomainResult("⏳ Sprawdzam dostępność w OVH...", "info");
        try {
          const res = await fetch("/api/onboarding/check-domain?domain=" + encodeURIComponent(d));
          const body = await res.json();
          if (!body.ok) {
            renderDomainResult("⚠ Nie udało się sprawdzić: " + (body.error || "unknown"), "warn");
            return;
          }
          const data = body.data;
          if (data.available) {
            const price = data.price_first_year ? `${data.price_first_year.value} ${data.price_first_year.currency || "PLN"}` : "(cena nieznana)";
            const renew = data.price_renew ? `, odnowienie ${data.price_renew.value} ${data.price_renew.currency || "PLN"}/rok` : "";
            renderDomainResult(`✓ <strong>${d}</strong> dostępna — pierwszy rok ${price}${renew} (wliczone w pakiet)`, "ok");
          } else {
            renderDomainResult(`✗ <strong>${d}</strong> już zajęta. Jeśli to Twoja domena — zaznacz wyżej "Mam już własną domenę".`, "err");
          }
        } catch (e) {
          renderDomainResult("⚠ Błąd sieci: " + (e?.message || e), "warn");
        }
      }
      if (domainInput) {
        domainInput.addEventListener("input", () => {
          if (domainCheckTimer) clearTimeout(domainCheckTimer);
          domainCheckTimer = setTimeout(checkDomainNow, 700);
        });
        domainSourceRadios.forEach((r) => r.addEventListener("change", () => {
          lastCheckedDomain = "";
          checkDomainNow();
        }));
      }

      // ============ POSTAL CODE AUTO-FORMAT (NN-NNN) ============
      const postalInput = document.getElementById("postal_code");
      if (postalInput) {
        postalInput.addEventListener("input", (e) => {
          const v = e.target.value.replace(/\D/g, "").slice(0, 5);
          e.target.value = v.length > 2 ? v.slice(0, 2) + "-" + v.slice(2) : v;
        });
      }

      // ============ CHARACTER COUNTERS ============
      document.querySelectorAll("[data-counter]").forEach((input) => {
        const counter = document.getElementById(input.dataset.counter);
        if (!counter) return;
        const max = parseInt(input.maxLength, 10) || parseInt(input.getAttribute("maxlength"), 10) || 0;
        const update = () => {
          const len = input.value.length;
          counter.textContent = `${len} / ${max}`;
          counter.classList.toggle("is-warn", len > max * 0.85 && len <= max);
          counter.classList.toggle("is-over", len >= max);
        };
        input.addEventListener("input", update);
        update();
      });

      // ============ HOURS PRESETS ============
      const HOURS_PRESETS = {
        "standard": { monday: "08:00-18:00", tuesday: "08:00-18:00", wednesday: "08:00-18:00", thursday: "08:00-18:00", friday: "08:00-18:00", saturday: "closed", sunday: "closed" },
        "extended": { monday: "07:00-20:00", tuesday: "07:00-20:00", wednesday: "07:00-20:00", thursday: "07:00-20:00", friday: "07:00-20:00", saturday: "09:00-14:00", sunday: "closed" },
        "24-7":     { monday: "00:00-23:59", tuesday: "00:00-23:59", wednesday: "00:00-23:59", thursday: "00:00-23:59", friday: "00:00-23:59", saturday: "00:00-23:59", sunday: "00:00-23:59" },
        "weekend":  { monday: "09:00-17:00", tuesday: "09:00-17:00", wednesday: "09:00-17:00", thursday: "09:00-17:00", friday: "09:00-17:00", saturday: "09:00-17:00", sunday: "closed" },
        "clear":    { monday: "", tuesday: "", wednesday: "", thursday: "", friday: "", saturday: "", sunday: "" },
      };
      document.querySelectorAll("[data-hours-preset]").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          const preset = HOURS_PRESETS[btn.dataset.hoursPreset];
          if (!preset) return;
          Object.entries(preset).forEach(([day, val]) => {
            const input = document.querySelector(`input[name="hours_${day}"]`);
            if (input) {
              input.value = val;
              input.dispatchEvent(new Event("input", { bubbles: true }));
            }
          });
          if (btn.dataset.hoursPreset === "24-7") {
            const note = document.querySelector('input[name="hours_note"]');
            if (note && !note.value) note.value = "Awaryjne wezwania 24/7 — telefon w każdej chwili";
          }
        });
      });

      const reviewsList = document.getElementById("reviews-list");
      const addReviewBtn = document.getElementById("add-review");
      let reviewIdx = 0;
      function addReviewRow(prefill) {
        prefill = prefill || {};
        const i = reviewIdx++;
        const row = document.createElement("div");
        row.className = "review-row";
        row.innerHTML = `
          <div class="grid-2">
            <label>Autor *<input type="text" name="reviews_${i}_author" required maxlength="80" value="${prefill.author||''}" /></label>
            <label>Ocena *
              <select name="reviews_${i}_rating" required>
                ${[5,4,3,2,1].map(r => `<option value="${r}" ${prefill.rating == String(r) ? 'selected' : ''}>${"★".repeat(r)}</option>`).join('')}
              </select>
            </label>
            <label>Data * (YYYY-MM-DD)<input type="text" name="reviews_${i}_date" required pattern="\\d{4}-\\d{2}-\\d{2}" value="${prefill.date||''}" /></label>
            <label>Źródło
              <select name="reviews_${i}_source">
                <option value="gbp">GBP</option><option value="manual">Manual</option><option value="facebook">Facebook</option>
              </select>
            </label>
          </div>
          <label style="margin-top: 0.5rem;">Treść *<textarea name="reviews_${i}_text" required maxlength="800" rows="2">${prefill.text||''}</textarea></label>
          <button type="button" class="btn" data-remove style="margin-top: 0.5rem; font-size: 0.8rem;">Usuń</button>
        `;
        row.querySelector("[data-remove]").addEventListener("click", () => row.remove());
        reviewsList.appendChild(row);
      }
      addReviewBtn.addEventListener("click", () => addReviewRow());

      // Industry → schema_type
      const industrySel = document.querySelector("[data-industry]");
      const schemaInput = document.querySelector('input[name="schema_type"]');
      industrySel.addEventListener("change", () => {
        const opt = industrySel.selectedOptions[0];
        schemaInput.value = (opt && opt.dataset.schema) || "";
      });

      // localStorage draft
      const form = document.getElementById("onboarding-form");
      const DRAFT_KEY = "mm-panel-onboarding-draft-v1";
      const draftStatus = document.getElementById("draft-status");

      function snapshotForm() {
        const data = new FormData(form);
        const out = {};
        for (const [k, v] of data.entries()) out[k] = v;
        return out;
      }
      function saveDraft() {
        try {
          localStorage.setItem(DRAFT_KEY, JSON.stringify(snapshotForm()));
          draftStatus.textContent = "Zapisano " + new Date().toLocaleTimeString("pl-PL");
        } catch {}
      }
      function loadDraft() {
        try {
          const raw = localStorage.getItem(DRAFT_KEY);
          if (!raw) { addServiceRow(); return; }
          const data = JSON.parse(raw);
          const sc = Object.keys(data).filter(k => /^services_\d+_slug$/.test(k)).length;
          const rc = Object.keys(data).filter(k => /^reviews_\d+_author$/.test(k)).length;
          for (let i = 0; i < Math.max(sc, 1); i++) addServiceRow();
          for (let i = 0; i < rc; i++) addReviewRow();
          for (const [k, v] of Object.entries(data)) {
            const el = form.elements.namedItem(k);
            if (!el) continue;
            if (el instanceof HTMLInputElement && el.type === "checkbox") el.checked = v === "on" || v === "true";
            else if ("value" in el) el.value = v;
          }
          industrySel.dispatchEvent(new Event("change"));
          draftStatus.textContent = "Szkic przywrócony";
        } catch { addServiceRow(); }
      }
      loadDraft();
      form.addEventListener("input", () => {
        clearTimeout(window.__draftTimer);
        window.__draftTimer = setTimeout(saveDraft, 400);
      });

      const SUBMIT_LABEL = "Zatwierdź i rozpocznij budowę strony →";
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const submitBtn = document.getElementById("submit-btn");
        const errBox = document.getElementById("form-errors");
        errBox.style.display = "none";
        submitBtn.disabled = true;
        submitBtn.textContent = "Wysyłam…";

        const data = snapshotForm();
        const get = (k) => String(data[k] || "").trim();
        const num = (k) => { const v = get(k); return v ? Number(v) : undefined; };

        const services = [];
        for (let i = 0; i < serviceIdx; i++) {
          if (!get(`services_${i}_slug`)) continue;
          const s = {
            slug: get(`services_${i}_slug`),
            name: get(`services_${i}_name`),
            description: get(`services_${i}_description`),
          };
          const price = get(`services_${i}_price_from`);
          const icon = get(`services_${i}_icon_key`);
          if (price) s.price_from = price;
          if (icon) s.icon_key = icon;
          services.push(s);
        }

        const reviews = [];
        for (let i = 0; i < reviewIdx; i++) {
          if (!get(`reviews_${i}_author`)) continue;
          reviews.push({
            author: get(`reviews_${i}_author`),
            rating: Number(get(`reviews_${i}_rating`)) || 5,
            date: get(`reviews_${i}_date`),
            text: get(`reviews_${i}_text`),
            source: get(`reviews_${i}_source`) || "gbp",
          });
        }

        const payload = {
          legal_name: get("legal_name") || undefined,
          regon: get("regon") || undefined,
          industry: get("industry"),
          schema_type: get("schema_type"),
          founded_year: num("founded_year"),
          employee_count: num("employee_count"),
          description: get("description"),
          tagline: get("tagline"),
          long_description: get("long_description"),
          primary_domain: get("primary_domain"),
          domain_source: get("domain_source"),
          street_address: get("street_address"),
          city: get("city"),
          voivodeship: get("voivodeship"),
          postal_code: get("postal_code"),
          latitude: num("latitude"),
          longitude: num("longitude"),
          service_area: get("service_area").split(",").map(s => s.trim()).filter(Boolean),
          contact_person_name: get("contact_person_name") || undefined,
          services,
          hours: {
            monday: get("hours_monday") || undefined,
            tuesday: get("hours_tuesday") || undefined,
            wednesday: get("hours_wednesday") || undefined,
            thursday: get("hours_thursday") || undefined,
            friday: get("hours_friday") || undefined,
            saturday: get("hours_saturday") || undefined,
            sunday: get("hours_sunday") || undefined,
            note: get("hours_note") || undefined,
          },
          theme_preset: get("theme_preset"),
          theme_variant: get("theme_variant") || undefined,
          theme_hero: get("theme_hero") || undefined,
          theme_accent: get("theme_accent") || undefined,
          theme_sections: (() => {
            const raw = get("theme_sections");
            if (!raw) return undefined;
            try {
              const arr = JSON.parse(raw);
              if (Array.isArray(arr)) return arr.map((kind) => ({ kind, enabled: true }));
            } catch { /* empty */ }
            return undefined;
          })(),
          plausible: form.elements.namedItem("plausible").checked,
          zaraz: form.elements.namedItem("zaraz").checked,
          ga4_id: get("ga4_id") || undefined,
          meta_pixel: get("meta_pixel") || undefined,
          reviews,
          consent_version: get("consent_version") || "v1.0",
          privacy_policy_url: get("privacy_policy_url") || undefined,
          terms_url: get("terms_url") || undefined,
          dpa_signed: form.elements.namedItem("dpa_signed").checked,
        };

        try {
          const res = await fetch("/api/onboarding/submit", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });
          const json = await res.json();
          if (json.ok) {
            localStorage.removeItem(DRAFT_KEY);
            window.location.href = json.data.next || "/onboarding/complete";
          } else {
            const errs = json.errors || [];
            errBox.innerHTML = errs.length
              ? "<strong>Brakuje danych:</strong><ul>" + errs.map(e => `<li><code>${e.field}</code>: ${e.message}</li>`).join("") + "</ul>"
              : "<strong>Błąd:</strong> " + (json.error || "Nieznany błąd");
            errBox.style.display = "block";
            errBox.scrollIntoView({ behavior: "smooth" });
            submitBtn.disabled = false;
            submitBtn.textContent = SUBMIT_LABEL;
          }
        } catch (err) {
          errBox.innerHTML = "<strong>Błąd sieci:</strong> " + err.message;
          errBox.style.display = "block";
          submitBtn.disabled = false;
          submitBtn.textContent = SUBMIT_LABEL;
        }
      });
    </script>
  </body>
</html>
