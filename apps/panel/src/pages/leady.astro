---
import PanelLayout from "../layouts/PanelLayout.astro";
import Icon from "../components/Icon.astro";
import { listLeads } from "../lib/db.ts";

const env = Astro.locals.runtime?.env;
const client = Astro.locals.client;
if (!env?.DB || !client) return new Response("Runtime not ready", { status: 500 });

const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get("status") ?? undefined;
const leadsOpts: { limit: number; status?: string } = { limit: 200 };
if (statusFilter) leadsOpts.status = statusFilter;
const leads = await listLeads(env.DB, client.id, leadsOpts);

const formatRelative = (iso: string): string => {
  const ms = Date.now() - new Date(iso).getTime();
  const min = Math.floor(ms / 60000);
  if (min < 60) return `${min} min temu`;
  const hr = Math.floor(min / 60);
  if (hr < 24) return `${hr} h temu`;
  return `${Math.floor(hr / 24)} d temu`;
};
const fmtPln = (n: number): string => `${n.toLocaleString("pl-PL")} zł`;

const STATUSES = [
  { value: "", label: "Wszystkie" },
  { value: "new", label: "Nowe" },
  { value: "contacted", label: "Skontaktowane" },
  { value: "qualified", label: "Zakwalifikowane" },
  { value: "won", label: "Wygrane" },
  { value: "lost", label: "Przegrane" },
  { value: "unqualified", label: "Niezakwalifikowane" },
];
---

<PanelLayout title="Leady">
  <header style="margin-bottom: 2rem;">
    <h1 style="font-size: 2rem; font-weight: 800; margin: 0 0 0.5rem 0; display: flex; align-items: center; gap: 0.6rem;">
      <Icon name="inbox" size={28} /> Leady
    </h1>
    <p style="margin: 0; color: var(--c-text-muted);">
      Wszystkie zgłoszenia z Twojej strony. {leads.length} wpisów.
    </p>
  </header>

  <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem;">
    {STATUSES.map((s) => (
      <a
        href={s.value ? `/leady?status=${s.value}` : "/leady"}
        class={`btn ${(statusFilter ?? "") === s.value ? "btn-primary" : ""}`}
        style="padding: 0.4rem 0.85rem; min-height: 32px; font-size: 0.85rem;"
      >
        {s.label}
      </a>
    ))}
  </div>

  <div class="card" style="padding: 0;">
    {leads.length === 0 ? (
      <p style="padding: 3rem 2rem; text-align: center; color: var(--c-text-muted); margin: 0;">
        Brak leadów z wybranym statusem.
      </p>
    ) : (
      <table class="table">
        <thead>
          <tr>
            <th>Data</th>
            <th>Źródło</th>
            <th>Usługa</th>
            <th>Wycena</th>
            <th>Kontakt (hash)</th>
            <th>Status</th>
            <th>Notyfikacja</th>
            <th>Marketing</th>
          </tr>
        </thead>
        <tbody>
          {leads.map((lead) => (
            <tr>
              <td style="font-size: 0.85rem; color: var(--c-text-muted);">{formatRelative(lead.created_at)}</td>
              <td style="font-size: 0.85rem;">{lead.source}</td>
              <td>{lead.service_interest ?? "—"}</td>
              <td>{lead.estimated_value_pln ? fmtPln(lead.estimated_value_pln) : "—"}</td>
              <td style="font-family: ui-monospace, monospace; font-size: 0.7rem; color: var(--c-text-muted);">
                {lead.email_hash ? lead.email_hash.slice(0, 12) + "…" : "—"}
              </td>
              <td>
                <span class={`badge ${lead.status === "new" ? "badge-warning" : lead.status === "won" ? "badge-success" : lead.status === "lost" || lead.status === "spam" ? "badge-danger" : ""}`}>{lead.status}</span>
                {lead.is_hot === 1 && <span class="badge badge-danger" style="margin-left: 0.25rem; display: inline-flex; align-items: center; gap: 0.25rem;"><Icon name="flame" size={11} /> hot</span>}
              </td>
              <td style="font-size: 0.8rem;">
                {lead.forwarded_status ?? "—"}
              </td>
              <td>
                {lead.consent_marketing === 1
                  ? <span class="badge badge-success">tak</span>
                  : <span class="badge">nie</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <details class="card" style="margin-top: 1.5rem;">
    <summary style="cursor: pointer; font-weight: 600; display: flex; align-items: center; gap: 0.4rem;">
      <Icon name="info" size={16} /> Dlaczego widzę hash zamiast prawdziwego emaila?
    </summary>
    <p style="margin-top: 1rem; color: var(--c-text-muted); font-size: 0.9rem; line-height: 1.6;">
      Dane osobowe leadów (email, telefon, treść zgłoszenia) są zaszyfrowane w bazie zgodnie z RODO.
      W v0.1 panel pokazuje tylko skróconą wartość hash do identyfikacji wpisu. W praktyce dostajesz pełne
      dane przez email/SMS w momencie zgłoszenia — panel jest do archiwizacji + statystyk.
      Pełne odszyfrowane dane będą dostępne w panelu w wersji v0.2 (po uruchomieniu modułu dekryptującego).
    </p>
  </details>
</PanelLayout>
