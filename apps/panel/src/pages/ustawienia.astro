---
import { env } from "cloudflare:workers";
import PanelLayout from "../layouts/PanelLayout.astro";
import Icon from "../components/Icon.astro";
import { getClientFullConfig, getClientContact } from "../lib/db.ts";
import { previewSvg, type PreviewStyle, type ThemeTokens } from "@mixturemarketing/web-core/theme";

// Inline palette data (mirror of apps/starter/src/themes/registry.ts variants — needed here without importing whole registry)
const PALETTES: Record<PreviewStyle, Record<string, { label: string; light: ThemeTokens; dark: ThemeTokens }>> = {
  minimalist: {
    "mono-blue": {
      label: "Granat + biel",
      light: { brand: "#0a4cff", brandFg: "#ffffff", accent: "#ff5c1f", surface: "#ffffff", surfaceMuted: "#f7f8fa", text: "#0a0a0a", textMuted: "#4a4a4a", border: "#e6e8ec" },
      dark: { brand: "#3b82f6", brandFg: "#ffffff", accent: "#fb923c", surface: "#0a0a0a", surfaceMuted: "#171717", text: "#fafafa", textMuted: "#a3a3a3", border: "#262626" },
    },
    "mono-black": {
      label: "Czerń + biel",
      light: { brand: "#0a0a0a", brandFg: "#ffffff", accent: "#fbbf24", surface: "#ffffff", surfaceMuted: "#fafafa", text: "#0a0a0a", textMuted: "#525252", border: "#e5e5e5" },
      dark: { brand: "#fafafa", brandFg: "#0a0a0a", accent: "#fbbf24", surface: "#0a0a0a", surfaceMuted: "#171717", text: "#fafafa", textMuted: "#a3a3a3", border: "#262626" },
    },
    "mono-emerald": {
      label: "Zieleń + krem",
      light: { brand: "#0d5d3b", brandFg: "#ffffff", accent: "#b8945f", surface: "#ffffff", surfaceMuted: "#f4f7f5", text: "#0d1b15", textMuted: "#475e52", border: "#dde6e0" },
      dark: { brand: "#34d399", brandFg: "#052e1c", accent: "#fbbf24", surface: "#0a1410", surfaceMuted: "#17241c", text: "#f0f5f1", textMuted: "#a3b3a8", border: "#2a3a30" },
    },
  },
  elegant: {
    "rose-cream": {
      label: "Pudrowy róż + krem",
      light: { brand: "#c4546d", brandFg: "#ffffff", accent: "#b08d57", surface: "#fdfaf6", surfaceMuted: "#f5ebe4", text: "#2a1d1f", textMuted: "#6b525a", border: "#e8d8d4" },
      dark: { brand: "#e8a4b5", brandFg: "#2a1d1f", accent: "#d4a574", surface: "#1a1410", surfaceMuted: "#241d1f", text: "#fdfaf6", textMuted: "#c4a8b0", border: "#3a2d2f" },
    },
    "sage-ivory": {
      label: "Szałwia + kość słoniowa",
      light: { brand: "#5d7560", brandFg: "#ffffff", accent: "#c9a96e", surface: "#fbf9f4", surfaceMuted: "#efeae0", text: "#1f2820", textMuted: "#5a6358", border: "#ddd5c4" },
      dark: { brand: "#a3bda6", brandFg: "#1f2820", accent: "#e0b97d", surface: "#1a1f1a", surfaceMuted: "#252b25", text: "#fbf9f4", textMuted: "#b8c4ba", border: "#3a4438" },
    },
    "mocha-blush": {
      label: "Mocha + bronze",
      light: { brand: "#6b4423", brandFg: "#fdf6ee", accent: "#d4a574", surface: "#fcf6ef", surfaceMuted: "#e8d9c8", text: "#2a1810", textMuted: "#6e4d35", border: "#d9c5b0" },
      dark: { brand: "#d4a574", brandFg: "#2a1810", accent: "#e8c498", surface: "#1a120a", surfaceMuted: "#241e15", text: "#fcf6ef", textMuted: "#c4a890", border: "#3a2e1f" },
    },
  },
  dynamic: {
    "red-action": {
      label: "Czerwień + biel",
      light: { brand: "#dc2626", brandFg: "#ffffff", accent: "#fbbf24", surface: "#ffffff", surfaceMuted: "#fef2f2", text: "#0a0a0a", textMuted: "#525252", border: "#fecaca" },
      dark: { brand: "#ef4444", brandFg: "#ffffff", accent: "#fbbf24", surface: "#0a0a0a", surfaceMuted: "#171717", text: "#fafafa", textMuted: "#a3a3a3", border: "#3a1a1a" },
    },
    "electric-blue": {
      label: "Electric + magenta",
      light: { brand: "#1d4ed8", brandFg: "#ffffff", accent: "#ec4899", surface: "#ffffff", surfaceMuted: "#eff6ff", text: "#0a0a0a", textMuted: "#475569", border: "#dbeafe" },
      dark: { brand: "#3b82f6", brandFg: "#ffffff", accent: "#f472b6", surface: "#0a0a14", surfaceMuted: "#17172a", text: "#fafafa", textMuted: "#a3a3b3", border: "#1a2a4a" },
    },
    "neon-noir": {
      label: "Cyan + czerń (dark)",
      light: { brand: "#00ffd1", brandFg: "#0a0a0a", accent: "#ff9500", surface: "#0a0a0a", surfaceMuted: "#171717", text: "#fafafa", textMuted: "#a3a3a3", border: "#262626" },
      dark: { brand: "#00ffd1", brandFg: "#0a0a0a", accent: "#ff9500", surface: "#0a0a0a", surfaceMuted: "#171717", text: "#fafafa", textMuted: "#a3a3a3", border: "#262626" },
    },
  },
  editorial: {
    "forest-amber": {
      label: "Las + bursztyn",
      light: { brand: "#2d4a36", brandFg: "#fef8f0", accent: "#c47a2e", surface: "#fef8f0", surfaceMuted: "#f0e6d4", text: "#1a1410", textMuted: "#5c4f3f", border: "#d9c8a8" },
      dark: { brand: "#7fb893", brandFg: "#1a1410", accent: "#e89556", surface: "#1a1410", surfaceMuted: "#241d15", text: "#fef8f0", textMuted: "#c4b8a8", border: "#3a2e20" },
    },
    "slate-rose": {
      label: "Łupek + róż",
      light: { brand: "#475569", brandFg: "#ffffff", accent: "#be5a6e", surface: "#f8f5f3", surfaceMuted: "#e8e2dd", text: "#1c1c20", textMuted: "#5a5460", border: "#d4ccc4" },
      dark: { brand: "#a3b3c4", brandFg: "#1c1c20", accent: "#e08c9d", surface: "#1a1a1f", surfaceMuted: "#252530", text: "#f8f5f3", textMuted: "#b4adb8", border: "#3a3540" },
    },
    "cream-cobalt": {
      label: "Krem + kobalt",
      light: { brand: "#1e40af", brandFg: "#fef8f0", accent: "#d97706", surface: "#fef8f0", surfaceMuted: "#ede4d3", text: "#0a1424", textMuted: "#475568", border: "#d8cebc" },
      dark: { brand: "#60a5fa", brandFg: "#0a1424", accent: "#fbbf24", surface: "#0a1424", surfaceMuted: "#172033", text: "#fef8f0", textMuted: "#a8b4c4", border: "#1f2d4a" },
    },
  },
};

const client = Astro.locals.client;
if (!env?.DB || !client) return new Response("Runtime not ready", { status: 500 });

const cfg = await getClientFullConfig(env.DB, client.id);
const contact = await getClientContact(env.DB, client.id);

// Read theme + services + sections config from provisioning config_json
const cfgRow = await env.DB
  .prepare(`SELECT config_json FROM client_provisioning_configs WHERE client_id = ? LIMIT 1`)
  .bind(client.id)
  .first<{ config_json: string }>();
type ThemeCfg = { preset?: string; variant?: string; heroVariant?: string; accent?: string; brandColor?: string; accentColor?: string; logoUrl?: string; mode?: "auto" | "light" | "dark"; fontPairIdx?: number };
type ServiceCfg = { slug: string; name: string; description: string; priceFrom?: string; iconKey?: string };
type SectionCfg = { kind: string; enabled: boolean; config?: Record<string, unknown> };
let themeCfg: ThemeCfg = {};
let servicesCfg: ServiceCfg[] = [];
let sectionsCfg: SectionCfg[] = [];
try {
  const parsed = cfgRow ? JSON.parse(cfgRow.config_json) : {};
  themeCfg = (parsed.theme ?? {}) as ThemeCfg;
  servicesCfg = Array.isArray(parsed.services) ? (parsed.services as ServiceCfg[]) : [];
  sectionsCfg = Array.isArray(parsed.sections) ? (parsed.sections as SectionCfg[]) : [];
} catch { /* empty */ }
const curPreset = themeCfg.preset ?? cfg?.theme_preset ?? "craftsman";
const curVariant = themeCfg.variant ?? "red-bold";
const curHero = themeCfg.heroVariant ?? "";
const curAccent = themeCfg.accent ?? "";
const curBrandColor = themeCfg.brandColor ?? "";
const curAccentColor = themeCfg.accentColor ?? "";
const curLogoUrl = themeCfg.logoUrl ?? "";
---

<PanelLayout title="Ustawienia">
  <header style="margin-bottom: 2rem;">
    <h1 style="font-size: 2rem; font-weight: 800; margin: 0 0 0.5rem 0; display: flex; align-items: center; gap: 0.6rem;">
      <Icon name="settings" size={28} /> Ustawienia
    </h1>
    <p style="margin: 0; color: var(--c-text-muted);">
      Aktualne dane Twojej firmy w MixtureMarketing. Edycja przez kontakt z agencją (v0.2 — edycja w panelu).
    </p>
  </header>

  {cfg && (
    <section class="card" style="margin-bottom: 1.5rem;">
      <h2 style="font-size: 1.1rem; font-weight: 700; margin: 0 0 1rem 0;">Dane firmy</h2>
      <dl style="display: grid; grid-template-columns: max-content 1fr; gap: 0.6rem 1.5rem; font-size: 0.9rem;">
        <dt style="color: var(--c-text-muted);">Nazwa</dt><dd style="margin: 0;">{cfg.business_name}</dd>
        {cfg.legal_name && <><dt style="color: var(--c-text-muted);">Nazwa prawna</dt><dd style="margin: 0;">{cfg.legal_name}</dd></>}
        {cfg.nip && <><dt style="color: var(--c-text-muted);">NIP</dt><dd style="margin: 0; font-family: ui-monospace, monospace;">{cfg.nip}</dd></>}
        <dt style="color: var(--c-text-muted);">Branża</dt><dd style="margin: 0;">{cfg.industry}</dd>
        <dt style="color: var(--c-text-muted);">Miasto</dt><dd style="margin: 0;">{cfg.city}{cfg.postal_code ? `, ${cfg.postal_code}` : ""}</dd>
        {cfg.voivodeship && <><dt style="color: var(--c-text-muted);">Województwo</dt><dd style="margin: 0;">{cfg.voivodeship}</dd></>}
        {cfg.primary_domain && (
          <><dt style="color: var(--c-text-muted);">Domena</dt><dd style="margin: 0;"><a href={`https://${cfg.primary_domain}`} target="_blank" rel="noopener" style="color: var(--c-brand); display: inline-flex; align-items: center; gap: 0.3rem;">{cfg.primary_domain} <Icon name="external-link" size={12} /></a></dd></>
        )}
      </dl>
    </section>
  )}

  <section class="card" style="margin-bottom: 1.5rem;">
    <h2 style="font-size: 1.1rem; font-weight: 700; margin: 0 0 1rem 0;">Pakiet i status</h2>
    <dl style="display: grid; grid-template-columns: max-content 1fr; gap: 0.6rem 1.5rem; font-size: 0.9rem;">
      <dt style="color: var(--c-text-muted);">Pakiet</dt>
      <dd style="margin: 0;"><span class="badge badge-brand">{cfg?.tier ?? client.tier}</span></dd>
      <dt style="color: var(--c-text-muted);">Status</dt>
      <dd style="margin: 0;"><span class={`badge ${cfg?.status === "active" ? "badge-success" : "badge-warning"}`}>{cfg?.status ?? client.status}</span></dd>
      {cfg?.activated_at && (
        <><dt style="color: var(--c-text-muted);">Aktywacja</dt><dd style="margin: 0;">{new Date(cfg.activated_at).toLocaleDateString("pl-PL")}</dd></>
      )}
      {cfg?.has_lock_in === 1 && cfg.lock_in_until && (
        <><dt style="color: var(--c-text-muted);">Lock-in do</dt><dd style="margin: 0;">{new Date(cfg.lock_in_until).toLocaleDateString("pl-PL")}</dd></>
      )}
    </dl>
  </section>

  {contact && (
    <section class="card" style="margin-bottom: 1.5rem;">
      <h2 style="font-size: 1.1rem; font-weight: 700; margin: 0 0 1rem 0;">Kontakt</h2>
      <form id="contact-form" style="display: flex; flex-direction: column; gap: 0.75rem;">
        <label style="font-size: 0.9rem;">
          Numer telefonu (E.164 z +48...)
          <input type="tel" name="phone" pattern="\+\d{8,15}" placeholder="+48600100200" required style="display: block; margin-top: 0.3rem; width: 100%; padding: 0.5rem; border: 1px solid var(--c-border); border-radius: 6px;" />
        </label>
        <button type="submit" class="btn btn-primary" style="align-self: flex-start;">Zapisz telefon</button>
      </form>
      <p style="margin-top: 1rem; color: var(--c-text-muted); font-size: 0.78rem;">
        Email — kontakt z agencją (zmiana wymaga weryfikacji nowego adresu). Nazwa firmy + NIP — kontakt z agencją.
      </p>
    </section>
  )}

  {/* Hero + tagline */}
  <section class="card" style="margin-bottom: 1.5rem;">
    <h2 style="font-size: 1.1rem; font-weight: 700; margin: 0 0 1rem 0;">Hero strony</h2>
    <form id="hero-form" style="display: flex; flex-direction: column; gap: 0.75rem;">
      <label style="font-size: 0.9rem;">
        Tagline (krótki slogan, max 180 znaków)
        <input type="text" name="tagline" maxlength="180" placeholder="Twój slogan firmy" style="display: block; margin-top: 0.3rem; width: 100%; padding: 0.5rem; border: 1px solid var(--c-border); border-radius: 6px;" />
      </label>
      <label style="font-size: 0.9rem;">
        Opis (max 500 znaków — wyświetla się pod tagline)
        <textarea name="description" maxlength="500" rows="4" placeholder="Opis firmy widoczny na stronie głównej" style="display: block; margin-top: 0.3rem; width: 100%; padding: 0.5rem; border: 1px solid var(--c-border); border-radius: 6px; font-family: inherit;"></textarea>
      </label>
      <button type="submit" class="btn btn-primary" style="align-self: flex-start;">Zapisz + odśwież stronę</button>
      <p style="margin: 0; color: var(--c-text-muted); font-size: 0.78rem;">Po zapisie strona przebudowuje się w ~2 min.</p>
    </form>
  </section>

  {/* Hours */}
  <section class="card" style="margin-bottom: 1.5rem;">
    <h2 style="font-size: 1.1rem; font-weight: 700; margin: 0 0 1rem 0;">Godziny otwarcia</h2>
    <form id="hours-form" style="display: grid; grid-template-columns: max-content 1fr; gap: 0.5rem 1rem; align-items: center;">
      {["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"].map((day) => (
        <>
          <label style="font-size: 0.88rem;" for={`h-${day}`}>{day === "monday" ? "Poniedziałek" : day === "tuesday" ? "Wtorek" : day === "wednesday" ? "Środa" : day === "thursday" ? "Czwartek" : day === "friday" ? "Piątek" : day === "saturday" ? "Sobota" : "Niedziela"}</label>
          <input type="text" id={`h-${day}`} name={day} placeholder="9:00-18:00 lub Zamknięte" style="padding: 0.4rem; border: 1px solid var(--c-border); border-radius: 6px; font-family: ui-monospace, monospace; font-size: 0.85rem;" />
        </>
      ))}
      <div></div>
      <button type="submit" class="btn btn-primary" style="justify-self: start; margin-top: 0.5rem;">Zapisz godziny</button>
    </form>
  </section>

  {/* Oferta / Usługi — repeater */}
  <section class="card" style="margin-bottom: 1.5rem;">
    <h2 style="font-size: 1.1rem; font-weight: 700; margin: 0 0 0.5rem 0;">Oferta / Usługi</h2>
    <p style="margin: 0 0 1rem 0; color: var(--c-text-muted); font-size: 0.85rem;">
      Dodaj, edytuj lub usuń usługi widoczne na stronie. Max 8 usług. Slug generuje się automatycznie z nazwy. Po zapisie strona przebudowuje się w ~2 min.
    </p>

    <div id="services-list" data-services-init={JSON.stringify(servicesCfg)}>
      <!-- Rows rendered by JS init -->
    </div>

    <div style="display: flex; gap: 0.5rem; align-items: center; margin-top: 1rem; flex-wrap: wrap;">
      <button type="button" id="services-add" class="btn btn-secondary">+ Dodaj usługę</button>
      <button type="button" id="services-save" class="btn btn-primary">Zapisz + odśwież stronę</button>
      <span id="services-status" style="font-size: 0.85rem; color: var(--c-text-muted);"></span>
    </div>

    <script is:inline define:vars={{ initialServices: servicesCfg }}>
      (function () {
        const ICONS = [
          ["", "— brak ikony —"],
          ["key", "Klucz (ślusarz)"],
          ["duplicate", "Klucze (dorabianie)"],
          ["shield", "Tarcza (bezpieczeństwo)"],
          ["wrench", "Klucz nasadowy (mechanik)"],
          ["lock", "Kłódka"],
          ["star", "Gwiazdka (premium)"],
          ["flame", "Płomień (food/grill)"],
          ["briefcase", "Teczka (B2B)"],
          ["clipboard-list", "Notatnik (lista usług)"],
          ["mail", "Koperta (kontakt)"],
          ["phone", "Telefon"],
        ];
        const root = document.getElementById("services-list");
        const status = document.getElementById("services-status");
        if (!root) return;

        function slugify(name) {
          return name.toLowerCase()
            .replace(/ł/g, "l").replace(/[ąćęńóśźż]/g, (c) => ({"ą":"a","ć":"c","ę":"e","ń":"n","ó":"o","ś":"s","ź":"z","ż":"z"})[c])
            .replace(/[^a-z0-9]+/g, "-")
            .replace(/(^-|-$)/g, "")
            .slice(0, 60);
        }

        function render(services) {
          root.innerHTML = "";
          services.forEach((svc, idx) => {
            const row = document.createElement("div");
            row.className = "service-row";
            row.style.cssText = "border: 1px solid var(--c-border); border-radius: 8px; padding: 1rem; margin-bottom: 0.75rem; background: var(--c-surface-muted);";
            row.dataset.idx = idx;
            row.innerHTML = `
              <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem;">
                <strong style="flex: 1; font-size: 0.9rem;">Usługa #${idx + 1}</strong>
                <button type="button" data-move-up style="background: transparent; border: 1px solid var(--c-border); padding: 0.2rem 0.5rem; cursor: pointer; font-size: 0.85rem; border-radius: 4px;" ${idx === 0 ? "disabled" : ""}>↑</button>
                <button type="button" data-move-down style="background: transparent; border: 1px solid var(--c-border); padding: 0.2rem 0.5rem; cursor: pointer; font-size: 0.85rem; border-radius: 4px;" ${idx === services.length - 1 ? "disabled" : ""}>↓</button>
                <button type="button" data-remove style="background: transparent; border: 1px solid var(--c-text-muted); color: var(--c-text-muted); padding: 0.2rem 0.6rem; cursor: pointer; font-size: 0.85rem; border-radius: 4px;">Usuń</button>
              </div>
              <div style="display: grid; gap: 0.5rem; grid-template-columns: 1fr 1fr;">
                <label style="font-size: 0.78rem; grid-column: 1 / -1;">
                  Nazwa usługi *
                  <input type="text" data-field="name" value="${escapeHtml(svc.name ?? "")}" maxlength="120" placeholder="np. Awaryjne otwieranie zamków" required style="display: block; width: 100%; margin-top: 0.2rem; padding: 0.4rem; border: 1px solid var(--c-border); border-radius: 4px;" />
                </label>
                <label style="font-size: 0.78rem; grid-column: 1 / -1;">
                  Opis (max 500 znaków) *
                  <textarea data-field="description" maxlength="500" rows="2" placeholder="Krótko o usłudze — co dostaje klient, w jakim czasie, jakie są ograniczenia" required style="display: block; width: 100%; margin-top: 0.2rem; padding: 0.4rem; border: 1px solid var(--c-border); border-radius: 4px; font-family: inherit;">${escapeHtml(svc.description ?? "")}</textarea>
                </label>
                <label style="font-size: 0.78rem;">
                  Cena (opcjonalnie)
                  <input type="text" data-field="priceFrom" value="${escapeHtml(svc.priceFrom ?? "")}" maxlength="40" placeholder="np. od 100 zł, wycena indywidualna" style="display: block; width: 100%; margin-top: 0.2rem; padding: 0.4rem; border: 1px solid var(--c-border); border-radius: 4px;" />
                </label>
                <label style="font-size: 0.78rem;">
                  Ikona (opcjonalnie)
                  <select data-field="iconKey" style="display: block; width: 100%; margin-top: 0.2rem; padding: 0.4rem; border: 1px solid var(--c-border); border-radius: 4px;">
                    ${ICONS.map(([k, l]) => `<option value="${k}"${(svc.iconKey ?? "") === k ? " selected" : ""}>${l}</option>`).join("")}
                  </select>
                </label>
                <input type="hidden" data-field="slug" value="${escapeHtml(svc.slug ?? "")}" />
              </div>
            `;
            root.appendChild(row);
          });
        }

        function escapeHtml(s) {
          return String(s).replace(/[&<>"']/g, (c) => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"})[c]);
        }

        function collect() {
          const services = [];
          root.querySelectorAll(".service-row").forEach((row) => {
            const get = (f) => row.querySelector(`[data-field="${f}"]`)?.value ?? "";
            const name = get("name").trim();
            const description = get("description").trim();
            const priceFrom = get("priceFrom").trim();
            const iconKey = get("iconKey").trim();
            let slug = get("slug").trim();
            if (!slug && name) slug = slugify(name);
            if (!name || !description) return; // skip incomplete
            const obj = { slug, name, description };
            if (priceFrom) obj.priceFrom = priceFrom;
            if (iconKey) obj.iconKey = iconKey;
            services.push(obj);
          });
          return services;
        }

        // Initial render — fallback if empty
        const initial = Array.isArray(initialServices) && initialServices.length > 0
          ? initialServices
          : [];
        render(initial);

        // Add button
        document.getElementById("services-add").addEventListener("click", () => {
          const current = collect();
          if (current.length >= 8) {
            alert("Limit 8 usług osiągnięty. Usuń niepotrzebne aby dodać nowe.");
            return;
          }
          current.push({ slug: "", name: "", description: "", priceFrom: "", iconKey: "" });
          render(current);
        });

        // Row actions (event delegation)
        root.addEventListener("click", async (e) => {
          const row = e.target.closest(".service-row");
          if (!row) return;
          const idx = parseInt(row.dataset.idx, 10);
          const current = collect();
          // Re-sync current row's draft fields before mutating
          if (e.target.matches("[data-remove]")) {
            if (!(await window.mmConfirm("Usunąć tę usługę?", { confirmLabel: "Usuń", danger: true }))) return;
            current.splice(idx, 1);
            render(current);
          } else if (e.target.matches("[data-move-up]") && idx > 0) {
            [current[idx - 1], current[idx]] = [current[idx], current[idx - 1]];
            render(current);
          } else if (e.target.matches("[data-move-down]") && idx < current.length - 1) {
            [current[idx + 1], current[idx]] = [current[idx], current[idx + 1]];
            render(current);
          }
        });

        // Auto-slug from name (live)
        root.addEventListener("input", (e) => {
          if (e.target.matches('[data-field="name"]')) {
            const row = e.target.closest(".service-row");
            const slugField = row.querySelector('[data-field="slug"]');
            if (slugField && !slugField.dataset.customSlug) {
              slugField.value = slugify(e.target.value);
            }
          }
        });

        // Save
        document.getElementById("services-save").addEventListener("click", async () => {
          const services = collect();
          if (services.length === 0) {
            status.textContent = "⚠️ Musi być min. 1 usługa";
            status.style.color = "#dc2626";
            return;
          }
          if (services.length > 8) {
            status.textContent = "⚠️ Max 8 usług";
            status.style.color = "#dc2626";
            return;
          }
          status.textContent = "Zapisuję…";
          status.style.color = "var(--c-text-muted)";
          try {
            const res = await fetch("/api/settings/save", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ kind: "services", services }),
            });
            const j = await res.json();
            if (j.ok) {
              status.textContent = "✓ Zapisane (rebuild w toku ~2 min)";
              status.style.color = "#16a34a";
            } else {
              status.textContent = "Błąd: " + (j.error || "unknown");
              status.style.color = "#dc2626";
            }
          } catch (err) {
            status.textContent = "Network error: " + err;
            status.style.color = "#dc2626";
          }
        });
      })();
    </script>
  </section>

  {/* Sekcje strony — page builder */}
  <section class="card" style="margin-bottom: 1.5rem;">
    <h2 style="font-size: 1.1rem; font-weight: 700; margin: 0 0 0.5rem 0;">Sekcje strony</h2>
    <p style="margin: 0 0 1rem 0; color: var(--c-text-muted); font-size: 0.85rem;">
      Włącz lub wyłącz dodatkowe sekcje strony głównej. Klient widzi tylko włączone. Przeciągnij za uchwyt aby zmienić kolejność. Po zapisie strona przebudowuje się w ~2 min.
    </p>

    <ul id="sections-list" data-sections-init={JSON.stringify(sectionsCfg)} style="list-style: none; padding: 0; margin: 0;">
      <!-- Rendered by JS -->
    </ul>

    <div style="display: flex; gap: 0.5rem; align-items: center; margin-top: 1rem; flex-wrap: wrap;">
      <button type="button" id="sections-save" class="btn btn-primary">Zapisz + odśwież stronę</button>
      <span id="sections-status" style="font-size: 0.85rem; color: var(--c-text-muted);"></span>
    </div>

    <details style="margin-top: 1rem;">
      <summary style="cursor: pointer; font-weight: 600; font-size: 0.85rem; color: var(--c-text-muted);">
        Konfiguracja zawartości sekcji (zaawansowane)
      </summary>
      <div style="margin-top: 0.75rem; padding: 1rem; background: var(--c-surface-muted); border-radius: 6px; font-size: 0.85rem; color: var(--c-text-muted); line-height: 1.5;">
        <p style="margin: 0 0 0.5rem 0;">Treść sekcji edytujesz w <strong>CMS Sveltia</strong> na <code>{themeCfg.preset === "minimalist" ? "twojadomena.pl/admin/" : "twojadomena.pl/admin/"}</code>:</p>
        <ul style="margin: 0; padding-left: 1.5rem;">
          <li><strong>Historia firmy</strong> — long-form rich text + opcjonalne zdjęcie + cytat wyróżniony</li>
          <li><strong>Zespół</strong> — kolekcja osób (imię, rola, opis, zdjęcie)</li>
          <li><strong>Galeria</strong> — upload zdjęć do R2 (Standard+)</li>
          <li><strong>Menu / Karta dań</strong> — kategorie + pozycje z cenami (Standard+)</li>
          <li><strong>Cennik</strong> — auto-generuje się z usług (sekcja "Oferta / Usługi" wyżej)</li>
          <li><strong>Wideo</strong> — wystarczy URL YouTube/Vimeo (poniżej)</li>
        </ul>
      </div>
    </details>

    <script is:inline define:vars={{ initialSections: sectionsCfg, currentStyle: themeCfg.preset ?? "minimalist" }}>
      (function () {
        const root = document.getElementById("sections-list");
        const status = document.getElementById("sections-status");
        if (!root) return;

        const REGISTRY = {
          pricing: { label: "Cennik", desc: "Tabelaryczny cennik usług z cenami.", tier: "free", cms: false },
          team: { label: "Zespół", desc: "Wizytówki członków zespołu (CMS).", tier: "free", cms: true },
          history: { label: "Historia firmy", desc: "Narracja o powstaniu firmy (CMS).", tier: "free", cms: true },
          video: { label: "Wideo", desc: "YouTube/Vimeo embed. Podaj URL poniżej.", tier: "free", cms: false },
          gallery: { label: "Galeria zdjęć", desc: "Grid zdjęć (CMS Sveltia, R2).", tier: "standard", cms: true },
          menu: { label: "Menu / Karta dań", desc: "Karta dań z cenami (CMS).", tier: "standard", cms: true },
          publications: { label: "Publikacje i wystąpienia", desc: "Lista publikacji prasowych / książek / wystąpień (Professional).", tier: "professional", cms: false },
          "trust-badges": { label: "Trust badges (uprawnienia)", desc: "Numer wpisu na listę, polisa OC, certyfikaty (Professional).", tier: "professional", cms: false },
          consultation: { label: "Płatna konsultacja online", desc: "Embed Cal.com/Calendly — klient książe spotkanie z Twojej strony (Professional).", tier: "professional", cms: false },
        };
        const RECOMMENDED = {
          minimalist: ["pricing", "team"],
          elegant: ["gallery", "history", "team"],
          dynamic: ["pricing", "video"],
          editorial: ["history", "gallery", "video", "team"],
        };

        // Merge initial config with full registry (so all sections show even if not in config)
        function normalizeSections(initial) {
          const byKind = {};
          (initial || []).forEach((s) => { byKind[s.kind] = s; });
          const recommended = new Set(RECOMMENDED[currentStyle] || []);
          // Order: initial order preserved, then missing kinds appended
          const result = (initial || []).map((s) => ({
            kind: s.kind,
            enabled: s.enabled !== false,
            config: s.config || {},
          })).filter((s) => REGISTRY[s.kind]);
          Object.keys(REGISTRY).forEach((kind) => {
            if (!byKind[kind]) {
              result.push({ kind, enabled: recommended.has(kind), config: {} });
            }
          });
          return result;
        }

        let sections = normalizeSections(initialSections);

        function render() {
          root.innerHTML = "";
          sections.forEach((s, idx) => {
            const info = REGISTRY[s.kind];
            if (!info) return;
            const tierBadge = info.tier === "free" ? "" : `<span style="display: inline-block; background: var(--c-accent, #f59e0b); color: #fff; padding: 0.1rem 0.4rem; border-radius: 3px; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; margin-left: 0.4rem;">${info.tier.toUpperCase()}+</span>`;
            const cmsBadge = info.cms ? `<span style="display: inline-block; background: transparent; color: var(--c-text-muted); padding: 0.1rem 0.4rem; border-radius: 3px; font-size: 0.65rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; margin-left: 0.4rem; border: 1px solid var(--c-border);">CMS</span>` : "";

            const row = document.createElement("li");
            row.dataset.idx = idx;
            row.dataset.kind = s.kind;
            row.style.cssText = "display: flex; align-items: center; gap: 0.75rem; padding: 0.85rem 1rem; background: var(--c-surface); border: 1px solid var(--c-border); border-radius: 8px; margin-bottom: 0.5rem;";
            row.innerHTML = `
              <span data-handle style="cursor: grab; color: var(--c-text-muted); font-family: ui-monospace, monospace; user-select: none; flex-shrink: 0;" title="Przeciągnij aby zmienić kolejność">⋮⋮</span>
              <label style="display: flex; gap: 0.5rem; align-items: center; cursor: pointer; flex-shrink: 0;">
                <input type="checkbox" data-toggle ${s.enabled ? "checked" : ""} aria-label="Włącz sekcję ${info.label}" />
              </label>
              <div style="flex: 1; min-width: 0;">
                <div style="display: flex; align-items: center; flex-wrap: wrap; gap: 0.25rem;">
                  <strong style="color: var(--c-text); font-size: 0.95rem;">${info.label}</strong>${tierBadge}${cmsBadge}
                </div>
                <div style="color: var(--c-text-muted); font-size: 0.78rem; margin-top: 0.15rem;">${info.desc}</div>
                ${s.kind === "video" ? renderVideoConfig(s) : ""}
              </div>
              <div style="display: flex; gap: 0.25rem; flex-shrink: 0;">
                <button type="button" data-up style="background: transparent; border: 1px solid var(--c-border); border-radius: 4px; padding: 0.25rem 0.5rem; cursor: pointer; font-size: 0.85rem;" ${idx === 0 ? "disabled" : ""} aria-label="Przesuń wyżej">↑</button>
                <button type="button" data-down style="background: transparent; border: 1px solid var(--c-border); border-radius: 4px; padding: 0.25rem 0.5rem; cursor: pointer; font-size: 0.85rem;" ${idx === sections.length - 1 ? "disabled" : ""} aria-label="Przesuń niżej">↓</button>
              </div>
            `;
            root.appendChild(row);
          });
        }

        function renderVideoConfig(s) {
          const url = (s.config && s.config.url) || "";
          return `<input type="url" data-video-url placeholder="https://youtube.com/watch?v=... lub https://vimeo.com/..." value="${escapeAttr(url)}" style="display: block; width: 100%; max-width: 28rem; margin-top: 0.4rem; padding: 0.3rem 0.5rem; border: 1px solid var(--c-border); border-radius: 4px; font-size: 0.78rem; font-family: ui-monospace, monospace;" />`;
        }

        function escapeAttr(s) { return String(s).replace(/"/g, "&quot;"); }

        function syncFromDom() {
          root.querySelectorAll("li").forEach((li, idx) => {
            const kind = li.dataset.kind;
            const enabled = li.querySelector("[data-toggle]").checked;
            const sec = sections.find((s) => s.kind === kind);
            if (!sec) return;
            sec.enabled = enabled;
            if (kind === "video") {
              const url = li.querySelector("[data-video-url]")?.value?.trim() || "";
              sec.config = url ? { ...sec.config, url } : { ...sec.config };
              if (!url) delete sec.config.url;
            }
          });
        }

        root.addEventListener("click", (e) => {
          const li = e.target.closest("li");
          if (!li) return;
          const idx = parseInt(li.dataset.idx, 10);
          syncFromDom();
          if (e.target.matches("[data-up]") && idx > 0) {
            [sections[idx - 1], sections[idx]] = [sections[idx], sections[idx - 1]];
            render();
          } else if (e.target.matches("[data-down]") && idx < sections.length - 1) {
            [sections[idx + 1], sections[idx]] = [sections[idx], sections[idx + 1]];
            render();
          }
        });

        // Simple drag-and-drop reorder (HTML5 DnD via handle)
        let dragSrc = null;
        root.addEventListener("mousedown", (e) => {
          if (!e.target.matches("[data-handle]")) return;
          const li = e.target.closest("li");
          if (!li) return;
          li.setAttribute("draggable", "true");
        });
        root.addEventListener("dragstart", (e) => {
          dragSrc = e.target.closest("li");
          if (dragSrc) {
            dragSrc.style.opacity = "0.4";
            syncFromDom();
          }
        });
        root.addEventListener("dragover", (e) => {
          e.preventDefault();
          const li = e.target.closest("li");
          if (!li || li === dragSrc) return;
          li.style.borderTop = "2px solid var(--c-brand)";
        });
        root.addEventListener("dragleave", (e) => {
          const li = e.target.closest("li");
          if (li) li.style.borderTop = "";
        });
        root.addEventListener("drop", (e) => {
          e.preventDefault();
          const li = e.target.closest("li");
          if (!li || !dragSrc || li === dragSrc) return;
          li.style.borderTop = "";
          const srcIdx = parseInt(dragSrc.dataset.idx, 10);
          const tgtIdx = parseInt(li.dataset.idx, 10);
          const [moved] = sections.splice(srcIdx, 1);
          sections.splice(tgtIdx, 0, moved);
          render();
        });
        root.addEventListener("dragend", () => {
          if (dragSrc) dragSrc.style.opacity = "";
          root.querySelectorAll("li").forEach((li) => { li.style.borderTop = ""; li.removeAttribute("draggable"); });
          dragSrc = null;
        });

        document.getElementById("sections-save").addEventListener("click", async () => {
          syncFromDom();
          status.textContent = "Zapisuję…";
          status.style.color = "var(--c-text-muted)";
          try {
            const res = await fetch("/api/settings/save", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ kind: "sections", sections }),
            });
            const j = await res.json();
            if (j.ok) {
              status.textContent = "✓ Zapisane (rebuild w toku ~2 min)";
              status.style.color = "#16a34a";
            } else {
              status.textContent = "Błąd: " + (j.error || "unknown");
              status.style.color = "#dc2626";
            }
          } catch (err) {
            status.textContent = "Network error: " + err;
            status.style.color = "#dc2626";
          }
        });

        render();
      })();
    </script>
  </section>

  {/* Logo firmy */}
  <section class="card" style="margin-bottom: 1.5rem;">
    <h2 style="font-size: 1.1rem; font-weight: 700; margin: 0 0 1rem 0;">Logo firmy</h2>
    {curLogoUrl ? (
      <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1rem;">
        <img src={curLogoUrl} alt="Aktualne logo" style="max-height: 80px; max-width: 200px; border: 1px solid var(--c-border); padding: 0.5rem; background: #fff; border-radius: 6px;" />
        <span style="color: var(--c-text-muted); font-size: 0.85rem;">Aktualne logo</span>
      </div>
    ) : (
      <p style="margin: 0 0 1rem 0; color: var(--c-text-muted); font-size: 0.85rem;">Brak loga — wgraj plik aby pojawił się w nagłówku strony.</p>
    )}
    <form id="logo-form" enctype="multipart/form-data" style="display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
      <input type="file" name="logo" accept="image/png,image/jpeg,image/svg+xml,image/webp" required style="font-size: 0.9rem;" />
      <button type="submit" class="btn btn-primary">Wgraj logo</button>
      <span style="color: var(--c-text-muted); font-size: 0.78rem;">PNG / JPG / SVG / WebP, max 500 KB. Zalecane: SVG przezroczyste tło, 200×80 px.</span>
    </form>
    <script is:inline>
      (function () {
        const form = document.getElementById("logo-form");
        if (!form) return;
        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          const btn = form.querySelector("button[type=submit]");
          const orig = btn.textContent;
          btn.disabled = true;
          btn.textContent = "Wgrywam…";
          try {
            const res = await fetch("/api/settings/logo-upload", { method: "POST", body: new FormData(form) });
            const j = await res.json();
            if (j.ok) {
              btn.textContent = "Wgrane ✓ (rebuild w toku)";
              setTimeout(() => location.reload(), 1500);
            } else { alert("Błąd: " + (j.error || "unknown")); btn.disabled = false; btn.textContent = orig; }
          } catch (err) { alert("Network: " + err); btn.disabled = false; btn.textContent = orig; }
        });
      })();
    </script>
  </section>

  {/* Wygląd strony — theme picker + brand color */}
  <section class="card" style="margin-bottom: 1.5rem;">
    <h2 style="font-size: 1.1rem; font-weight: 700; margin: 0 0 1rem 0;">Wygląd strony</h2>
    <p style="margin: 0 0 1rem 0; color: var(--c-text-muted); font-size: 0.85rem;">
      Wybierz styl, paletę kolorów i opcjonalnie nadpisz kolor swojej firmy. Po zapisie strona przebudowuje się w ~2 min.
    </p>

    {/* Visual palette picker — 12 mini-previews */}
    <details open style="margin-bottom: 1.25rem;">
      <summary style="cursor: pointer; font-weight: 600; font-size: 0.9rem; color: var(--c-text); margin-bottom: 0.75rem;">
        Podgląd palet ({Object.keys(PALETTES).reduce((sum, p) => sum + Object.keys(PALETTES[p as PreviewStyle]).length, 0)} dostępnych)
      </summary>
      <div style="display: flex; flex-direction: column; gap: 1.25rem;">
        {(Object.keys(PALETTES) as PreviewStyle[]).map((style) => (
          <div>
            <h3 style="font-size: 0.9rem; font-weight: 700; margin: 0 0 0.5rem 0; color: var(--c-text);">
              {style === "minimalist" ? "Czysty" : style === "elegant" ? "Elegancki" : style === "dynamic" ? "Dynamiczny" : "Magazynowy"}
            </h3>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.75rem;">
              {Object.entries(PALETTES[style]).map(([slug, palette]) => {
                const isCurrent = curPreset === style && curVariant === slug;
                return (
                  <button
                    type="button"
                    class={`palette-btn ${isCurrent ? "is-current" : ""}`}
                    data-palette-pick
                    data-preset={style}
                    data-variant={slug}
                    aria-label={`Wybierz: ${palette.label}`}
                    style={`background: transparent; border: 2px solid ${isCurrent ? "var(--c-brand)" : "var(--c-border)"}; border-radius: 10px; padding: 0; cursor: pointer; overflow: hidden; transition: transform 150ms, border-color 150ms; display: block;`}
                  >
                    <Fragment set:html={previewSvg(style, palette.light, palette.label)} />
                    <div style="padding: 0.5rem 0.6rem; text-align: left; background: var(--c-surface);">
                      <div style="font-size: 0.8rem; font-weight: 600; color: var(--c-text);">{palette.label}</div>
                      <div style="display: flex; gap: 0.25rem; margin-top: 0.3rem;">
                        <span style={`width: 16px; height: 16px; border-radius: 50%; background: ${palette.light.brand}; border: 1px solid var(--c-border);`}></span>
                        <span style={`width: 16px; height: 16px; border-radius: 50%; background: ${palette.light.accent}; border: 1px solid var(--c-border);`}></span>
                        <span style={`width: 16px; height: 16px; border-radius: 50%; background: ${palette.light.surface}; border: 1px solid var(--c-border);`}></span>
                        <span style={`width: 16px; height: 16px; border-radius: 50%; background: ${palette.light.text}; border: 1px solid var(--c-border);`}></span>
                      </div>
                    </div>
                  </button>
                );
              })}
            </div>
          </div>
        ))}
      </div>
      <p style="margin: 0.75rem 0 0 0; color: var(--c-text-muted); font-size: 0.78rem;">
        Kliknij dowolną paletę aby ją wybrać. Możesz potem nadpisać kolory własnymi (HEX picker poniżej).
      </p>
    </details>
    <script is:inline>
      document.addEventListener("click", (e) => {
        const btn = e.target.closest("[data-palette-pick]");
        if (!btn) return;
        e.preventDefault();
        const preset = btn.dataset.preset;
        const variant = btn.dataset.variant;
        const presetEl = document.getElementById("t-preset");
        const variantEl = document.getElementById("t-variant");
        if (presetEl && presetEl.value !== preset) {
          presetEl.value = preset;
          presetEl.dispatchEvent(new Event("change"));
        }
        // Wait next tick for variant options to render then set
        setTimeout(() => {
          if (variantEl) variantEl.value = variant;
          // Visual indicator
          document.querySelectorAll("[data-palette-pick]").forEach((b) => {
            b.classList.toggle("is-current", b === btn);
            b.style.borderColor = b === btn ? "var(--c-brand)" : "var(--c-border)";
          });
        }, 30);
      });
    </script>
    <form id="theme-form" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <label style="font-size: 0.9rem;">
        Styl strony
        <select name="preset" id="t-preset" required style="display: block; margin-top: 0.3rem; width: 100%; padding: 0.5rem; border: 1px solid var(--c-border); border-radius: 6px;">
          <option value="minimalist" selected={curPreset === "minimalist"}>Czysty — minimalistyczny, profesjonalny (prawnik, lekarz, IT)</option>
          <option value="elegant" selected={curPreset === "elegant"}>Elegancki — premium, atmosfera (SPA, fryzjer, fotograf)</option>
          <option value="dynamic" selected={curPreset === "dynamic"}>Dynamiczny — konwersyjny, "zadzwoń teraz" (ślusarz, kurier, fast-food)</option>
          <option value="editorial" selected={curPreset === "editorial"}>Magazynowy — narracyjny, historia firmy (restauracja, hotel, marka osobista)</option>
        </select>
      </label>

      <label style="font-size: 0.9rem;">
        Wariant kolorystyczny
        <select name="variant" id="t-variant" required style="display: block; margin-top: 0.3rem; width: 100%; padding: 0.5rem; border: 1px solid var(--c-border); border-radius: 6px;">
        </select>
      </label>

      <label style="font-size: 0.9rem;">
        Layout hero
        <select name="heroVariant" style="display: block; margin-top: 0.3rem; width: 100%; padding: 0.5rem; border: 1px solid var(--c-border); border-radius: 6px;">
          <option value="" selected={!curHero}>— domyślny dla stylu —</option>
          <option value="centered" selected={curHero === "centered"}>Wyśrodkowany</option>
          <option value="split" selected={curHero === "split"}>Split (tekst + zdjęcie)</option>
          <option value="image-bg" selected={curHero === "image-bg"}>Zdjęcie w tle</option>
          <option value="asymmetric" selected={curHero === "asymmetric"}>Asymetryczny (magazyn)</option>
        </select>
      </label>

      <label style="font-size: 0.9rem;">
        Tryb (jasny / ciemny)
        <select name="mode" id="t-mode" style="display: block; margin-top: 0.3rem; width: 100%; padding: 0.5rem; border: 1px solid var(--c-border); border-radius: 6px;">
          <option value="auto" selected={themeCfg.mode === "auto" || !themeCfg.mode}>Auto (zgodnie z systemem użytkownika)</option>
          <option value="light" selected={themeCfg.mode === "light"}>Tylko jasny</option>
          <option value="dark" selected={themeCfg.mode === "dark"}>Tylko ciemny</option>
        </select>
      </label>

      <label style="font-size: 0.9rem;">
        Para fontów
        <select name="fontPairIdx" id="t-font-pair" style="display: block; margin-top: 0.3rem; width: 100%; padding: 0.5rem; border: 1px solid var(--c-border); border-radius: 6px;">
          {/* Opcje renderowane w runtime przez script (per styl różne) */}
        </select>
      </label>

      <label style="font-size: 0.9rem;">
        Akcent buttonów
        <select name="accent" style="display: block; margin-top: 0.3rem; width: 100%; padding: 0.5rem; border: 1px solid var(--c-border); border-radius: 6px;">
          <option value="" selected={!curAccent}>— domyślny dla motywu —</option>
          <option value="bold" selected={curAccent === "bold"}>Bold (mocny)</option>
          <option value="soft" selected={curAccent === "soft"}>Soft (pastelowy)</option>
          <option value="outline" selected={curAccent === "outline"}>Outline (obramowany)</option>
        </select>
      </label>

      <label style="font-size: 0.9rem; grid-column: 1 / -1;">
        Kolor firmowy (opcjonalnie — nadpisuje paletę)
        <div style="display: flex; gap: 0.5rem; margin-top: 0.3rem; align-items: center;">
          <input type="color" name="brandColor" id="t-brand-color" value={curBrandColor || "#c0392b"} style="width: 60px; height: 40px; border: 1px solid var(--c-border); border-radius: 6px; cursor: pointer;" />
          <input type="text" name="brandColorHex" id="t-brand-hex" value={curBrandColor} placeholder="#c0392b lub pusto = paleta motywu" pattern="^#[0-9a-fA-F]{6}$" style="flex: 1; padding: 0.5rem; border: 1px solid var(--c-border); border-radius: 6px; font-family: ui-monospace, monospace;" />
          <button type="button" id="t-brand-clear" style="padding: 0.4rem 0.75rem; background: transparent; color: var(--c-text-muted); border: 1px solid var(--c-border); border-radius: 6px; cursor: pointer; font-size: 0.85rem;">Reset</button>
        </div>
      </label>

      <label style="font-size: 0.9rem; grid-column: 1 / -1;">
        Kolor akcentu (opcjonalnie)
        <div style="display: flex; gap: 0.5rem; margin-top: 0.3rem; align-items: center;">
          <input type="color" name="accentColor" id="t-accent-color" value={curAccentColor || "#f39c12"} style="width: 60px; height: 40px; border: 1px solid var(--c-border); border-radius: 6px; cursor: pointer;" />
          <input type="text" name="accentColorHex" id="t-accent-hex" value={curAccentColor} placeholder="#f39c12 lub pusto = paleta motywu" pattern="^#[0-9a-fA-F]{6}$" style="flex: 1; padding: 0.5rem; border: 1px solid var(--c-border); border-radius: 6px; font-family: ui-monospace, monospace;" />
          <button type="button" id="t-accent-clear" style="padding: 0.4rem 0.75rem; background: transparent; color: var(--c-text-muted); border: 1px solid var(--c-border); border-radius: 6px; cursor: pointer; font-size: 0.85rem;">Reset</button>
        </div>
      </label>

      <div style="grid-column: 1 / -1; display: flex; gap: 0.5rem; align-items: center;">
        <button type="submit" class="btn btn-primary">Zapisz + odśwież stronę</button>
        <span style="color: var(--c-text-muted); font-size: 0.78rem;">
          ⚠️ Po zmianie motywu strona zostanie przebudowana (~2 min). Klienci w trakcie mogą zobaczyć starą wersję.
        </span>
      </div>
    </form>

    <script is:inline define:vars={{ curVariant, curFontPairIdx: themeCfg.fontPairIdx ?? 0 }}>
      (function () {
        const VARIANTS = {
          minimalist: [["mono-blue", "Granat + biel + orange"], ["mono-black", "Czerń + biel + żółty"], ["mono-emerald", "Zieleń + krem + złoto"]],
          elegant: [["rose-cream", "Pudrowy róż + krem"], ["sage-ivory", "Szałwia + kość słoniowa"], ["mocha-blush", "Mocha + bronze"]],
          dynamic: [["red-action", "Czerwień + biel + żółty"], ["electric-blue", "Electric + magenta"], ["neon-noir", "Cyan + czerń (dark)"]],
          editorial: [["forest-amber", "Las + bursztyn"], ["slate-rose", "Łupek + róż"], ["cream-cobalt", "Krem + kobalt"]],
        };
        const FONT_PAIRS = {
          minimalist: ["Inter (domyślnie)", "Geist + Geist Mono (tech)", "Manrope + JetBrains Mono (warmer)"],
          elegant: ["Playfair + Lora (domyślnie)", "Cormorant Garamond + Source Sans", "Fraunces + Inter"],
          dynamic: ["Barlow Condensed + Inter (domyślnie)", "Archivo Black + Archivo", "Anton + Manrope"],
          editorial: ["Fraunces + IBM Plex Sans (domyślnie)", "Crimson Pro + Inter", "Cormorant Garamond + Inter"],
        };
        const preset = document.getElementById("t-preset");
        const variant = document.getElementById("t-variant");
        const fontPair = document.getElementById("t-font-pair");

        function renderFontPairs(p) {
          const opts = FONT_PAIRS[p] || [];
          fontPair.innerHTML = opts.map((label, i) => `<option value="${i}"${i === curFontPairIdx ? " selected" : ""}>${label}</option>`).join("");
        }
        renderFontPairs(preset.value);
        const brandColor = document.getElementById("t-brand-color");
        const brandHex = document.getElementById("t-brand-hex");
        const brandClear = document.getElementById("t-brand-clear");
        const accentColor = document.getElementById("t-accent-color");
        const accentHex = document.getElementById("t-accent-hex");
        const accentClear = document.getElementById("t-accent-clear");

        function renderVariants(p, selected) {
          variant.innerHTML = (VARIANTS[p] || []).map(([v, l]) => `<option value="${v}"${v === selected ? " selected" : ""}>${l}</option>`).join("");
        }
        renderVariants(preset.value, curVariant);
        preset.addEventListener("change", () => {
          renderVariants(preset.value, "");
          renderFontPairs(preset.value);
        });

        // Sync color picker ↔ hex input
        brandColor.addEventListener("input", () => { brandHex.value = brandColor.value; });
        brandHex.addEventListener("input", () => {
          if (/^#[0-9a-fA-F]{6}$/.test(brandHex.value)) brandColor.value = brandHex.value;
        });
        brandClear.addEventListener("click", () => { brandHex.value = ""; });

        accentColor.addEventListener("input", () => { accentHex.value = accentColor.value; });
        accentHex.addEventListener("input", () => {
          if (/^#[0-9a-fA-F]{6}$/.test(accentHex.value)) accentColor.value = accentHex.value;
        });
        accentClear.addEventListener("click", () => { accentHex.value = ""; });

        const form = document.getElementById("theme-form");
        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          const btn = form.querySelector("button[type=submit]");
          const orig = btn.textContent;
          btn.disabled = true;
          btn.textContent = "Zapisuję…";
          const body = {
            kind: "theme",
            preset: preset.value,
            variant: variant.value,
            heroVariant: form.elements.heroVariant.value || undefined,
            accent: form.elements.accent.value || undefined,
            brandColor: brandHex.value.trim() || undefined,
            accentColor: accentHex.value.trim() || undefined,
            mode: form.elements.mode.value || "auto",
            fontPairIdx: parseInt(fontPair.value, 10) || 0,
          };
          try {
            const res = await fetch("/api/settings/save", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(body),
            });
            const j = await res.json();
            if (j.ok) {
              btn.textContent = "Zapisane ✓ (rebuild w toku)";
              setTimeout(() => { btn.disabled = false; btn.textContent = orig; }, 2000);
            } else { alert("Błąd: " + (j.error || "unknown")); btn.disabled = false; btn.textContent = orig; }
          } catch (err) { alert("Network: " + err); btn.disabled = false; btn.textContent = orig; }
        });
      })();
    </script>
  </section>

  <details class="card">
    <summary style="cursor: pointer; font-weight: 600; display: flex; align-items: center; gap: 0.4rem;">
      <Icon name="info" size={16} /> Co jeszcze możesz edytować?
    </summary>
    <ul style="margin-top: 1rem; padding-left: 1.5rem; color: var(--c-text-muted); font-size: 0.9rem; line-height: 1.7;">
      <li>Treści blogowe i FAQ — przez <strong>Sveltia CMS</strong> na <code>twojadomena.pl/admin/</code></li>
      <li>Dodatki (chatbot, FOMO, opinie, etc.) — przez <a href="/addons" style="color: var(--c-brand);">/addons</a></li>
      <li>Integracje (Wolt, NFC, Instagram, Booksy) — przez <a href="/integrations" style="color: var(--c-brand);">/integrations</a></li>
      <li>Zmiana branży / nazwy firmy / NIP — wymaga kontaktu z agencją (info@mixturemarketing.pl)</li>
      <li>Logo firmy — sekcja "Logo" niżej na tej stronie (upload PNG/SVG, automatyczne podłączenie)</li>
    </ul>
  </details>

  <script is:inline>
    async function saveSettings(form, kind, fields) {
      const btn = form.querySelector("button[type=submit]");
      const orig = btn.textContent;
      btn.disabled = true;
      btn.textContent = "Zapisuję…";
      const data = new FormData(form);
      const body = { kind };
      if (kind === "hours") {
        body.hours = {};
        for (const f of fields) {
          const v = String(data.get(f) || "").trim();
          if (v) body.hours[f] = v;
        }
      } else {
        for (const f of fields) body[f] = String(data.get(f) || "");
      }
      try {
        const res = await fetch("/api/settings/save", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        const json = await res.json();
        if (json.ok) {
          btn.textContent = "Zapisane ✓";
          setTimeout(() => { btn.disabled = false; btn.textContent = orig; }, 1500);
        } else { alert("Błąd: " + (json.error || "unknown")); btn.disabled = false; btn.textContent = orig; }
      } catch (e) { alert("Network: " + e); btn.disabled = false; btn.textContent = orig; }
    }
    const cf = document.getElementById("contact-form");
    if (cf) cf.addEventListener("submit", (e) => { e.preventDefault(); saveSettings(cf, "contact", ["phone"]); });
    const hf = document.getElementById("hero-form");
    if (hf) hf.addEventListener("submit", (e) => { e.preventDefault(); saveSettings(hf, "hero", ["tagline", "description"]); });
    const hr = document.getElementById("hours-form");
    if (hr) hr.addEventListener("submit", (e) => { e.preventDefault(); saveSettings(hr, "hours", ["monday","tuesday","wednesday","thursday","friday","saturday","sunday"]); });
  </script>
</PanelLayout>
