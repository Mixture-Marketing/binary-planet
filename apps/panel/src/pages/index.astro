---
import { env } from "cloudflare:workers";
import PanelLayout from "../layouts/PanelLayout.astro";
import Icon from "../components/Icon.astro";
import { getDashboardStats, listLeads } from "../lib/db.ts";

const client = Astro.locals.client;
if (!env?.DB || !client) return new Response("Runtime not ready", { status: 500 });

const stats = await getDashboardStats(env.DB, client.id);
const recentLeads = await listLeads(env.DB, client.id, { limit: 5 });

// Fetch klient site URL — primary_domain (custom) or preview_domain (workers.dev fallback)
const siteRow = await env.DB
  .prepare(`SELECT primary_domain, preview_domain FROM clients WHERE id = ? LIMIT 1`)
  .bind(client.id)
  .first<{ primary_domain: string | null; preview_domain: string | null }>();
const siteUrl = siteRow?.primary_domain
  ? `https://${siteRow.primary_domain}`
  : siteRow?.preview_domain
    ? `https://${siteRow.preview_domain}`
    : null;
const isPreviewOnly = !siteRow?.primary_domain && !!siteRow?.preview_domain;

// Provisioning status — show banner when site is being built or pending wizard
interface ProvRow {
  provisioning_status: string;
  provisioning_started_at: string | null;
  provisioning_finished_at: string | null;
  provisioning_error: string | null;
  steps_json: string | null;
}
const provRow = await env.DB
  .prepare(
    `SELECT provisioning_status, provisioning_started_at, provisioning_finished_at,
            provisioning_error, steps_json
       FROM client_provisioning_configs WHERE client_id = ? LIMIT 1`,
  )
  .bind(client.id)
  .first<ProvRow>();

const PROV_STATUS_LABELS: Record<string, { label: string; tone: "info" | "success" | "warn" | "error" }> = {
  pending: { label: "W kolejce — start automatyczny co 2 min", tone: "info" },
  running: { label: "W trakcie budowy strony...", tone: "info" },
  waiting_domain: { label: "Czekamy na rejestrację domeny w OVH", tone: "warn" },
  done: { label: "Strona gotowa", tone: "success" },
  failed: { label: "Błąd provisioningu — skontaktuj się z agencją", tone: "error" },
};
const provInfo = provRow ? PROV_STATUS_LABELS[provRow.provisioning_status] : null;
const provSteps = provRow?.steps_json ? (() => {
  try { return JSON.parse(provRow.steps_json) as Array<{ step: string; ok: boolean; message?: string; dry_run?: boolean }>; } catch { return null; }
})() : null;
// Detect DRY-RUN: hub's PROVISIONING_DRY_RUN=true (default) marks every step as dry_run.
// In that case the provisioning_status flips to "done" but NOTHING was actually deployed.
// Show explicit warning so klient doesn't think their site is live.
const isDryRun = provSteps !== null && provSteps.length > 0 && provSteps.every((s) => s.dry_run === true);
const provStarted = provRow?.provisioning_started_at ? new Date(provRow.provisioning_started_at) : null;
const provDurationMs = provStarted && provRow?.provisioning_finished_at
  ? new Date(provRow.provisioning_finished_at).getTime() - provStarted.getTime()
  : provStarted ? Date.now() - provStarted.getTime() : null;
const fmtDur = (ms: number): string => {
  const min = Math.floor(ms / 60000);
  if (min < 1) return "<1 min";
  if (min < 60) return `${min} min`;
  return `${Math.floor(min / 60)}h ${min % 60}min`;
};

// Tones → colors
const TONE_STYLES: Record<string, string> = {
  info: "background: #dbeafe; border-color: #93c5fd; color: #1e3a8a;",
  success: "background: #d1fae5; border-color: #6ee7b7; color: #065f46;",
  warn: "background: #fef3c7; border-color: #fcd34d; color: #78350f;",
  error: "background: #fee2e2; border-color: #fca5a5; color: #991b1b;",
};

const formatRelative = (iso: string): string => {
  const ms = Date.now() - new Date(iso).getTime();
  const min = Math.floor(ms / 60000);
  if (min < 60) return `${min} min temu`;
  const hr = Math.floor(min / 60);
  if (hr < 24) return `${hr} h temu`;
  return `${Math.floor(hr / 24)} d temu`;
};

const formatPln = (n: number): string => `${n.toLocaleString("pl-PL")} zł`;

const STAT_CARDS: Array<{ label: string; value: string | number; icon: Parameters<typeof Icon>[0]["name"] }> = [
  { label: "Leady dzisiaj", value: stats.leadsToday, icon: "inbox" },
  { label: "Leady (7 dni)", value: stats.leadsThisWeek, icon: "layout-dashboard" },
  { label: "Leady (30 dni)", value: stats.leadsThisMonth, icon: "clipboard-list" },
  { label: "Hot leads", value: stats.hotLeads, icon: "flame" },
  { label: "Wygrane (won)", value: stats.wonLeads, icon: "check-circle-2" },
  { label: "Przychód z won", value: formatPln(stats.estimatedRevenuePln), icon: "target" },
];
---

<PanelLayout title="Dashboard">
  <header style="margin-bottom: 2rem; display: flex; gap: 1rem; align-items: start; justify-content: space-between; flex-wrap: wrap;">
    <div>
      <h1 style="font-size: 2rem; font-weight: 800; margin: 0 0 0.5rem 0;">Witaj, {client?.businessName ?? ""}</h1>
      <p style="margin: 0; color: var(--c-text-muted);">
        Stan na {new Date().toLocaleDateString("pl-PL", { weekday: "long", day: "numeric", month: "long" })}.
      </p>
    </div>
    {siteUrl && (
      <a
        href={siteUrl}
        target="_blank"
        rel="noopener"
        class="card"
        style={`text-decoration: none; padding: 0.85rem 1.1rem; display: flex; align-items: center; gap: 0.7rem; ${isPreviewOnly ? "background: #fef3c7; border-color: #fcd34d;" : "background: var(--c-surface); border-color: var(--c-brand);"}; transition: transform 150ms;`}
      >
        <div>
          <p style="margin: 0; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--c-text-muted); font-weight: 600;">
            {isPreviewOnly ? "Podgląd na workers.dev" : "Twoja strona"}
          </p>
          <p style={`margin: 0.15rem 0 0 0; font-weight: 600; font-size: 0.95rem; color: ${isPreviewOnly ? "#78350f" : "var(--c-brand)"};`}>
            {siteRow?.primary_domain || siteRow?.preview_domain}
            <span style="margin-left: 0.4rem; opacity: 0.7;">↗</span>
          </p>
        </div>
      </a>
    )}
  </header>

  {siteUrl && isPreviewOnly && (
    <section style="border: 1px solid #fcd34d; background: #fffbeb; border-radius: 0.75rem; padding: 1rem 1.25rem; margin-bottom: 1.5rem; font-size: 0.92rem; color: #78350f;">
      <strong>Tymczasowy adres workers.dev.</strong> Aby uruchomić własną domenę (np. twojafirma.pl) i ustawić tytuł w Google, wejdź w
      <a href="/ustawienia#domena" style="color: inherit; text-decoration: underline; font-weight: 600;"> Ustawienia → Domena</a>.
    </section>
  )}

  {provInfo && (
    <section
      role="status"
      aria-live="polite"
      style={`border: 1px solid; border-radius: 0.75rem; padding: 1.25rem 1.5rem; margin-bottom: 2rem; ${isDryRun ? TONE_STYLES.warn : (TONE_STYLES[provInfo.tone] ?? "")}`}
    >
      <div style="display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;">
        <div style="display: flex; align-items: center; gap: 0.75rem; flex: 1; min-width: 0;">
          {isDryRun ? <Icon name="alert-triangle" size={22} /> : provInfo.tone === "info" && <Icon name="rocket" size={22} />}
          {!isDryRun && provInfo.tone === "warn" && <Icon name="info" size={22} />}
          {!isDryRun && provInfo.tone === "success" && <Icon name="check-circle-2" size={22} />}
          {!isDryRun && provInfo.tone === "error" && <Icon name="alert-triangle" size={22} />}
          <div>
            <p style="margin: 0; font-weight: 700; font-size: 1.05rem;">
              {isDryRun
                ? "Tryb testowy (DRY-RUN) — strona NIE została jeszcze wdrożona"
                : `Twoja strona — ${provInfo.label}`}
            </p>
            {isDryRun && (
              <p style="margin: 0.25rem 0 0 0; font-size: 0.85rem; opacity: 0.85;">
                Pipeline przebiegł w trybie symulacji (PROVISIONING_DRY_RUN=true). Aby uruchomić
                realny provisioning agencja musi ustawić ten flag w sekretach hub'a + zresetować
                Twój status do <code>pending</code>.
              </p>
            )}
            {provDurationMs !== null && (
              <p style="margin: 0.25rem 0 0 0; font-size: 0.85rem; opacity: 0.85;">
                {provRow?.provisioning_status === "done"
                  ? `Zakończono w ${fmtDur(provDurationMs)}`
                  : `Trwa od ${fmtDur(provDurationMs)}`}
              </p>
            )}
            {provRow?.provisioning_status === "failed" && provRow.provisioning_error && (
              <p style="margin: 0.25rem 0 0 0; font-size: 0.85rem; opacity: 0.85;">
                Szczegóły: {provRow.provisioning_error}
              </p>
            )}
          </div>
        </div>
        {provSteps && provSteps.length > 0 && (
          <details style="font-size: 0.85rem;">
            <summary style="cursor: pointer; font-weight: 600;">
              {provSteps.filter((s) => s.ok).length}/{provSteps.length} kroków
            </summary>
            <ul style="margin: 0.75rem 0 0 0; padding-left: 1.25rem; line-height: 1.6;">
              {provSteps.map((s) => (
                <li>{s.ok ? "✓" : "✗"} {s.step.replace(/_/g, " ")}{s.message ? ` — ${s.message}` : ""}</li>
              ))}
            </ul>
          </details>
        )}
      </div>
    </section>
  )}

  {!provInfo && client?.status === "pending" && (
    <section
      role="status"
      aria-live="polite"
      style={`border: 1px solid; border-radius: 0.75rem; padding: 1.25rem 1.5rem; margin-bottom: 2rem; ${TONE_STYLES.warn}`}
    >
      <div style="display: flex; align-items: center; gap: 0.75rem;">
        <Icon name="clipboard-list" size={22} />
        <div>
          <p style="margin: 0; font-weight: 700; font-size: 1.05rem;">Wypełnij wizard onboardingu</p>
          <p style="margin: 0.25rem 0 0 0; font-size: 0.9rem;">
            <a href="/onboarding" style="color: inherit; text-decoration: underline; font-weight: 600;">
              Otwórz wizard →
            </a>
            {" "}żeby ruszyć z budową strony. Bez wypełnienia nic się nie dzieje.
          </p>
        </div>
      </div>
    </section>
  )}

  <section style="display: grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); margin-bottom: 2.5rem;">
    {STAT_CARDS.map((s) => (
      <article class="card" style="display: flex; flex-direction: column; gap: 0.5rem;">
        <div style="display: flex; align-items: center; gap: 0.5rem; color: var(--c-text-muted);">
          <Icon name={s.icon} size={18} />
          <p style="margin: 0; font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;">{s.label}</p>
        </div>
        <p style="margin: 0; font-size: 1.75rem; font-weight: 800; line-height: 1.1;">{s.value}</p>
      </article>
    ))}
  </section>

  <section style="margin-bottom: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1rem;">
      <h2 style="font-size: 1.2rem; font-weight: 700; margin: 0;">Najnowsze leady</h2>
      <a href="/leady" style="font-size: 0.9rem; color: var(--c-brand); font-weight: 600;">Wszystkie →</a>
    </div>
    <div class="card" style="padding: 0;">
      {recentLeads.length === 0 ? (
        <p style="padding: 2rem; text-align: center; color: var(--c-text-muted); margin: 0;">
          Brak leadów. Pojawią się tutaj, gdy klienci końcowi wypełnią formularz na Twojej stronie.
        </p>
      ) : (
        <table class="table">
          <thead>
            <tr>
              <th>Źródło</th>
              <th>Usługa</th>
              <th>Wycena</th>
              <th>Status</th>
              <th>Kiedy</th>
            </tr>
          </thead>
          <tbody>
            {recentLeads.map((lead) => (
              <tr>
                <td style="font-size: 0.85rem;">{lead.source}</td>
                <td>{lead.service_interest ?? "—"}</td>
                <td>{lead.estimated_value_pln ? formatPln(lead.estimated_value_pln) : "—"}</td>
                <td>
                  <span class={`badge ${lead.status === "new" ? "badge-warning" : lead.status === "won" ? "badge-success" : ""}`}>{lead.status}</span>
                  {lead.is_hot === 1 && <span class="badge badge-danger" style="margin-left: 0.25rem; display: inline-flex; align-items: center; gap: 0.25rem;"><Icon name="flame" size={12} /> hot</span>}
                </td>
                <td style="color: var(--c-text-muted); font-size: 0.85rem;">{formatRelative(lead.created_at)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>
  </section>
</PanelLayout>
