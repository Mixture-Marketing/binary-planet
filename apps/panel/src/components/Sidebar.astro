---
import Icon from "./Icon.astro";
import type { IconName } from "@mixturemarketing/web-core/ui";

interface Props {
  client: {
    id: string;
    businessName: string;
    tier: string;
  };
  activeAddons?: string[];
}

const { client, activeAddons = [] } = Astro.props;
const currentPath = Astro.url.pathname;
const hasAddon = (slug: string): boolean => activeAddons.includes(slug);

type NavItem = { href: string; label: string; icon: IconName; show?: boolean };
const navItems: NavItem[] = [
  { href: "/", label: "Dashboard", icon: "layout-dashboard" },
  { href: "/leady", label: "Leady", icon: "inbox" },
  { href: "/faktury", label: "Faktury", icon: "file-text" },
  { href: "/raporty", label: "Raporty", icon: "clipboard-list" },
  { href: "/integrations", label: "Integracje", icon: "package", show: hasAddon("wolt_glovo") || hasAddon("nfc_stand") },
  { href: "/instagram", label: "Instagram", icon: "external-link", show: hasAddon("instagram_sync") },
  { href: "/competitor-monitoring", label: "Konkurencja", icon: "target", show: hasAddon("competitor_monitoring") },
  { href: "/addons", label: "Dodatki", icon: "plus" },
  { href: "/ustawienia", label: "Ustawienia", icon: "settings" },
  { href: "/rodo", label: "RODO", icon: "shield-check" },
].filter((it) => it.show !== false);

const isActive = (href: string): boolean => {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
};
---

<aside
  role="navigation"
  aria-label="Główna nawigacja"
  style="background: var(--c-surface); border-right: 1px solid var(--c-border); padding: 1.5rem 1rem; display: flex; flex-direction: column; gap: 1.5rem; position: sticky; top: 0; height: 100vh; overflow-y: auto;"
>
  <div>
    <h1 style="font-size: 1.05rem; font-weight: 700; margin: 0 0 0.25rem 0;">{client.businessName}</h1>
    <p style="font-size: 0.75rem; color: var(--c-text-muted); margin: 0;">Panel klienta · MixtureMarketing</p>
    <p style="margin-top: 0.5rem;"><span class="badge badge-brand">{client.tier}</span></p>
  </div>

  <nav style="flex: 1;">
    <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.25rem;">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            style={`
              display: flex;
              align-items: center;
              gap: 0.625rem;
              padding: 0.625rem 0.875rem;
              border-radius: 0.5rem;
              color: var(--c-text);
              text-decoration: none;
              font-weight: 500;
              font-size: 0.9rem;
              ${isActive(item.href) ? "background: var(--c-brand); color: var(--c-brand-fg);" : ""}
            `}
          >
            <Icon name={item.icon} size={18} />
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div style="padding-top: 1rem; border-top: 1px solid var(--c-border);">
    <p style="font-size: 0.75rem; color: var(--c-text-muted); margin: 0 0 0.5rem 0;">Klient ID</p>
    <p style="font-family: ui-monospace, monospace; font-size: 0.75rem; word-break: break-all; margin: 0 0 0.75rem 0;">{client.id}</p>
    <form method="POST" action="/api/auth/logout">
      <button type="submit" class="btn" style="width: 100%; font-size: 0.85rem; padding: 0.4rem 0.75rem; min-height: 32px; gap: 0.4rem;">
        <Icon name="log-out" size={14} />
        Wyloguj
      </button>
    </form>
  </div>
</aside>
