# Cloudflare Workers Assets — _headers file mapping
# https://developers.cloudflare.com/workers/static-assets/headers/

# Astro builds hashed filenames for /_astro/* — safe for immutable caching
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts — same hashed-content treatment
/cf-fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Favicon + logos — slightly shorter to allow updates
/favicon.svg
  Cache-Control: public, max-age=86400

# Robots / sitemap / llms — short cache, updated infrequently
/robots.txt
  Cache-Control: public, max-age=3600
/sitemap.xml
  Cache-Control: public, max-age=3600
/llms.txt
  Cache-Control: public, max-age=3600
