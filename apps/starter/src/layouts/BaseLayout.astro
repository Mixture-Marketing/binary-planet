---
import "../styles/globals.css";

import {
  consentBannerCss,
  consentBannerHtml,
  defaultConsentScriptTag,
  preferencesModalCss,
  preferencesModalHtml,
} from "@mixturemarketing/web-core/consent";
import {
  BREADCRUMB_CSS,
  focusVisibleStyles,
  skipLink,
  VISUALLY_HIDDEN_CSS,
} from "@mixturemarketing/web-core/a11y";
import { buildMetaTags, type MetaInput } from "@mixturemarketing/web-core/seo";
import { buildChatWidgetHtml } from "@mixturemarketing/web-core/chatbot";

import clientConfig from "../client.config.ts";
import { tokensCss } from "../themes/craftsman/tokens.ts";

interface Props {
  meta: MetaInput;
  jsonLd?: unknown[];
}

const { meta, jsonLd = [] } = Astro.props;
const nonce = Astro.locals.nonce ?? "";
const tokens = tokensCss(clientConfig.theme.variant);
const plausibleEnabled = clientConfig.integrations.plausible;

// Track 24f — Chatbot widget (rendered server-side, runs only when CHATBOT_ENABLED=true env)
const chatbotEnabled = String((Astro.locals.runtime?.env as { CHATBOT_ENABLED?: string } | undefined)?.CHATBOT_ENABLED ?? "").toLowerCase() === "true";
const chatWidgetHtml = chatbotEnabled
  ? buildChatWidgetHtml({
      apiPath: "/api/chat",
      brandColor: "var(--c-brand, #047857)",
      introMessage: `Cześć! Jestem asystentem ${clientConfig.business.name}. W czym mogę pomóc?`,
      businessName: clientConfig.business.name,
    })
  : "";

// SEO: build meta tags from input. dev: log warnings.
const { tags, warnings } = buildMetaTags(meta);
if (import.meta.env.DEV && warnings.length > 0) {
  for (const w of warnings) console.warn(`[SEO] ${w.field}: ${w.message}`);
}

// A11y components — render once globally
const sl = skipLink({ targetId: "main" });

// Consent — banner + modal
const banner = consentBannerHtml({
  businessName: clientConfig.business.name,
  privacyUrl: clientConfig.rodo.privacyPolicyUrl ?? "/polityka-prywatnosci",
  ...(clientConfig.rodo.termsUrl && { termsUrl: clientConfig.rodo.termsUrl }),
  version: clientConfig.rodo.consentVersion,
});
const modal = preferencesModalHtml();

// Combined global CSS
const globalCss = [
  VISUALLY_HIDDEN_CSS,
  focusVisibleStyles({ outlineColor: "var(--color-brand)" }),
  sl.css,
  BREADCRUMB_CSS,
  consentBannerCss(),
  preferencesModalCss(),
].join("\n");
---

<!doctype html>
<html lang="pl">
  <head>
    {/* MUST be first — browsers need charset within the first 1024 bytes of <head> */}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Consent default state — MUST be before any tracker scripts */}
    <Fragment set:html={defaultConsentScriptTag({ nonce })} />

    {/* SEO tags built by web-core/seo */}
    {tags.map((tag) => {
      if (tag.kind === "title") return <title>{tag.content}</title>;
      if (tag.kind === "link") return <link rel={tag.rel} href={tag.href} hreflang={tag.hreflang} type={tag.type} />;
      return <meta name={tag.name} property={tag.property} content={tag.content} />;
    })}

    {/* Theme tokens (per-variant) */}
    <style set:html={`:root{${tokens}}`} nonce={nonce}></style>

    {/* Global a11y + consent CSS */}
    <style is:global set:html={globalCss}></style>

    {/* Plausible (cookieless — always loads, no consent needed) */}
    {plausibleEnabled && (
      <script
        is:inline
        defer
        data-domain={clientConfig.domain.primary}
        src="https://plausible.io/js/script.js"
      ></script>
    )}

    {/* JSON-LD structured data */}
    {jsonLd.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} nonce={nonce}></script>
    ))}
  </head>
  <body>
    <Fragment set:html={sl.html} />
    <slot />

    {/* Consent banner + preferences modal (hidden until runtime decides) */}
    <Fragment set:html={banner} />
    <Fragment set:html={modal} />

    {/* Runtime init: consent + GCLID capture + auto-track clicks */}
    <script>
      import { initStarter } from "../scripts/init.client.ts";
      initStarter();
    </script>

    {/* Track 24f — Chatbot widget (only when CHATBOT_ENABLED=true) */}
    {chatbotEnabled && <Fragment set:html={chatWidgetHtml} />}
  </body>
</html>
