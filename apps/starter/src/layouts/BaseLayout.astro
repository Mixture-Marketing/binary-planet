---
import "../styles/globals.css";

// Astro 6 security.csp is incompatible with ClientRouter. Migrated to native
// CSS View Transitions API via `@view-transition { navigation: auto; }` in
// globals.css (Chrome 126+, Edge 126+, Firefox graceful fallback).
import {
  consentBannerCss,
  consentBannerHtml,
  defaultConsentScriptTag,
  preferencesModalCss,
  preferencesModalHtml,
} from "@mixturemarketing/web-core/consent";
import {
  BREADCRUMB_CSS,
  focusVisibleStyles,
  skipLink,
  VISUALLY_HIDDEN_CSS,
} from "@mixturemarketing/web-core/a11y";
import { buildMetaTags, type MetaInput } from "@mixturemarketing/web-core/seo";
import { buildChatWidgetHtml } from "@mixturemarketing/web-core/chatbot";
import { buildLeadpopHtml } from "@mixturemarketing/web-core/leadpop";
import { buildFomoHtml } from "@mixturemarketing/web-core/fomo";
import { buildBooksyHtml } from "@mixturemarketing/web-core/booksy";
import { buildNewsletterHtml } from "@mixturemarketing/web-core/newsletter";
import { buildDeliveryHtml } from "@mixturemarketing/web-core/delivery";

import clientConfig from "../client.config.ts";
import { dualTokensCss, fontsCss, fontsHref, type ThemePresetSlug } from "../themes/registry.ts";

interface Props {
  meta: MetaInput;
  jsonLd?: unknown[];
}

const { meta, jsonLd = [] } = Astro.props;
const nonce = Astro.locals.nonce ?? "";
const themePreset = (clientConfig.theme.preset ?? "minimalist") as ThemePresetSlug;
const themeMode = clientConfig.theme.mode ?? "auto";
const fontPairIdx = clientConfig.theme.fontPairIdx ?? 0;
const tokens = dualTokensCss(themePreset, clientConfig.theme.variant, {
  ...(clientConfig.theme.brandColor && { brandColor: clientConfig.theme.brandColor }),
  ...(clientConfig.theme.accentColor && { accentColor: clientConfig.theme.accentColor }),
});
const fonts = fontsCss(themePreset, fontPairIdx);
const fontsUrl = fontsHref(themePreset, fontPairIdx);
const plausibleEnabled = clientConfig.integrations.plausible;

// Track 24f / 24f-2 / Faza A — feature flag toggles
// Astro 6: Astro.locals.runtime.env removed → use cloudflare:workers env
let runtimeEnv: {
  CHATBOT_ENABLED?: string;
  LEADPOP_ENABLED?: string;
  FOMO_COUNTER_ENABLED?: string;
  BOOKSY_URL?: string;
} | undefined;
try {
  const mod = await import("cloudflare:workers");
  runtimeEnv = mod.env as typeof runtimeEnv;
} catch {
  runtimeEnv = undefined;
}

const isOn = (v?: string): boolean => String(v ?? "").toLowerCase() === "true";

// Chatbot (Track 24f)
const chatbotEnabled = isOn(runtimeEnv?.CHATBOT_ENABLED);
const chatWidgetHtml = chatbotEnabled
  ? buildChatWidgetHtml({
      apiPath: "/api/chat",
      brandColor: "var(--c-brand, #047857)",
      introMessage: `Cześć! Jestem asystentem ${clientConfig.business.name}. W czym mogę pomóc?`,
      businessName: clientConfig.business.name,
    })
  : "";

// Leadpop (Faza A)
const leadpopEnabled = isOn(runtimeEnv?.LEADPOP_ENABLED);
const leadpopHtml = leadpopEnabled
  ? buildLeadpopHtml({
      title: "Specjalna oferta dla nowych klientów",
      body: `Zostaw email i dostań -10% na pierwszą wizytę w ${clientConfig.business.name}.`,
      discountCode: "PIERWSZE10",
      brandColor: "var(--c-brand, #047857)",
    })
  : "";

// FOMO counter (Faza A)
const fomoEnabled = isOn(runtimeEnv?.FOMO_COUNTER_ENABLED);
const cityName = clientConfig.location?.address?.city ?? "okolicy";
const fomoHtml = fomoEnabled
  ? buildFomoHtml({
      messages: [
        `<strong>Nowy zapytanie</strong> z ${cityName} — przed chwilą.`,
        `<strong>${cityName}</strong> — 12 osób skorzystało w tym tygodniu.`,
        `<strong>Klient</strong> zostawił 5★ opinię 2 godz. temu.`,
      ],
      brandColor: "var(--c-brand, #047857)",
    })
  : "";

// Booksy embed (Faza A) — also available baseline in Starter pakiet per Track 25.
// BOOKSY_URL = klient's Booksy/Calendly profile (set in wizard, then injected as env var by provisioning).
const booksyUrl = runtimeEnv?.BOOKSY_URL?.trim() ?? "";
const booksyHtml = booksyUrl
  ? buildBooksyHtml({
      bookingUrl: booksyUrl,
      ctaLabel: "Zarezerwuj wizytę",
      brandColor: "var(--c-brand, #047857)",
      mode: "sticky",
    })
  : "";

// Instagram embed (Track 24f-5) — section rendered before footer when configured
const igEmbedUrl = (runtimeEnv as { INSTAGRAM_EMBED_URL?: string } | undefined)?.INSTAGRAM_EMBED_URL?.trim() ?? "";
const igSectionTitle = (runtimeEnv as { INSTAGRAM_SECTION_TITLE?: string } | undefined)?.INSTAGRAM_SECTION_TITLE ?? "Instagram";

// Delivery widget (Track 24f-6) — sticky bottom-left "Zamów online"
const deliveryUrl = (runtimeEnv as { DELIVERY_URL?: string } | undefined)?.DELIVERY_URL?.trim() ?? "";
const deliveryProvider = (runtimeEnv as { DELIVERY_PROVIDER?: string } | undefined)?.DELIVERY_PROVIDER as "wolt" | "glovo" | "pyszne" | "uber_eats" | "generic" | undefined;
const deliveryHtml = deliveryUrl
  ? buildDeliveryHtml({
      deliveryUrl,
      brandColor: "var(--c-brand, #047857)",
      ...(deliveryProvider && { provider: deliveryProvider }),
    })
  : "";

// Newsletter widget (Track 24f-4) — bottom-right sticky card, after 6s
const newsletterEnabled = isOn((runtimeEnv as { NEWSLETTER_SMS_ENABLED?: string } | undefined)?.NEWSLETTER_SMS_ENABLED);
const newsletterHtml = newsletterEnabled
  ? buildNewsletterHtml({
      title: "Bądź na bieżąco",
      body: `Otrzymuj nowości i promocje od ${clientConfig.business.name}. Bez spamu.`,
      brandColor: "var(--c-brand, #047857)",
      mode: "sticky",
      collectPhone: false,
    })
  : "";

// SEO: build meta tags from input. dev: log warnings.
const { tags, warnings } = buildMetaTags(meta);
if (import.meta.env.DEV && warnings.length > 0) {
  for (const w of warnings) console.warn(`[SEO] ${w.field}: ${w.message}`);
}

// A11y components — render once globally
const sl = skipLink({ targetId: "main" });

// Consent — banner + modal
const banner = consentBannerHtml({
  businessName: clientConfig.business.name,
  privacyUrl: clientConfig.rodo.privacyPolicyUrl ?? "/polityka-prywatnosci",
  ...(clientConfig.rodo.termsUrl && { termsUrl: clientConfig.rodo.termsUrl }),
  version: clientConfig.rodo.consentVersion,
});
const modal = preferencesModalHtml();

// Combined global CSS
const globalCss = [
  VISUALLY_HIDDEN_CSS,
  focusVisibleStyles({ outlineColor: "var(--color-brand)" }),
  sl.css,
  BREADCRUMB_CSS,
  consentBannerCss(),
  preferencesModalCss(),
].join("\n");
---

<!doctype html>
<html lang="pl" data-theme={themeMode}>
  <head>
    {/* MUST be first — browsers need charset within the first 1024 bytes of <head> */}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Consent default state — MUST be before any tracker scripts */}
    <Fragment set:html={defaultConsentScriptTag({ nonce })} />

    {/* SEO tags built by web-core/seo */}
    {tags.map((tag) => {
      if (tag.kind === "title") return <title>{tag.content}</title>;
      if (tag.kind === "link") return <link rel={tag.rel} href={tag.href} hreflang={tag.hreflang} type={tag.type} />;
      return <meta name={tag.name} property={tag.property} content={tag.content} />;
    })}

    {/* Theme tokens (light + dark via data-theme) + fonts (per preset + font pair) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Unsplash CDN — every theme uses photos. Preconnect saves ~150ms LCP. */}
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link rel="stylesheet" href={fontsUrl} />
    <style set:html={`${tokens}:root{${fonts}}body{font-family:var(--font-body);font-feature-settings:var(--font-features,"liga");font-variant-ligatures:common-ligatures}h1,h2,h3,h4{font-family:var(--font-display)}`} nonce={nonce}></style>

    {/* Global a11y + consent CSS */}
    <style is:global set:html={globalCss}></style>

    {/* View Transitions via native CSS @view-transition rule (globals.css).
        Cross-document navigation animacje w Chrome 126+/Edge 126+. Firefox/Safari
        bez animacji ale bez błędów — graceful degradation. Brak JS = brak CSP issue. */}

    {/* Plausible (cookieless — always loads, no consent needed) */}
    {plausibleEnabled && (
      <script
        is:inline
        defer
        nonce={nonce}
        data-domain={clientConfig.domain.primary}
        src="https://plausible.io/js/script.js"
      ></script>
    )}

    {/* JSON-LD structured data */}
    {jsonLd.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} nonce={nonce}></script>
    ))}
  </head>
  <body>
    <Fragment set:html={sl.html} />
    {/* WCAG 4.1.3 — announce route changes for AT users on Astro ClientRouter navigation */}
    <div id="route-announcer" role="status" aria-live="polite" class="visually-hidden"></div>
    {themePreset === "editorial" && (
      <div data-reading-progress aria-hidden="true"></div>
    )}
    {clientConfig.clientId.startsWith("clk_demo_") && (
      <div style="position: sticky; top: 0; z-index: 9999; background: #fbbf24; color: #1a1a1a; text-align: center; padding: 0.5rem 1rem; font-size: 0.9rem; font-weight: 600;">
        🎨 STRONA DEMO — przykład realizacji MixtureMarketing.pl ·
        <a href="https://mixturemarketing.pl/abonament" style="color: #1a1a1a; text-decoration: underline; margin-left: 0.5rem;">Zamów swoją od 179 zł/mc →</a>
      </div>
    )}
    <slot />

    {/* Consent banner + preferences modal (hidden until runtime decides) */}
    <Fragment set:html={banner} />
    <Fragment set:html={modal} />

    {/* Runtime init: consent + GCLID capture + auto-track clicks */}
    <script>
      import { initStarter } from "../scripts/init.client.ts";
      initStarter();
    </script>

    {/* Track 24f — Chatbot widget (only when CHATBOT_ENABLED=true) */}
    {chatbotEnabled && <Fragment set:html={chatWidgetHtml} />}

    {/* Faza A — Booksy sticky CTA (BOOKSY_URL set per-klient) */}
    {booksyUrl && <Fragment set:html={booksyHtml} />}

    {/* Faza A — FOMO counter (FOMO_COUNTER_ENABLED) */}
    {fomoEnabled && <Fragment set:html={fomoHtml} />}

    {/* Faza A — Leadpop modal (LEADPOP_ENABLED) — last because it's modal */}
    {leadpopEnabled && <Fragment set:html={leadpopHtml} />}

    {/* Track 24f-4 — Newsletter subscribe widget */}
    {newsletterEnabled && <Fragment set:html={newsletterHtml} />}

    {/* Track 24f-6 — Delivery sticky CTA (Wolt/Glovo/Pyszne) */}
    {deliveryUrl && <Fragment set:html={deliveryHtml} />}

    {/* Track 24f-5 — Instagram embed section (renders inline iframe from SnapWidget/Lightwidget/etc.) */}
    {igEmbedUrl && (
      <section style="max-width: 1000px; margin: 3rem auto; padding: 0 1rem;">
        <h2 style="font-size: 1.5rem; font-weight: 700; text-align: center; margin: 0 0 1.5rem 0;">📸 {igSectionTitle}</h2>
        <iframe src={igEmbedUrl} width="100%" height="600" loading="lazy" style="border:0;border-radius:12px;display:block;" title="Instagram"></iframe>
      </section>
    )}

    {/* Mobile sticky CTA bar — branch by business type.
       Restaurant: Zadzwoń + Zarezerwuj stolik.
       Service businesses (Locksmith, AutoRepair, Beauty, Medical, etc.): Zadzwoń (emphasized) + Wycena/Formularz. */}
    {(() => {
      const stype = clientConfig.business.schemaType;
      if (stype === "Restaurant") {
        return (
          <nav class="mobile-cta-bar" aria-label="Szybki kontakt">
            <a href={`tel:${clientConfig.contact.primaryPhone}`} class="mobile-cta-bar__btn mobile-cta-bar__btn--ghost" data-track-event="phone_click" data-track-position="sticky-mobile">
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
              Zadzwoń
            </a>
            <a href="/kontakt" class="mobile-cta-bar__btn mobile-cta-bar__btn--primary" data-track-event="reservation_click" data-track-position="sticky-mobile">
              Zarezerwuj stolik
            </a>
          </nav>
        );
      }
      // Services / craftsmen / local services — phone-first (most calls = revenue)
      return (
        <nav class="mobile-cta-bar" aria-label="Szybki kontakt">
          <a href={`tel:${clientConfig.contact.primaryPhone}`} class="mobile-cta-bar__btn mobile-cta-bar__btn--primary mobile-cta-bar__btn--wide" data-track-event="phone_click" data-track-position="sticky-mobile">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
            Zadzwoń teraz
          </a>
          <a href="/kontakt" class="mobile-cta-bar__btn mobile-cta-bar__btn--ghost" data-track-event="quote_click" data-track-position="sticky-mobile">
            Wycena
          </a>
        </nav>
      );
    })()}
  </body>
</html>
