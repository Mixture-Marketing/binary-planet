---
import { getCollection } from "astro:content";

import CraftsmanLayout from "../../themes/craftsman/layouts/CraftsmanLayout.astro";
import BreadcrumbNav from "../../themes/craftsman/components/BreadcrumbNav.astro";
import PostCard from "../../themes/craftsman/components/PostCard.astro";
import { aktualnosciSeo } from "../../lib/seo.ts";

const { meta, jsonLd } = aktualnosciSeo();

const posts = (await getCollection("posts"))
  .filter((p) => p.data.published)
  .sort((a, b) => +b.data.date - +a.data.date);
---

<CraftsmanLayout meta={meta} jsonLd={jsonLd}>
  <BreadcrumbNav items={[{ name: "Strona główna", url: "/" }, { name: "Aktualności" }]} />
  <section class="container-px" style="padding-block: 1.5rem 3rem;">
    <header style="margin-bottom: 2rem;">
      <h1 style="margin: 0 0 0.5rem 0;">Aktualności</h1>
      <p style="margin: 0; color: var(--color-text-muted);">
        Porady, nowości i wpisy z naszej działalności.
      </p>
    </header>

    {posts.length === 0 ? (
      <p style="color: var(--color-text-muted);">Wkrótce pojawią się tutaj pierwsze wpisy.</p>
    ) : (
      <ul style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; list-style: none; margin: 0; padding: 0;">
        {posts.map((post) => (
          <li>
            <PostCard
              href={`/aktualnosci/${post.id}`}
              title={post.data.title}
              date={post.data.date}
              excerpt={post.data.excerpt}
              coverImage={post.data.coverImage}
              tags={post.data.tags}
            />
          </li>
        ))}
      </ul>
    )}
  </section>
</CraftsmanLayout>
