---
import CraftsmanLayout from "../themes/craftsman/layouts/CraftsmanLayout.astro";
import Hero from "../themes/craftsman/components/Hero.astro";
import ServicesList from "../themes/craftsman/components/ServicesList.astro";
import OpeningHours from "../themes/craftsman/components/OpeningHours.astro";
import ReviewsSection from "../themes/craftsman/components/ReviewsSection.astro";
import ContactForm from "../themes/craftsman/components/ContactForm.astro";
import { homeSeo } from "../lib/seo.ts";

const { meta, jsonLd } = homeSeo();
---

<CraftsmanLayout meta={meta} jsonLd={jsonLd}>
  <Hero />
  <ServicesList linkToDetails={false} />
  <ReviewsSection />
  <OpeningHours />
  <ContactForm />
</CraftsmanLayout>
