---
import CraftsmanLayout from "../themes/dynamic/layouts/CraftsmanLayout.astro";
import BreadcrumbNav from "../themes/dynamic/components/BreadcrumbNav.astro";
import OpeningHours from "../themes/OpeningHours.astro";
import ContactForm from "../themes/ContactForm.astro";
import clientConfig from "../client.config.ts";
import { breadcrumbItems, kontaktSeo } from "../lib/seo.ts";

const city = clientConfig.location.address.city;
const isRestaurant = clientConfig.business.schemaType === "Restaurant";

// Page-specific FAQ — pairs with FAQPage JSON-LD
const faqs = isRestaurant
  ? [
      {
        question: "Jak szybko otrzymam potwierdzenie rezerwacji?",
        answer: `Telefoniczną rezerwację potwierdzamy od razu. Rezerwacje przez formularz potwierdzamy w ciągu 2 godzin w godzinach pracy ${clientConfig.business.name}.`,
      },
      {
        question: "Czy obsługujecie eventy i grupy 8+ osób?",
        answer: `Tak. Mamy salę główną do 40 osób i kameralną do 16. Dla grup 8+ proszę o kontakt z dwudniowym wyprzedzeniem — przygotujemy menu degustacyjne lub indywidualną kartę pod event.`,
      },
      {
        question: "Czy wystawiacie fakturę VAT?",
        answer: "Tak, fakturę VAT wystawiamy na życzenie — wystarczy podać NIP przy zamówieniu. Dostarczamy elektronicznie na wskazany email.",
      },
      {
        question: "Czy są opcje wegetariańskie i bezglutenowe?",
        answer: "Mamy oznaczone dania wegetariańskie (V), wegańskie (Ve) i bezglutenowe (GF). Pizzę na cieście bezglutenowym przygotowujemy +8 zł.",
      },
    ]
  : [
      {
        question: "Jak szybko mogę liczyć na odpowiedź?",
        answer: "Telefonicznie odbieramy zwykle od razu, najpóźniej w 15 minut. Na formularze odpisujemy w godzinach pracy w ciągu godziny.",
      },
      {
        question: "Czy dojeżdżacie do mnie?",
        answer: `Tak, dojeżdżamy do klientów na terenie ${city} oraz okolicznych miejscowości. Dla awaryjnych wezwań — 24/7.`,
      },
      {
        question: "Czy wystawiacie fakturę VAT?",
        answer: "Tak, każda usługa kończy się fakturą VAT. Dostarczamy elektronicznie na podany email.",
      },
      {
        question: "Czy mogę zarezerwować termin online?",
        answer:
          "Najszybciej telefonicznie — termin ustalamy w trakcie krótkiej rozmowy. Można też wypełnić formularz, oddzwaniamy z propozycjami.",
      },
    ];

const { meta, jsonLd } = kontaktSeo(faqs);
---

<CraftsmanLayout meta={meta} jsonLd={jsonLd}>
  <BreadcrumbNav items={breadcrumbItems("Kontakt")} />

  <section class="section-py" style="background: var(--color-surface-muted);">
    <div class="container-px">
      <p style="margin: 0 0 0.5rem 0; font-weight: 600; color: var(--color-brand);">Skontaktuj się</p>
      <h1 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; margin: 0 0 1rem 0;">
        Kontakt
      </h1>
      <p style="color: var(--color-text-muted); font-size: 1.15rem; max-width: 50rem; margin: 0;">
        Najszybciej odpowiem na telefon. Możesz też napisać — odzywam się tego samego dnia w godzinach pracy.
      </p>
    </div>
  </section>

  <OpeningHours />

  <section aria-labelledby="faq-heading" class="section-py">
    <div class="container-px" style="max-width: 50rem;">
      <h2 id="faq-heading" style="font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight: 700; margin: 0 0 2rem 0;">
        Najczęstsze pytania
      </h2>
      <dl style="display: grid; gap: 1.5rem;">
        {faqs.map((item) => (
          <div style="background: var(--color-surface-muted); padding: 1.5rem; border-radius: var(--radius-md);">
            <dt style="font-weight: 700; margin-bottom: 0.5rem;">{item.question}</dt>
            <dd style="margin: 0; color: var(--color-text-muted);">{item.answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <ContactForm heading="Wypełnij formularz" />
</CraftsmanLayout>
