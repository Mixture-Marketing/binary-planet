---
/**
 * Elegant Hero — full-bleed photo with slow zoom, product-label corner
 * (Aesop/Aman pattern). Top: floating brand wordmark left + tiny nav right.
 * Bottom-right product label with overline + italic h1 + CTA.
 */
import { formatPolishPhone, phoneAriaLabel as buildPhoneAriaLabel } from "@mixturemarketing/web-core/local";
import clientConfig from "../../../client.config.ts";

const { business, contact, location } = clientConfig;
const cityName = location.address.city;
const phoneDisplay = formatPolishPhone(contact.primaryPhone);
const phoneAria = buildPhoneAriaLabel(contact.primaryPhone);
// Industry-specific hero image (curated)
const HERO_IMAGES: Record<string, string> = {
  beauty: "https://images.unsplash.com/photo-1560066984-138dadb4c035?w=1800&fm=webp&q=85",
  spa: "https://images.unsplash.com/photo-1487412947147-5cebf100ffc2?w=1800&fm=webp&q=85",
  fryzjer: "https://images.unsplash.com/photo-1560066984-138dadb4c035?w=1800&fm=webp&q=85",
  hotel: "https://images.unsplash.com/photo-1566073771259-6a8506099945?w=1800&fm=webp&q=85",
  fotograf: "https://images.unsplash.com/photo-1452587925148-ce544e77e70d?w=1800&fm=webp&q=85",
};
const heroImageUrl = HERO_IMAGES[business.industry.toLowerCase()] ?? "https://images.unsplash.com/photo-1560066984-138dadb4c035?w=1800&fm=webp&q=85";
---

<section aria-labelledby="hero-heading" class="e-hero">
  {/* Real <img> instead of CSS bg-image — preload-scanner discoverable, faster LCP */}
  <img
    src={heroImageUrl}
    alt=""
    role="presentation"
    class="e-hero__img"
    width="1800"
    height="2400"
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
  <div class="e-hero__veil" aria-hidden="true"></div>

  <a href="/" class="e-hero__brand" aria-label={`${business.name} — strona główna`}>
    {business.name}
    {business.foundedYear && <small>{location.address.city} · {business.foundedYear}</small>}
  </a>

  <div class="e-hero__top-right">
    <a href={`tel:${contact.primaryPhone}`} class="e-hero__phone" aria-label={phoneAria}>
      {phoneDisplay}
    </a>
  </div>

  <div class="e-hero__label">
    <p class="e-hero__overline">{business.industry} · butikowy · {cityName}</p>
    <h1 id="hero-heading" class="e-hero__h1">
      {business.tagline}
      {business.foundedYear && <span class="e-hero__h1-brand">{business.name} · est. {business.foundedYear}</span>}
    </h1>
    <a href="/kontakt" class="e-hero__cta" data-track-event="booking_intent" data-track-position="hero">
      Umów wizytę →
    </a>
  </div>
</section>

<style>
  .e-hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    background: #2a1d1f;
    color: #fff;
    isolation: isolate;
  }
  .e-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: -2;
    transform: scale(1.05);
    animation: e-hero-zoom 18s ease-out forwards;
  }
  @keyframes e-hero-zoom { to { transform: scale(1); } }
  @media (prefers-reduced-motion: reduce) { .e-hero__img { animation: none; transform: none; } }
  /* Veil — stronger scrim covers bottom 60% for label contrast (WCAG 1.4.3) */
  .e-hero__veil {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(180deg, rgba(20,12,10,0.35) 0%, transparent 30%),
      linear-gradient(180deg, transparent 30%, rgba(20,12,10,0.7) 100%);
  }

  .e-hero__brand {
    position: absolute;
    top: 2.5rem;
    left: 2.5rem;
    color: #fff;
    text-decoration: none;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.4rem;
    letter-spacing: 0.05em;
    z-index: 2;
  }
  .e-hero__brand small {
    display: block;
    font-style: normal;
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-top: 0.25rem;
    opacity: 0.7;
  }
  @media (max-width: 768px) {
    .e-hero__brand { top: 1.5rem; left: 1.5rem; font-size: 1.15rem; }
  }

  .e-hero__top-right {
    position: absolute;
    top: 2.5rem;
    right: 2.5rem;
    z-index: 2;
  }
  @media (max-width: 768px) {
    .e-hero__top-right { top: 1.5rem; right: 1.5rem; }
  }
  .e-hero__phone {
    color: #fff;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.85;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 999px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    background: rgba(255,255,255,0.05);
    font-variant-numeric: tabular-nums;
  }
  .e-hero__phone:hover { background: rgba(255,255,255,0.15); }

  .e-hero__label {
    position: absolute;
    bottom: 4rem;
    right: 4rem;
    text-align: right;
    z-index: 2;
    max-width: 32rem;
    /* Defense-in-depth: text-shadow for contrast on bright photo regions (WCAG 1.4.3) */
    text-shadow: 0 2px 12px rgba(20,12,10,0.5);
  }
  @media (max-width: 768px) {
    .e-hero__label {
      right: 1.5rem;
      left: 1.5rem;
      bottom: 2.5rem;
      text-align: left;
      max-width: none;
    }
  }
  .e-hero__overline {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    font-weight: 500;
    opacity: 0.85;
    margin: 0 0 1.5rem;
  }
  .e-hero__h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-style: italic;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1;
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
    color: #fff;
    text-wrap: balance;
  }
  .e-hero__h1-brand {
    display: block;
    font-style: normal;
    font-weight: 300;
    font-size: 0.6em;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-top: 1rem;
  }
  .e-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1.5rem;
    padding: 0.95rem 2rem;
    background: rgba(255,255,255,0.12);
    color: #fff;
    text-decoration: none;
    /* Solid 1.5px white border (was 1px @ 0.5 alpha = FAIL 1.4.11 non-text contrast) */
    border: 1.5px solid rgba(255,255,255,0.9);
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    border-radius: 999px;
    transition: background 250ms ease;
    min-height: 48px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .e-hero__cta:hover { background: rgba(255,255,255,0.22); }
  @media (prefers-reduced-transparency: reduce) {
    .e-hero__phone {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: rgba(255,255,255,0.18);
    }
    .e-hero__cta {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: rgba(255,255,255,0.25);
    }
  }
</style>
