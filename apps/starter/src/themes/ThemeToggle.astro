---
/**
 * Dark mode toggle button — universal across all 4 styles.
 *
 * - Reads `clientConfig.theme.mode` (auto/light/dark) from data-theme on <html>
 * - Click cycles: auto → light → dark → auto (saves to localStorage)
 * - On load, if localStorage has explicit choice, applies it
 * - Otherwise honors `prefers-color-scheme` (via CSS @media in dualTokensCss)
 *
 * Style adapts via per-style class wrapper. Pass `style` prop for visual fit.
 */

interface Props {
  /** Visual style: matches parent theme. "minimal" / "elegant" / "dynamic" / "editorial". */
  style?: "minimal" | "elegant" | "dynamic" | "editorial";
}
const { style = "minimal" } = Astro.props;
---

<button
  type="button"
  class={`theme-toggle theme-toggle--${style}`}
  aria-label="Przełącz tryb jasny/ciemny"
  data-theme-toggle
>
  <svg class="theme-toggle__icon theme-toggle__icon--sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path><path d="M12 20v2"></path>
    <path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path>
    <path d="M2 12h2"></path><path d="M20 12h2"></path>
    <path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
  </svg>
  <svg class="theme-toggle__icon theme-toggle__icon--moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
</button>

<script is:inline>
  (function () {
    const KEY = "mm-theme-mode";
    const root = document.documentElement;

    function applyMode(mode) {
      root.setAttribute("data-theme", mode);
    }

    function getCurrentMode() {
      const saved = localStorage.getItem(KEY);
      if (saved === "light" || saved === "dark" || saved === "auto") return saved;
      return root.getAttribute("data-theme") || "auto";
    }

    function cycleMode() {
      const cur = getCurrentMode();
      const next = cur === "auto" ? "light" : cur === "light" ? "dark" : "auto";
      localStorage.setItem(KEY, next);
      applyMode(next);
      updateToggleVisual(next);
    }

    function effectiveTheme() {
      const mode = getCurrentMode();
      if (mode === "auto") {
        return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
      }
      return mode;
    }

    function updateToggleVisual(mode) {
      const effective = effectiveTheme();
      document.querySelectorAll("[data-theme-toggle]").forEach((btn) => {
        btn.setAttribute("data-effective", effective);
        btn.setAttribute("data-mode", mode);
        btn.setAttribute("title", "Tryb: " + (mode === "auto" ? "automatyczny" : mode === "light" ? "jasny" : "ciemny"));
      });
    }

    // Init on load
    function init() {
      const saved = localStorage.getItem(KEY);
      if (saved && saved !== root.getAttribute("data-theme")) {
        applyMode(saved);
      }
      updateToggleVisual(getCurrentMode());
    }
    init();

    // Astro View Transitions — re-apply after each page swap (uniknięcie flash of light)
    document.addEventListener("astro:after-swap", init);

    // Listen for system changes (if mode is auto)
    if (window.matchMedia) {
      window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", () => {
        if (getCurrentMode() === "auto") updateToggleVisual("auto");
      });
    }

    // Bind toggles (event delegation — działa też po VT swap)
    document.addEventListener("click", (e) => {
      const t = e.target.closest("[data-theme-toggle]");
      if (t) {
        e.preventDefault();
        cycleMode();
      }
    });
  })();
</script>

<style>
  .theme-toggle {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.4rem;
    border-radius: 6px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 200ms, border-color 200ms, background 200ms;
  }
  .theme-toggle:hover {
    color: var(--color-brand);
    border-color: var(--color-brand);
  }
  .theme-toggle__icon { display: none; }
  .theme-toggle[data-effective="light"] .theme-toggle__icon--moon { display: block; }
  .theme-toggle[data-effective="dark"] .theme-toggle__icon--sun { display: block; }
  /* Pre-init fallback — show sun (light assumed) */
  .theme-toggle:not([data-effective]) .theme-toggle__icon--moon { display: block; }

  /* Style-specific tweaks */
  .theme-toggle--elegant { border-radius: 999px; }
  .theme-toggle--dynamic { border-width: 2px; border-radius: 4px; }
  .theme-toggle--editorial { border-radius: 0; border-width: 1px; }
</style>
