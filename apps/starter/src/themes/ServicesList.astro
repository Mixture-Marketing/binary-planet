---
import clientConfig from "../client.config.ts";
import MinimalistServices from "./minimalist/components/ServicesList.astro";
import ElegantServices from "./elegant/components/ServicesList.astro";
import DynamicServices from "./dynamic/components/ServicesList.astro";
import EditorialServices from "./editorial/components/ServicesList.astro";

interface Props {
  heading?: string;
  linkToDetails?: boolean;
}

const preset = clientConfig.theme.preset;
const props = Astro.props;
---

{preset === "minimalist" && <MinimalistServices {...props} />}
{preset === "elegant" && <ElegantServices {...props} />}
{preset === "dynamic" && <DynamicServices {...props} />}
{preset === "editorial" && <EditorialServices {...props} />}
