---
/**
 * Editorial Menu (Karta) — printed-card style. Category title with italic
 * subhead, dot-leader items, italic accent tag, tabular numerals for prices.
 */
interface Props {
  config?: {
    heading?: string;
    categories?: Array<{
      name: string;
      subhead?: string;
      items: Array<{ name: string; description?: string; price: string; badge?: string }>;
    }>;
  };
}
const { config = {} } = Astro.props;
const heading = config.heading ?? "Karta dań";
const categories = config.categories ?? [];
---

{categories.length > 0 && (
  <section aria-labelledby="menu-heading" class="ed-karta" id="karta">
    <div class="container-px ed-karta__inner">
      <header class="ed-karta__head">
        <p class="ed-karta__eyebrow">Karta dań</p>
        <h2 id="menu-heading" class="ed-karta__h2">{heading}</h2>
      </header>

      <div class="ed-karta__layout">
        <div class="ed-karta__list">
          {categories.map((cat) => (
            <div class="ed-karta__group">
              <h3 class="ed-karta__group-title">
                {cat.name}
                {cat.subhead && <small>{cat.subhead}</small>}
              </h3>
              {cat.items.map((item) => (
                <div class="ed-karta__item">
                  <div>
                    <span class="ed-karta__item-name">
                      {item.name}
                      {item.badge && <em>{item.badge}</em>}
                    </span>
                    {item.description && <p class="ed-karta__item-desc">{item.description}</p>}
                  </div>
                  <span class="ed-karta__item-price">{item.price}</span>
                </div>
              ))}
            </div>
          ))}
        </div>

        {/* Chef's pick — printed-card sidebar element (signature klocek) */}
        <aside class="ed-karta__pick" aria-label="Polecenie szefa kuchni">
          <p class="ed-karta__pick-overline">— Karta poleceń szefa</p>
          <figure class="ed-karta__pick-figure">
            <img
              src="https://images.unsplash.com/photo-1572441713132-c542fc4fe282?w=600&h=750&fit=crop&fm=webp&q=85"
              alt="Tagliatelle al ragù — danie dnia"
              width="600"
              height="750"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <h3 class="ed-karta__pick-name">Tagliatelle <em>al Ragù</em></h3>
          <p class="ed-karta__pick-desc">
            Sos mięsny gotowany 6 godzin. Wołowina, boczek włoski, San Marzano,
            Chianti redukowane do połowy. Pasta wałkowana ręcznie tego ranka.
          </p>
          <div class="ed-karta__pick-meta">
            <span class="ed-karta__pick-pairing">Najlepiej z kieliszkiem <em>Chianti Classico</em></span>
            <span class="ed-karta__pick-price">46&nbsp;zł</span>
          </div>
          <a href="/kontakt" class="ed-karta__pick-cta">Zarezerwuj stolik →</a>
        </aside>
      </div>
    </div>
  </section>
)}

<style>
  .ed-karta {
    background: var(--color-surface);
    padding-block: clamp(4rem, 7vw, 6rem);
    border-top: 1px solid var(--color-border);
  }
  .ed-karta__inner { max-width: 76rem; margin: 0 auto; }
  .ed-karta__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 900px) {
    .ed-karta__layout { grid-template-columns: 1.7fr 1fr; gap: 4rem; }
  }
  .ed-karta__list { max-width: 56rem; }

  /* Chef's pick sidebar — printed-card aesthetic */
  .ed-karta__pick {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 1.75rem 1.75rem 1.5rem;
    position: relative;
    overflow: hidden;
  }
  .ed-karta__pick::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--color-accent);
  }
  .ed-karta__pick-overline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.92rem;
    color: var(--color-accent);
    margin: 0 0 1rem;
    letter-spacing: 0.02em;
  }
  .ed-karta__pick-figure {
    margin: 0 0 1.25rem;
    border-radius: 2px;
    overflow: hidden;
  }
  .ed-karta__pick-figure img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
  }
  .ed-karta__pick-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin: 0 0 0.75rem;
    color: var(--color-text);
  }
  .ed-karta__pick-name em {
    font-style: italic;
    color: var(--color-brand);
  }
  .ed-karta__pick-desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0 0 1.25rem;
  }
  .ed-karta__pick-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.75rem;
    justify-content: space-between;
    padding-block: 1rem;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.25rem;
  }
  .ed-karta__pick-pairing {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.88rem;
    color: var(--color-text-muted);
    max-width: 60%;
  }
  .ed-karta__pick-pairing em {
    font-style: italic;
    color: var(--color-text);
    font-weight: 500;
  }
  .ed-karta__pick-price {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    color: var(--color-brand);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.01em;
  }
  .ed-karta__pick-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-text);
    font-size: 1rem;
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
    text-underline-offset: 6px;
    text-decoration-thickness: 2px;
  }
  .ed-karta__pick-cta:hover { text-decoration-thickness: 3px; }
  .ed-karta__head { text-align: center; margin-bottom: 4rem; }
  .ed-karta__eyebrow {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-accent);
    font-size: 1.05rem;
    margin: 0 0 0.5rem;
  }
  .ed-karta__h2 {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    margin: 0;
    line-height: 1;
    letter-spacing: -0.015em;
    color: var(--color-text);
  }

  .ed-karta__group { margin-bottom: 3rem; }
  .ed-karta__group-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.4rem;
    color: var(--color-brand);
    margin: 0 0 1.25rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .ed-karta__group-title small {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--color-accent);
    font-weight: 400;
    letter-spacing: 0.04em;
  }

  .ed-karta__item {
    padding: 0.85rem 0;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: baseline;
  }
  .ed-karta__item-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.15rem;
    color: var(--color-text);
  }
  .ed-karta__item-name em {
    font-style: italic;
    color: var(--color-brand);
    font-weight: 400;
    margin-left: 0.4rem;
    font-size: 0.85em;
  }
  .ed-karta__item-desc {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin: 0.15rem 0 0;
  }
  .ed-karta__item-price {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.1rem;
    color: var(--color-text);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }
</style>
