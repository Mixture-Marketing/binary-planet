---
import { formatPolishPhone, phoneAriaLabel } from "@mixturemarketing/web-core/local";
import clientConfig from "../../../client.config.ts";
import Icon from "./Icon.astro";
import ThemeToggle from "../../ThemeToggle.astro";

const phoneDisplay = formatPolishPhone(clientConfig.contact.primaryPhone);
const phoneAria = phoneAriaLabel(clientConfig.contact.primaryPhone);

const navItems = [
  { href: "/", label: "Start" },
  { href: "/oferta", label: "Oferta" },
  { href: "/uslugi", label: "Obszar działania" },
  { href: "/aktualnosci", label: "Aktualności" },
  { href: "/faq", label: "FAQ" },
  { href: "/o-firmie", label: "O firmie" },
  { href: "/kontakt", label: "Kontakt" },
];

const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
---

<header role="banner" style="background: var(--color-surface); border-bottom: 1px solid var(--color-border); position: sticky; top: 0; z-index: 50;">
  <div class="container-px" style="display: flex; align-items: center; justify-content: space-between; padding-block: 1rem; gap: 1rem;">
    <a href="/" aria-label={`${clientConfig.business.name} - strona główna`} style="font-weight: 700; font-size: 1.25rem; color: var(--color-text); text-decoration: none;">
      {clientConfig.business.name}
    </a>

    <nav aria-label="Główna nawigacja" style="display: none;" class="md:!flex" data-nav-desktop>
      <ul style="display: flex; gap: 1.5rem; list-style: none; margin: 0; padding: 0;">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={currentPath === item.href.replace(/\/+$/, "") || (item.href === "/" && currentPath === "/") ? "page" : undefined}
              style={`color: var(--color-text); text-decoration: none; font-weight: 500; padding: 0.5rem; border-radius: 4px; ${currentPath === item.href.replace(/\/+$/, "") ? "color: var(--color-brand);" : ""}`}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div style="display: flex; align-items: center; gap: 0.5rem;">
      <ThemeToggle style="dynamic" />
      <a
        href={`tel:${clientConfig.contact.primaryPhone}`}
        class="btn-primary d-header__phone"
        aria-label={phoneAria}
        data-track-event="phone_click"
        data-track-position="header"
        style="font-size: 0.95rem; padding: 0.6rem 1rem;"
      >
        <Icon name="phone" size={16} />
        <span class="hidden sm:inline">{phoneDisplay}</span>
        <span class="sm:hidden">Zadzwoń</span>
      </a>
    </div>
  </div>
</header>

<style>
  @media (min-width: 768px) {
    [data-nav-desktop] { display: flex !important; }
  }
</style>
