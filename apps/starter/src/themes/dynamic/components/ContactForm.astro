---
/**
 * Dynamic ContactForm — final-CTA gradient card style.
 * Top: BIG headline + sub + visible phone link. Below: form with split fields.
 */
import { formatPolishPhone } from "@mixturemarketing/web-core/local";
import clientConfig from "../../../client.config.ts";

interface Props { heading?: string; }
const { heading = "Zatrzaśnięte drzwi? Zadzwoń teraz." } = Astro.props;
const consentVersion = clientConfig.rodo.consentVersion;
const phoneDisplay = formatPolishPhone(clientConfig.contact.primaryPhone);
const hasEmergency = clientConfig.hours.note?.includes("24/7");
---

<section aria-labelledby="contact-heading" class="d-contact" id="kontakt">
  <div class="container-px d-contact__inner">
    <div class="d-contact__cta-card">
      {hasEmergency && <p class="d-contact__eyebrow">Awaryjne wezwania 24/7</p>}
      <h2 id="contact-heading" class="d-contact__h2">{heading}</h2>
      <p class="d-contact__sub">Dojazd 30 minut. Bez uszkodzenia. Faktura VAT.</p>
      <a href={`tel:${clientConfig.contact.primaryPhone}`} class="d-contact__phone-btn" data-track-event="phone_click" data-track-position="final-cta">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {phoneDisplay}
      </a>
    </div>

    <details class="d-contact__form-wrap">
      <summary>...albo wyślij wiadomość — oddzwonię w 2h</summary>
      <form id="contact-form" method="POST" action="/api/contact" class="d-contact__form" novalidate>
        <input type="hidden" name="consent_text_version" value={consentVersion} />
        <input type="hidden" name="source_page" value={Astro.url.pathname} />
        <div aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden">
          <label><input type="text" name="honeypot" tabindex="-1" autocomplete="off" /></label>
        </div>

        <p id="contact-form__status" role="status" aria-live="polite" class="d-contact__status"></p>

        <input type="text" name="name" required minlength="2" maxlength="100" autocomplete="name" placeholder="Imię" aria-required="true" class="d-contact__input" />
        <input type="tel" name="phone" required minlength="6" maxlength="20" autocomplete="tel" inputmode="tel" placeholder="Telefon" aria-required="true" class="d-contact__input" />
        <textarea name="message" required minlength="10" maxlength="2000" rows="3" placeholder="Co się dzieje? (np. zatrzaśnięte drzwi, ul. X)" aria-required="true" class="d-contact__input"></textarea>

        <label class="d-contact__consent">
          <input type="checkbox" name="consent" required aria-required="true" />
          <span>Zgadzam się na kontakt zwrotny. <a href={clientConfig.rodo.privacyPolicyUrl ?? "/polityka-prywatnosci"}>Polityka prywatności</a></span>
        </label>

        <button type="submit" class="d-contact__submit">Wyślij zgłoszenie →</button>
      </form>
    </details>
  </div>
</section>

<style>
  .d-contact {
    padding-block: clamp(4rem, 7vw, 6rem);
    background: var(--color-surface);
  }
  .d-contact__inner {
    max-width: 80rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Bento-style 2-col: lewa text + sub, prawa duży phone tile.
     Subtelne kolory, surface-muted + akcent na phone button. Brak gradient wallpaper. */
  .d-contact__cta-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    padding: 2rem;
    border-radius: 20px;
    position: relative;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .d-contact__cta-card {
      grid-template-columns: 1.5fr 1fr;
      align-items: center;
      gap: 2.5rem;
      padding: 3rem;
    }
  }
  /* Subtle red glow top-right corner, NOT full gradient */
  .d-contact__cta-card::after {
    content: '';
    position: absolute;
    top: -40%;
    right: -10%;
    width: 50%;
    height: 180%;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-brand) 14%, transparent) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  .d-contact__cta-text { position: relative; z-index: 1; }
  .d-contact__eyebrow {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-brand);
    font-weight: 700;
    margin: 0 0 0.75rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .d-contact__eyebrow::before {
    content: '';
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--color-brand);
    animation: d-contact-dot 1.8s ease-in-out infinite;
  }
  @keyframes d-contact-dot { 50% { opacity: 0.4; } }
  @media (prefers-reduced-motion: reduce) { .d-contact__eyebrow::before { animation: none; } }
  .d-contact__h2 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    margin: 0 0 0.75rem;
    letter-spacing: -0.025em;
    line-height: 1.05;
    text-wrap: balance;
    color: var(--color-text);
  }
  .d-contact__h2 em { font-style: normal; color: var(--color-brand); }
  .d-contact__sub {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.55;
  }
  /* BIG phone button — tile language matching hero */
  .d-contact__phone-btn {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1.5rem 1.75rem;
    background: var(--color-brand);
    color: var(--color-brand-fg);
    text-decoration: none;
    border-radius: 16px;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.25rem, 2.5vw, 1.6rem);
    font-variant-numeric: tabular-nums;
    transition: transform 200ms cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 200ms ease;
    min-height: 72px;
    justify-content: center;
    letter-spacing: -0.01em;
    box-shadow:
      0 8px 24px -8px color-mix(in srgb, var(--color-brand) 50%, transparent),
      inset 0 -3px 0 0 color-mix(in srgb, var(--color-brand) 45%, #000 25%);
  }
  .d-contact__phone-btn:hover {
    transform: translateY(-2px);
    box-shadow:
      0 12px 30px -8px color-mix(in srgb, var(--color-brand) 65%, transparent),
      inset 0 -3px 0 0 color-mix(in srgb, var(--color-brand) 45%, #000 25%);
  }
  .d-contact__phone-btn svg { flex-shrink: 0; }

  /* Form (collapsed by default) */
  .d-contact__form-wrap {
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 1.5rem;
  }
  .d-contact__form-wrap summary {
    cursor: pointer;
    list-style: none;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 44px;
  }
  .d-contact__form-wrap summary::-webkit-details-marker { display: none; }
  .d-contact__form-wrap summary::after { content: '+'; margin-left: auto; font-family: var(--font-mono, ui-monospace, monospace); font-size: 1.25rem; color: var(--color-brand); transition: transform 200ms; }
  .d-contact__form-wrap[open] summary::after { transform: rotate(45deg); }

  .d-contact__form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  .d-contact__input {
    width: 100%;
    padding: 0.95rem 1.1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    border-radius: 8px;
    font: inherit;
    font-size: 0.95rem;
  }
  .d-contact__input::placeholder { color: var(--color-text-muted); }
  .d-contact__input:focus { outline: 2px solid var(--color-brand); outline-offset: 1px; }
  textarea.d-contact__input { resize: vertical; min-height: 100px; }

  .d-contact__consent {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }
  .d-contact__consent a { color: var(--color-brand); }

  .d-contact__submit {
    padding: 1rem 1.5rem;
    background: var(--color-brand);
    color: var(--color-brand-fg);
    border: 0;
    border-radius: 8px;
    font: inherit;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    min-height: 52px;
    transition: transform 200ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .d-contact__submit:hover { transform: translateY(-1px); }

  .d-contact__status:not(:empty) {
    padding: 0.75rem 1rem;
    background: color-mix(in srgb, var(--color-brand) 12%, transparent);
    border-left: 3px solid var(--color-brand);
    color: var(--color-text);
    border-radius: 4px;
    font-size: 0.92rem;
  }
</style>
