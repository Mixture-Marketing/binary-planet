---
/**
 * Dynamic OpeningHours — bento-grid feel. Week at-glance as horizontal day chips,
 * today highlighted with brand bar. No table boxes — clean type-only row.
 */
import {
  computeOpenStatus,
  isEmergency24h,
  openStatusMessage,
  type DayKey,
} from "@mixturemarketing/web-core/local";
import clientConfig from "../../../client.config.ts";

const { hours } = clientConfig;
const DAYS: Array<[DayKey, string, string]> = [
  ["monday", "Pon", "Poniedziałek"],
  ["tuesday", "Wt", "Wtorek"],
  ["wednesday", "Śr", "Środa"],
  ["thursday", "Czw", "Czwartek"],
  ["friday", "Pt", "Piątek"],
  ["saturday", "Sob", "Sobota"],
  ["sunday", "Nd", "Niedziela"],
];
const now = new Date();
const todayIdx = now.getDay() === 0 ? 6 : now.getDay() - 1;
const todayKey = DAYS[todayIdx]![0];

const renderHours = (v: unknown): { open: string; close: string; closed: boolean } => {
  if (v === "closed") return { open: "", close: "", closed: true };
  if (Array.isArray(v) && v.length === 2) return { open: v[0] as string, close: v[1] as string, closed: false };
  return { open: "—", close: "—", closed: true };
};

// Open status
const hoursForStatus: Partial<Record<DayKey, [string, string] | "closed">> & { note?: string } = {
  ...(hours.note !== undefined && { note: hours.note }),
};
for (const k of ["monday","tuesday","wednesday","thursday","friday","saturday","sunday"] as const) {
  const v = hours[k];
  if (v === "closed" || (Array.isArray(v) && v.length === 2)) {
    hoursForStatus[k] = v as [string, string] | "closed";
  }
}
const status = computeOpenStatus({ hours: hoursForStatus });
const has24 = isEmergency24h(hours.note);
const openMsg = openStatusMessage(status);
---

<section aria-labelledby="hours-heading" class="d-hours">
  <div class="container-px d-hours__inner">
    <header class="d-hours__head">
      <span class="d-hours__eyebrow"># godziny otwarcia</span>
      <h2 id="hours-heading" class="d-hours__h2">
        {has24 ? <>Pracujemy <em>24/7</em></> : status.kind === "open" ? <>Otwarte teraz · <em>{(status as { kind: "open"; closesAt: string }).closesAt}</em></> : openMsg}
      </h2>
    </header>

    <div class="d-hours__week" role="list" aria-label="Tygodniowe godziny">
      {DAYS.map(([key, short, full]) => {
        const h = renderHours(hours[key]);
        const isToday = key === todayKey;
        return (
          <div class={`d-day${isToday ? " is-today" : ""}${h.closed ? " is-closed" : ""}`} role="listitem">
            <span class="d-day__short" aria-hidden="true">{short}</span>
            <span class="d-day__full">{full}</span>
            {h.closed ? (
              <span class="d-day__hours d-day__hours--closed">Zamknięte</span>
            ) : (
              <span class="d-day__hours"><strong>{h.open}</strong><span class="d-day__sep">–</span><strong>{h.close}</strong></span>
            )}
          </div>
        );
      })}
    </div>

    {hours.note && <p class="d-hours__note">{hours.note}</p>}
  </div>
</section>

<style>
  .d-hours {
    padding-block: clamp(4rem, 7vw, 6rem);
    background: var(--color-surface);
  }
  .d-hours__inner { max-width: 80rem; margin: 0 auto; }
  .d-hours__head { margin-bottom: 2rem; }
  .d-hours__eyebrow {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.5rem;
  }
  .d-hours__h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    margin: 0;
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--color-text);
  }
  .d-hours__h2 em {
    font-style: normal;
    color: var(--color-brand);
  }

  /* Week — 7 horizontal day rows, today highlighted */
  .d-hours__week {
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
  }
  .d-day {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
    transition: background-color 200ms ease;
  }
  .d-day:last-child { border-bottom: 0; }
  .d-day__short {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .d-day__full {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }
  .d-day__hours {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.95rem;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
  }
  .d-day__hours strong { font-weight: 600; }
  .d-day__sep { color: var(--color-text-muted); }
  .d-day__hours--closed {
    color: var(--color-text-muted);
    font-style: italic;
    font-size: 0.88rem;
  }

  /* Today — brand-color left bar */
  .d-day.is-today {
    background: color-mix(in srgb, var(--color-brand) 6%, transparent);
    position: relative;
  }
  .d-day.is-today::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--color-brand);
  }
  .d-day.is-today .d-day__full {
    color: var(--color-brand);
  }
  .d-day.is-today .d-day__short {
    color: var(--color-brand);
  }
  .d-day.is-today .d-day__hours strong {
    color: var(--color-brand);
    font-weight: 700;
  }

  .d-day.is-closed {
    background: var(--color-surface);
  }
  .d-day.is-closed .d-day__full {
    opacity: 0.6;
  }

  .d-hours__note {
    margin-top: 1rem;
    padding: 1rem 1.25rem;
    background: color-mix(in srgb, var(--color-brand) 8%, transparent);
    border-left: 3px solid var(--color-brand);
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text);
    line-height: 1.5;
  }
</style>
