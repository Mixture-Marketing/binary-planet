---
/**
 * Dynamic Hero — bento grid 4-6 tiles. BIG phone tile (2x2) dominates,
 * live open-status tile (pulsing dot), area-served chips tile,
 * headline tile, before/after proof tile. Mobile: tiles stack with phone first.
 */
import {
  computeOpenStatus,
  formatPolishPhone,
  isEmergency24h,
  openStatusMessage,
  phoneAriaLabel as buildPhoneAriaLabel,
  type DayKey,
} from "@mixturemarketing/web-core/local";
import clientConfig from "../../../client.config.ts";

const { business, contact, location } = clientConfig;
const phoneDisplay = formatPolishPhone(contact.primaryPhone);
const phoneAria = buildPhoneAriaLabel(contact.primaryPhone);
const hasEmergencyNote = isEmergency24h(clientConfig.hours.note);

// Open status
const hoursForStatus: Partial<Record<DayKey, [string, string] | "closed">> & { note?: string } = {
  ...(clientConfig.hours.note !== undefined && { note: clientConfig.hours.note }),
};
for (const k of ["monday","tuesday","wednesday","thursday","friday","saturday","sunday"] as const) {
  const v = clientConfig.hours[k];
  if (v === "closed" || (Array.isArray(v) && v.length === 2)) {
    hoursForStatus[k] = v as [string, string] | "closed";
  }
}
const status = computeOpenStatus({ hours: hoursForStatus });
const openMsg = openStatusMessage(status);

// Area chips — up to 4 + overflow count
const areaChips = location.serviceArea.slice(0, 4);
const overflow = location.serviceArea.length - areaChips.length;

// Phone number split for big display (XX [break] XXX XX XX)
const phoneParts = phoneDisplay.split(" ");
---

<section aria-labelledby="hero-heading" class="d-hero">
  <div class="container-px d-hero__inner">
    <h1 id="hero-heading" class="visually-hidden">{business.name} — {business.tagline}</h1>

    <div class="d-hero__grid">
      {/* BIG PHONE TILE — dominant 2x2 on desktop, full-width on mobile */}
      <a href={`tel:${contact.primaryPhone}`} class="d-tile d-tile--phone" aria-label={phoneAria} data-track-event="phone_click" data-track-position="hero">
        <span class="d-tile__phone-label">
          {hasEmergencyNote ? `Awaryjne wezwania · 24/7 · ${location.address.city}` : `${business.industry} · ${location.address.city}`}
        </span>
        <div class="d-tile__phone-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <div class="d-tile__phone-number">
          {phoneParts.length >= 4 ? (
            <>
              {phoneParts[0]} {phoneParts[1]}<br />
              {phoneParts[2]} {phoneParts[3]} {phoneParts[4] ?? ""}
            </>
          ) : phoneDisplay}
        </div>
        <span class="d-tile__phone-sub">Dojazd 30 min · bez uszkodzenia drzwi</span>
      </a>

      {/* STATUS — green pulse when open */}
      <div class={`d-tile d-tile--status${status.kind === "open" || status.kind === "emergency24h" ? " is-open" : ""}`}>
        <span class="d-tile__status-dot" aria-hidden="true"></span>
        <h2 class="d-tile__status-headline">{openMsg.split(" — ")[0]}{openMsg.includes(" — ") && <small>{openMsg.split(" — ")[1]}</small>}</h2>
        <span class="d-tile__status-meta">{clientConfig.hours.note ?? `Pn–Pt ${(clientConfig.hours.monday as [string, string] | undefined)?.[0] ?? "—"}–${(clientConfig.hours.monday as [string, string] | undefined)?.[1] ?? "—"}`}</span>
      </div>

      {/* AREA — chips */}
      <div class="d-tile d-tile--map">
        <span class="d-tile__map-label">Obszar działania</span>
        <h2 class="d-tile__map-title">{location.address.city}<br /><small>{overflow > 0 ? `+ ${overflow} ${overflow === 1 ? "miejscowość" : "miejscowości"}` : "+ okolice"}</small></h2>
        <div class="d-tile__map-chips">
          {areaChips.map((c) => <span class="d-chip">{c}</span>)}
          {overflow > 0 && <span class="d-chip"><strong>+{overflow}</strong></span>}
        </div>
      </div>

      {/* HEADLINE */}
      <div class="d-tile d-tile--headline">
        <h2 class="d-tile__headline-text">
          {business.tagline.split(" ").slice(0, 4).join(" ")}<br />
          <em>{business.tagline.split(" ").slice(4).join(" ")}</em>
        </h2>
        <span class="d-tile__headline-sub">{business.foundedYear ? `${new Date().getFullYear() - business.foundedYear}+ lat · ` : ""}{clientConfig.reviews?.length ?? 0} opinii Google</span>
      </div>
    </div>
  </div>
</section>

<style>
  .d-hero {
    padding: 1.5rem 0 3rem;
    background: var(--color-surface);
  }
  .d-hero__inner { max-width: 80rem; margin: 0 auto; }
  .d-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-auto-rows: minmax(200px, auto);
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .d-hero__grid {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: repeat(2, minmax(240px, 1fr));
      gap: 1.25rem;
    }
  }

  .d-tile {
    border-radius: 20px;
    padding: 1.85rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 250ms ease;
  }
  .d-tile:hover { transform: translateY(-4px); box-shadow: 0 20px 40px -16px color-mix(in srgb, var(--color-text) 18%, transparent); }
  .d-tile:active { transform: translateY(-1px) scale(0.99); }

  /* PHONE TILE — 2x2 dominant */
  .d-tile--phone {
    background: var(--color-brand);
    color: var(--color-brand-fg);
    min-height: 280px;
  }
  @media (min-width: 768px) {
    .d-tile--phone { grid-column: span 2; grid-row: span 2; }
  }
  .d-tile--phone::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 70% 30%, color-mix(in srgb, var(--color-accent) 50%, transparent) 0%, transparent 50%);
    pointer-events: none;
  }
  .d-tile__phone-label {
    position: relative;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.9;
  }
  .d-tile__phone-icon {
    width: 56px;
    height: 56px;
    background: rgba(255,255,255,0.18);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .d-tile__phone-icon::before {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.6);
    animation: d-pulse-ring 1.8s ease-out infinite;
  }
  @keyframes d-pulse-ring {
    0% { transform: scale(0.8); opacity: 1; }
    100% { transform: scale(1.6); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) { .d-tile__phone-icon::before { animation: none; } }
  .d-tile__phone-icon svg { width: 28px; height: 28px; color: var(--color-brand-fg); }
  .d-tile__phone-number {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    letter-spacing: -0.025em;
    line-height: 0.95;
    margin-top: auto;
    font-variant-numeric: tabular-nums;
    position: relative;
  }
  .d-tile__phone-sub {
    position: relative;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.85rem;
    opacity: 0.9;
  }

  /* STATUS TILE */
  .d-tile--status {
    background: linear-gradient(135deg, #1a1410 0%, #2a1f15 100%);
    color: #fff;
  }
  .d-tile--status.is-open {
    background: linear-gradient(135deg, #052e1c 0%, #0d5d3b 100%);
  }
  .d-tile__status-dot {
    width: 12px; height: 12px;
    background: #fbbf24;
    border-radius: 50%;
    position: relative;
    box-shadow: 0 0 0 4px color-mix(in srgb, #fbbf24 25%, transparent), 0 0 0 12px color-mix(in srgb, #fbbf24 10%, transparent);
  }
  .d-tile--status.is-open .d-tile__status-dot {
    background: #4ade80;
    box-shadow: none;
  }
  .d-tile--status.is-open .d-tile__status-dot::before,
  .d-tile--status.is-open .d-tile__status-dot::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #4ade80;
    will-change: transform, opacity;
    animation: d-pulse-soft 2s ease-out infinite;
  }
  .d-tile--status.is-open .d-tile__status-dot::after { animation-delay: 1s; }
  @keyframes d-pulse-soft {
    0%   { transform: scale(1);   opacity: 0.5; }
    100% { transform: scale(2.8); opacity: 0;   }
  }
  @media (prefers-reduced-motion: reduce) {
    .d-tile--status.is-open .d-tile__status-dot::before,
    .d-tile--status.is-open .d-tile__status-dot::after { animation: none; opacity: 0; }
  }
  .d-tile__status-headline {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .d-tile__status-headline small { display: block; font-size: 0.6em; font-weight: 500; opacity: 0.8; margin-top: 0.25rem; }
  .d-tile__status-meta {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    opacity: 0.8;
    margin-top: auto;
  }

  /* MAP TILE */
  .d-tile--map {
    background: var(--color-surface-muted);
    border: 1px solid var(--color-border);
  }
  .d-tile__map-label {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .d-tile__map-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    margin: 0;
    line-height: 1.1;
    color: var(--color-text);
  }
  .d-tile__map-title small { display: block; font-size: 0.85rem; font-weight: 500; color: var(--color-text-muted); margin-top: 0.25rem; }
  .d-tile__map-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
  }
  .d-chip {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-text);
  }
  .d-chip strong { color: var(--color-brand); font-weight: 700; }

  /* HEADLINE TILE */
  .d-tile--headline {
    background: var(--color-text);
    color: var(--color-surface);
    grid-column: span 1;
  }
  @media (min-width: 768px) { .d-tile--headline { grid-column: span 2; } }
  .d-tile__headline-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0;
    text-wrap: balance;
  }
  .d-tile__headline-text em {
    font-style: italic;
    color: var(--color-accent);
  }
  .d-tile__headline-sub {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.85rem;
    opacity: 0.65;
    margin-top: auto;
  }
</style>
