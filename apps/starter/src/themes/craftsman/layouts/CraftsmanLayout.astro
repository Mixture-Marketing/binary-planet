---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  jsonLd?: unknown[];
  ogImage?: string;
}

const props = Astro.props;
---

<BaseLayout {...props}>
  <Header />
  <main id="main" tabindex="-1">
    <slot />
  </main>
  <Footer />
</BaseLayout>
