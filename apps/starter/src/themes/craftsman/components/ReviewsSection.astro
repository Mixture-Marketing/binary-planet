---
import clientConfig from "../../../client.config.ts";

const { reviews = [] } = clientConfig;
const limit = 3;
const displayed = reviews.slice(0, limit);

const avg = reviews.length
  ? (reviews.reduce((sum, r) => sum + r.rating, 0) / reviews.length).toFixed(1)
  : null;

const formatDate = (iso: string): string => {
  const d = new Date(iso);
  return d.toLocaleDateString("pl-PL", { year: "numeric", month: "long" });
};
---

{displayed.length > 0 && (
  <section aria-labelledby="reviews-heading" class="section-py">
    <div class="container-px">
      <div style="display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between; gap: 1rem; margin-bottom: 2.5rem;">
        <h2 id="reviews-heading" style="font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight: 700; margin: 0;">
          Opinie klientów
        </h2>
        {avg && (
          <p style="margin: 0; font-size: 1.15rem; color: var(--color-text-muted);">
            <strong style="color: var(--color-brand); font-size: 1.5rem;">{avg}</strong>
            <span style="margin-left: 0.5rem;">⭐⭐⭐⭐⭐</span>
            <span style="margin-left: 0.5rem;">({reviews.length} opinii)</span>
          </p>
        )}
      </div>

      <ul style="display: grid; gap: 1.5rem; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); list-style: none; margin: 0; padding: 0;">
        {displayed.map((review) => (
          <li
            style="background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 1.75rem; display: flex; flex-direction: column; gap: 1rem;"
          >
            <div aria-label={`Ocena: ${review.rating} z 5`} style="color: var(--color-accent); font-size: 1.15rem;">
              {"⭐".repeat(review.rating)}
            </div>
            <p style="margin: 0; color: var(--color-text); font-style: italic;">
              „{review.text}"
            </p>
            <p style="margin: 0; font-weight: 600;">
              {review.author}
              <span style="display: block; font-size: 0.85rem; color: var(--color-text-muted); font-weight: 400; margin-top: 0.25rem;">
                {formatDate(review.date)}
              </span>
            </p>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}
