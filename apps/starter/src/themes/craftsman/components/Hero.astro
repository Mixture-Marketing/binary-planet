---
import clientConfig from "../../../client.config.ts";

const { business, contact, location } = clientConfig;
const cityName = location.address.city;
---

<section
  aria-labelledby="hero-heading"
  style="background: linear-gradient(135deg, var(--color-surface-muted) 0%, var(--color-surface) 100%); position: relative; overflow: hidden;"
  class="section-py"
>
  <div class="container-px" style="display: grid; gap: 2.5rem; align-items: center;">
    <div>
      <p style="display: inline-block; background: var(--color-brand); color: var(--color-brand-fg); padding: 0.35rem 0.85rem; border-radius: 999px; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.02em; margin-bottom: 1.25rem;">
        🚨 Awaryjne wezwania 24/7
      </p>

      <h1 id="hero-heading" style="font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; margin: 0 0 1.25rem 0; letter-spacing: -0.02em;">
        {business.name} — {cityName}
      </h1>

      <p style="font-size: clamp(1.1rem, 2vw, 1.35rem); color: var(--color-text-muted); margin: 0 0 2rem 0; max-width: 40rem;">
        {business.tagline}
      </p>

      <div style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: center;">
        <a href={`tel:${contact.primaryPhone}`} class="btn-primary" data-track-event="phone_click" data-track-position="hero">
          <span aria-hidden="true">📞</span>
          Zadzwoń teraz: {contact.primaryPhone}
        </a>
        <a href="/kontakt" class="btn-outline">
          Napisz wiadomość
        </a>
      </div>

      <ul style="display: flex; flex-wrap: wrap; gap: 1.25rem; list-style: none; margin: 2rem 0 0 0; padding: 0; color: var(--color-text-muted); font-size: 0.95rem;">
        <li style="display: flex; align-items: center; gap: 0.4rem;">
          <span aria-hidden="true" style="color: var(--color-brand);">✓</span>
          Dojazd 30 minut
        </li>
        <li style="display: flex; align-items: center; gap: 0.4rem;">
          <span aria-hidden="true" style="color: var(--color-brand);">✓</span>
          Bez uszkodzeń drzwi
        </li>
        <li style="display: flex; align-items: center; gap: 0.4rem;">
          <span aria-hidden="true" style="color: var(--color-brand);">✓</span>
          {business.foundedYear ? `Od ${business.foundedYear} roku` : "20+ lat doświadczenia"}
        </li>
      </ul>
    </div>
  </div>
</section>
