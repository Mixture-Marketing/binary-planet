---
import clientConfig from "../../../client.config.ts";

interface Props {
  heading?: string;
}
const { heading = "Napisz wiadomość" } = Astro.props;

const turnstileSiteKey = clientConfig.integrations.turnstileSiteKey;
const consentVersion = clientConfig.rodo.consentVersion;
---

<section aria-labelledby="contact-heading" class="section-py" style="background: var(--color-surface-muted);">
  <div class="container-px">
    <h2 id="contact-heading" style="font-size: clamp(1.75rem, 3.5vw, 2.5rem); font-weight: 700; margin: 0 0 0.5rem 0;">
      {heading}
    </h2>
    <p style="color: var(--color-text-muted); font-size: 1.1rem; margin: 0 0 2rem 0;">
      Odpowiadam zwykle w ciągu godziny w godzinach pracy
    </p>

    <form
      id="contact-form"
      method="POST"
      action="/api/contact"
      style="display: grid; gap: 1.25rem; max-width: 36rem; background: var(--color-surface); padding: 2rem; border-radius: var(--radius-lg); border: 1px solid var(--color-border);"
      novalidate
    >
      <input type="hidden" name="consent_text_version" value={consentVersion} />
      <input type="hidden" name="source_page" value={Astro.url.pathname} />
      {/* Honeypot — hidden field, filled by bots */}
      <label style="position: absolute; left: -9999px;" aria-hidden="true">
        <input type="text" name="honeypot" tabindex="-1" autocomplete="off" />
      </label>

      <div>
        <label for="cf-name" style="display: block; font-weight: 600; margin-bottom: 0.4rem;">
          Imię i nazwisko <span aria-label="wymagane" style="color: var(--color-brand);">*</span>
        </label>
        <input
          id="cf-name"
          name="name"
          type="text"
          required
          minlength="2"
          maxlength="100"
          autocomplete="name"
          style="width: 100%; padding: 0.75rem 1rem; border: 2px solid var(--color-border); border-radius: var(--radius-sm); font: inherit; background: var(--color-surface);"
        />
      </div>

      <div>
        <label for="cf-email" style="display: block; font-weight: 600; margin-bottom: 0.4rem;">
          E-mail <span aria-label="wymagane" style="color: var(--color-brand);">*</span>
        </label>
        <input
          id="cf-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          inputmode="email"
          style="width: 100%; padding: 0.75rem 1rem; border: 2px solid var(--color-border); border-radius: var(--radius-sm); font: inherit; background: var(--color-surface);"
        />
      </div>

      <div>
        <label for="cf-phone" style="display: block; font-weight: 600; margin-bottom: 0.4rem;">
          Telefon
        </label>
        <input
          id="cf-phone"
          name="phone"
          type="tel"
          autocomplete="tel"
          inputmode="tel"
          placeholder="+48 504 123 456"
          style="width: 100%; padding: 0.75rem 1rem; border: 2px solid var(--color-border); border-radius: var(--radius-sm); font: inherit; background: var(--color-surface);"
        />
      </div>

      <div>
        <label for="cf-service" style="display: block; font-weight: 600; margin-bottom: 0.4rem;">
          Czego potrzebujesz?
        </label>
        <select
          id="cf-service"
          name="service_interest"
          style="width: 100%; padding: 0.75rem 1rem; border: 2px solid var(--color-border); border-radius: var(--radius-sm); font: inherit; background: var(--color-surface);"
        >
          <option value="">Wybierz usługę…</option>
          {clientConfig.services.map((s) => (
            <option value={s.slug}>{s.name}</option>
          ))}
          <option value="other">Inne / nie wiem</option>
        </select>
      </div>

      <div>
        <label for="cf-message" style="display: block; font-weight: 600; margin-bottom: 0.4rem;">
          Wiadomość
        </label>
        <textarea
          id="cf-message"
          name="message"
          rows="5"
          maxlength="2000"
          style="width: 100%; padding: 0.75rem 1rem; border: 2px solid var(--color-border); border-radius: var(--radius-sm); font: inherit; background: var(--color-surface); resize: vertical;"
        ></textarea>
      </div>

      {turnstileSiteKey && (
        <div class="cf-turnstile" data-sitekey={turnstileSiteKey}></div>
        <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
      )}

      <label style="display: flex; gap: 0.6rem; align-items: flex-start; cursor: pointer;">
        <input type="checkbox" name="consent_processing" required style="margin-top: 0.25rem;" />
        <span style="font-size: 0.9rem; color: var(--color-text-muted);">
          Wyrażam zgodę na przetwarzanie moich danych osobowych w celu odpowiedzi na zapytanie zgodnie z RODO.
          <span aria-label="wymagane" style="color: var(--color-brand);">*</span>
        </span>
      </label>

      <label style="display: flex; gap: 0.6rem; align-items: flex-start; cursor: pointer;">
        <input type="checkbox" name="consent_marketing" style="margin-top: 0.25rem;" />
        <span style="font-size: 0.9rem; color: var(--color-text-muted);">
          (Opcjonalnie) Chcę otrzymywać oferty i informacje marketingowe drogą elektroniczną.
        </span>
      </label>

      <button type="submit" class="btn-primary" style="margin-top: 0.5rem;">
        Wyślij wiadomość
      </button>

      <div id="contact-form-status" role="status" aria-live="polite" style="min-height: 1.5rem;"></div>
    </form>

    <script is:inline nonce={Astro.locals.nonce}>
      (() => {
        const form = document.getElementById("contact-form");
        const status = document.getElementById("contact-form-status");
        if (!form || !status) return;

        form.addEventListener("submit", async (e) => {
          e.preventDefault();
          status.textContent = "Wysyłam…";
          status.style.color = "";

          const formData = new FormData(form);
          // Convert FormData to JSON
          const body = {};
          for (const [k, v] of formData.entries()) {
            body[k] = v;
          }

          try {
            const res = await fetch(form.action, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(body),
            });
            const json = await res.json();
            if (res.ok && json.ok) {
              status.textContent = json.message || "Dziękujemy! Wiadomość została wysłana.";
              status.style.color = "var(--color-brand)";
              form.reset();
              if (window.plausible) window.plausible("lead_form_submit", { props: { service: body.service_interest || "unknown" } });
            } else {
              status.textContent = json.message || "Coś poszło nie tak. Spróbuj ponownie lub zadzwoń.";
              status.style.color = "var(--color-brand)";
            }
          } catch (err) {
            status.textContent = "Brak połączenia. Spróbuj zadzwonić bezpośrednio.";
            status.style.color = "var(--color-brand)";
          }
        });
      })();
    </script>
  </div>
</section>
