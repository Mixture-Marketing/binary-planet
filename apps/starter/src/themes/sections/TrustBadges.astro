---
/**
 * Trust badges section — uprawnienia, polisa OC, certyfikaty (Professional tier).
 * Config: { heading?, items: Array<{ label, value, type? }> }
 *
 * Type guides icon: 'license' / 'insurance' / 'chamber' / 'certificate' / 'award'
 */
import Icon from "../dynamic/components/Icon.astro";

interface Props {
  config?: {
    heading?: string;
    items?: Array<{
      label: string;
      value: string;
      type?: "license" | "insurance" | "chamber" | "certificate" | "award";
    }>;
  };
}
const { config = {} } = Astro.props;
const heading = config.heading ?? "Uprawnienia i gwarancje";
const items = config.items ?? [];

const TYPE_ICON: Record<string, "shield-check" | "check-circle-2" | "briefcase" | "star"> = {
  license: "shield-check",
  insurance: "shield-check",
  chamber: "briefcase",
  certificate: "check-circle-2",
  award: "star",
};
---

{items.length > 0 && (
  <section aria-labelledby="trust-heading" class="sec-trust">
    <div class="container-px">
      <header class="sec-trust__head">
        <p class="sec-trust__overline">Zaufanie</p>
        <h2 id="trust-heading">{heading}</h2>
      </header>

      <ul class="sec-trust__grid">
        {items.map((it) => {
          const iconName = (it.type && TYPE_ICON[it.type]) ?? "shield-check";
          return (
            <li class="sec-trust__card">
              <div class="sec-trust__icon">
                <Icon name={iconName as any} size={24} />
              </div>
              <div class="sec-trust__main">
                <div class="sec-trust__label">{it.label}</div>
                <div class="sec-trust__value">{it.value}</div>
              </div>
            </li>
          );
        })}
      </ul>
    </div>
  </section>
)}

<style>
  .sec-trust { padding-block: 4rem; background: var(--color-surface-muted); }
  .sec-trust__head { text-align: center; margin-bottom: 2.5rem; }
  .sec-trust__overline {
    font-family: var(--font-body);
    font-size: 0.75rem; font-weight: 600;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--color-accent); margin: 0 0 0.5rem 0;
  }
  .sec-trust__head h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 600;
    margin: 0;
    color: var(--color-text);
    letter-spacing: -0.02em;
  }
  .sec-trust__grid {
    list-style: none; margin: 0; padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) { .sec-trust__grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .sec-trust__grid { grid-template-columns: repeat(4, 1fr); } }
  .sec-trust__card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.25rem;
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
  }
  .sec-trust__icon {
    width: 44px; height: 44px;
    border-radius: 6px;
    background: color-mix(in srgb, var(--color-brand) 12%, transparent);
    color: var(--color-brand);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .sec-trust__main { flex: 1; min-width: 0; }
  .sec-trust__label {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }
  .sec-trust__value {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.3;
    overflow-wrap: anywhere;
  }
</style>
