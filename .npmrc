# GitHub Packages registry for @mixturemarketing scope
# Wymaga env var NODE_AUTH_TOKEN (GitHub Personal Access Token z scope read:packages, write:packages)
@mixturemarketing:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}

# pnpm settings
auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
prefer-workspace-packages=true
link-workspace-packages=true
